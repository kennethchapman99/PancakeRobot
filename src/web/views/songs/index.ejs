<% title = 'Song Catalog' %>
<%
  const brandMap = {};
  for (const p of (profiles || [])) brandMap[p.id] = p.name;
  function brandLabel(id) { return id ? (brandMap[id] || id) : null; }
  const activeSort = typeof sort !== 'undefined' ? sort : '';
  const activeActivity = typeof filterActivity !== 'undefined' ? filterActivity : '';
  const hasServerFilters = Boolean(q || filterStatus || filterBrand || activeSort);
%>

<div class="p-4 sm:p-6 lg:p-8" x-data="catalog()">
  <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h1 class="text-3xl font-black tracking-tight text-zinc-900">Song Catalog</h1>
      <p class="mt-1 text-sm text-zinc-500" id="song-count"><%= songs.length %> song<%= songs.length !== 1 ? 's' : '' %></p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <a href="/ideas" class="rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-700 shadow-sm transition hover:border-zinc-300 hover:bg-zinc-50">From Idea</a>
    </div>
  </div>

  <form method="GET" action="/songs" class="mb-4 rounded-3xl border border-zinc-200 bg-white p-4 shadow-sm" id="song-catalog-filters">
    <div class="grid gap-3 lg:grid-cols-[minmax(0,1.7fr)_220px_220px_200px_200px_auto_auto]">
      <input type="text" name="q" value="<%= q %>" placeholder="Search songs, notes, or topics…"
        class="w-full rounded-2xl border border-zinc-200 px-4 py-3 text-sm text-zinc-800 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-900">

      <% if ((profiles || []).length > 1) { %>
      <select name="brand" class="rounded-2xl border border-zinc-200 px-4 py-3 text-sm text-zinc-700 focus:outline-none">
        <option value="">All brand profiles</option>
        <% for (const p of profiles) { %>
          <option value="<%= p.id %>" <%= filterBrand === p.id ? 'selected' : '' %>><%= p.name %></option>
        <% } %>
      </select>
      <% } else { %>
      <input type="hidden" name="brand" value="<%= filterBrand || '' %>">
      <div class="rounded-2xl border border-zinc-100 bg-zinc-50 px-4 py-3 text-sm text-zinc-500">Brand: <%= brandLabel(filterBrand) || brandLabel((profiles || [])[0]?.id) || 'Default' %></div>
      <% } %>

      <select name="status" class="rounded-2xl border border-zinc-200 px-4 py-3 text-sm text-zinc-700 focus:outline-none">
        <option value="">All statuses</option>
        <% for (const option of songStatusOptions) { %>
          <option value="<%= option.value %>" <%= filterStatus === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% } %>
      </select>

      <select name="activity" id="activity-filter" class="rounded-2xl border border-zinc-200 px-4 py-3 text-sm text-zinc-700 focus:outline-none">
        <option value="">All activity dates</option>
        <option value="7" <%= activeActivity === '7' ? 'selected' : '' %>>Latest activity: 7 days</option>
        <option value="30" <%= activeActivity === '30' ? 'selected' : '' %>>Latest activity: 30 days</option>
        <option value="90" <%= activeActivity === '90' ? 'selected' : '' %>>Latest activity: 90 days</option>
      </select>

      <select name="sort" class="rounded-2xl border border-zinc-200 px-4 py-3 text-sm text-zinc-700 focus:outline-none">
        <option value="" <%= activeSort === '' ? 'selected' : '' %>>Latest activity first</option>
        <option value="created" <%= activeSort === 'created' ? 'selected' : '' %>>Created newest first</option>
        <option value="title" <%= activeSort === 'title' ? 'selected' : '' %>>Title A–Z</option>
        <option value="status" <%= activeSort === 'status' ? 'selected' : '' %>>Status</option>
      </select>

      <button type="submit" class="rounded-2xl bg-zinc-900 px-4 py-3 text-sm font-semibold text-white transition hover:bg-zinc-700">Apply</button>
      <a href="/songs" id="clear-catalog-filters" class="rounded-2xl border border-zinc-200 px-4 py-3 text-center text-sm font-medium text-zinc-500 transition hover:bg-zinc-50 hover:text-zinc-700 <%= hasServerFilters ? '' : 'hidden' %>">Clear</a>
    </div>
  </form>

  <div id="active-filter-chips" class="mb-5 flex flex-wrap gap-2 text-xs font-semibold">
    <% if (q) { %>
      <span class="rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-zinc-600 shadow-sm">Search: <%= q %></span>
    <% } %>
    <% if (filterBrand) { %>
      <span class="rounded-full border border-violet-200 bg-violet-50 px-3 py-1.5 text-violet-700 shadow-sm">Brand: <%= brandLabel(filterBrand) %></span>
    <% } %>
    <% if (filterStatus) { %>
      <span class="rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-zinc-600 shadow-sm">Status: <%= songStatusLabel(filterStatus) %></span>
    <% } %>
    <% if (activeSort) { %>
      <span class="rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-zinc-600 shadow-sm">Sort: <%= activeSort === 'created' ? 'Created newest first' : activeSort === 'title' ? 'Title A–Z' : activeSort === 'status' ? 'Status' : activeSort %></span>
    <% } %>
  </div>

  <div x-show="selected.length > 0" x-cloak class="sticky top-4 z-20 mb-5 rounded-2xl border border-zinc-900 bg-zinc-900 px-4 py-3 text-white shadow-2xl">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex items-center gap-3 text-sm">
        <label class="inline-flex items-center gap-2">
          <input type="checkbox" class="rounded border-zinc-600 bg-zinc-800" @change="toggleAll($event.target.checked)" :checked="selected.length === totalCards && totalCards > 0">
          <span x-text="selected.length + ' selected'"></span>
        </label>
        <button @click="clearSelection()" class="text-zinc-300 transition hover:text-white">Clear</button>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <button @click="runBulkAnalysis()" class="rounded-xl border border-zinc-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-zinc-800">Run A&R Analysis</button>
        <button @click="applyReleaseAction('publish')" class="rounded-xl bg-white px-3 py-2 text-xs font-semibold text-zinc-900 transition hover:bg-zinc-100">Approve Selected for Release Packaging</button>
        <button @click="applyReleaseAction('edit')" class="rounded-xl border border-zinc-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-zinc-800">Send Selected to Editing</button>
        <button @click="applyReleaseAction('hold')" class="rounded-xl border border-zinc-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-zinc-800">Hold Selected</button>
        <select x-model="bulkStatus" class="rounded-xl border border-zinc-700 bg-zinc-800 px-3 py-2 text-xs text-white focus:outline-none">
          <option value="">Set status…</option>
          <% for (const option of songStatusOptions) { %>
            <option value="<%= option.value %>"><%= option.label %></option>
          <% } %>
        </select>
        <button @click="applyBulkStatus()" :disabled="!bulkStatus" class="rounded-xl bg-white px-3 py-2 text-xs font-semibold text-zinc-900 transition hover:bg-zinc-100 disabled:opacity-40">Update Status</button>
        <button @click="archiveSelected()" class="rounded-xl border border-zinc-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-zinc-800">Archive</button>
      </div>
    </div>
  </div>

  <% if (songs.length === 0) { %>
    <div class="rounded-3xl border border-dashed border-zinc-300 bg-zinc-50 px-6 py-20 text-center text-zinc-400">
      <div class="mb-4 text-5xl">🎵</div>
      <div class="text-lg font-medium text-zinc-500">No songs found</div>
      <div class="mt-2 text-sm">
        <% if (q || filterStatus || filterBrand) { %>
          Try adjusting your filters, or <a href="/songs" class="underline">clear them</a>.
        <% } else { %>
          <a href="/ideas" class="underline">Promote an idea</a> to get started.
        <% } %>
      </div>
    </div>
  <% } else { %>
    <div class="hidden rounded-2xl px-5 pb-2 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-400 lg:grid"
         style="grid-template-columns: 44px minmax(0,2.4fr) 160px 170px 170px 170px;">
      <div>Select</div>
      <div>Song</div>
      <div>Brand Profile</div>
      <div>Status</div>
      <div>Latest Activity</div>
      <div>Actions</div>
    </div>

    <div class="space-y-4" id="song-catalog-list">
      <% for (const song of songs) { %>
      <% const latestActivityAt = song.latest_activity_at || song.updated_at || song.published_at || song.distributor_submission_date || song.created_at; %>
      <article id="song-card-<%= song.id %>"
        data-song-card="true"
        data-latest-activity="<%= latestActivityAt || '' %>"
        class="rounded-[28px] border border-zinc-200 bg-white shadow-[0_12px_30px_rgba(15,23,42,0.06)] transition hover:-translate-y-0.5 hover:border-zinc-300 hover:shadow-[0_18px_45px_rgba(15,23,42,0.09)]"
        :class="selected.includes('<%= song.id %>') ? 'ring-2 ring-zinc-900 border-zinc-900' : ''">
        <div class="grid gap-4 p-4 lg:items-center lg:p-5">
          <div class="flex items-start gap-4 lg:hidden">
            <input type="checkbox" class="mt-1 h-4 w-4 rounded border-zinc-300 accent-zinc-900"
              :checked="selected.includes('<%= song.id %>')"
              @change="toggleOne('<%= song.id %>', $event.target.checked)">
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2">
                <a href="/songs/<%= song.id %>" class="text-lg font-bold leading-tight text-zinc-900 hover:text-zinc-700"><%= song.title || song.topic || song.id %></a>
                <% if (song.brand_profile_id) { %>
                <span class="rounded-full bg-violet-50 px-2.5 py-1 text-[11px] font-semibold text-violet-700"><%= brandLabel(song.brand_profile_id) %></span>
                <% } %>
              </div>
              <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-zinc-500">
                <span><%= song.durationLabel %></span>
                <span>•</span>
                <span><%= song.wordCount %> words</span>
                <span>•</span>
                <span>Latest activity <%= timeAgo(latestActivityAt) %></span>
              </div>
              <p class="mt-3 line-clamp-2 text-sm leading-6 text-zinc-600"><%= song.description %></p>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class="rounded-full border px-2.5 py-1 text-[11px] font-semibold <%= statusBadge(song.status) %>"><%= songStatusLabel(song.status) %></span>
                <span class="rounded-full border border-zinc-200 bg-zinc-50 px-2.5 py-1 text-[11px] font-semibold text-zinc-600"><%= song.hasAudio ? 'audio' : 'no audio' %></span>
                <span class="rounded-full border border-zinc-200 bg-zinc-50 px-2.5 py-1 text-[11px] font-semibold text-zinc-600"><%= song.hasArtwork ? 'artwork' : 'no artwork' %></span>
                <span class="rounded-full border border-zinc-200 bg-zinc-50 px-2.5 py-1 text-[11px] font-semibold text-zinc-600"><%= song.hasMarketingPack ? 'marketing pack' : 'no pack yet' %></span>
              </div>
              <div class="mt-4 grid gap-2 sm:grid-cols-[minmax(0,1fr)_auto_auto]">
                <select onchange="changeSongStatus('<%= song.id %>', this.value)" class="rounded-xl border border-zinc-200 px-3 py-2 text-sm text-zinc-700 focus:outline-none">
                  <% for (const option of songStatusOptions) { %>
                    <option value="<%= option.value %>" <%= song.status === option.value ? 'selected' : '' %>><%= option.label %></option>
                  <% } %>
                </select>
                <a href="/songs/<%= song.id %>" class="rounded-xl border border-zinc-200 px-3 py-2 text-center text-sm font-medium text-zinc-700 transition hover:bg-zinc-50">Open</a>
                <a href="/songs/<%= song.id %>?tab=marketing" class="rounded-xl bg-zinc-900 px-3 py-2 text-center text-sm font-semibold text-white transition hover:bg-zinc-700">Marketing</a>
              </div>
            </div>
          </div>

          <div class="hidden lg:grid lg:items-center lg:gap-4" style="grid-template-columns: 44px minmax(0,2.4fr) 160px 170px 170px 170px;">
            <div>
              <input type="checkbox" class="h-4 w-4 rounded border-zinc-300 accent-zinc-900"
                :checked="selected.includes('<%= song.id %>')"
                @change="toggleOne('<%= song.id %>', $event.target.checked)">
            </div>

            <div class="min-w-0">
              <div class="flex items-center gap-3">
                <% if (song.previewImageUrl) { %>
                  <img src="<%= song.previewImageUrl %>" alt="<%= song.title || song.topic %>" class="h-14 w-14 shrink-0 rounded-2xl border border-zinc-200 object-cover">
                <% } else { %>
                  <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-zinc-200 bg-gradient-to-br from-zinc-100 to-zinc-200 text-xl text-zinc-400">🎵</div>
                <% } %>
                <div class="min-w-0">
                  <a href="/songs/<%= song.id %>" class="block truncate text-base font-bold text-zinc-900 hover:text-zinc-700"><%= song.title || song.topic || song.id %></a>
                  <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-zinc-500">
                    <span><%= song.durationLabel %></span>
                    <span>•</span>
                    <span><%= song.wordCount %> words</span>
                    <span>•</span>
                    <span><%= song.id %></span>
                  </div>
                  <p class="mt-2 line-clamp-2 text-sm leading-6 text-zinc-600"><%= song.description %></p>
                </div>
              </div>
            </div>

            <div>
              <% if (song.brand_profile_id) { %>
                <span class="inline-flex rounded-full bg-violet-50 px-2.5 py-1 text-[11px] font-semibold text-violet-700"><%= brandLabel(song.brand_profile_id) %></span>
              <% } else { %>
                <span class="text-xs text-zinc-400">—</span>
              <% } %>
            </div>

            <div>
              <span class="inline-flex rounded-full border px-2.5 py-1 text-[11px] font-semibold <%= statusBadge(song.status) %>"><%= songStatusLabel(song.status) %></span>
              <select onchange="changeSongStatus('<%= song.id %>', this.value)" class="mt-2 block w-full rounded-xl border border-zinc-200 px-3 py-2 text-xs text-zinc-700 focus:outline-none">
                <% for (const option of songStatusOptions) { %>
                  <option value="<%= option.value %>" <%= song.status === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% } %>
              </select>
            </div>

            <div class="text-sm text-zinc-600">
              <div class="font-semibold text-zinc-800"><%= timeAgo(latestActivityAt) %></div>
              <div class="mt-1 text-xs text-zinc-400"><%= formatDateTime(latestActivityAt) %></div>
            </div>

            <div class="flex flex-col gap-2">
              <a href="/songs/<%= song.id %>" class="rounded-xl border border-zinc-200 px-3 py-2 text-center text-sm font-medium text-zinc-700 transition hover:bg-zinc-50">Open Song</a>
              <div class="grid grid-cols-2 gap-2">
                <a href="/songs/<%= song.id %>/edit" class="rounded-xl border border-zinc-200 px-3 py-2 text-center text-xs font-medium text-zinc-600 transition hover:bg-zinc-50">Edit</a>
                <a href="/songs/<%= song.id %>?tab=marketing" class="rounded-xl bg-zinc-900 px-3 py-2 text-center text-xs font-semibold text-white transition hover:bg-zinc-700">Marketing</a>
              </div>
            </div>
          </div>
        </div>
      </article>
      <% } %>
    </div>
    <div id="activity-empty-state" class="hidden rounded-3xl border border-dashed border-zinc-300 bg-zinc-50 px-6 py-20 text-center text-zinc-400">
      <div class="mb-4 text-5xl">🎵</div>
      <div class="text-lg font-medium text-zinc-500">No songs found for that activity window</div>
      <div class="mt-2 text-sm"><a href="/songs" class="underline">Clear filters</a></div>
    </div>
  <% } %>
</div>

<script>
window.catalog = function() {
  return {
    selected: [],
    bulkStatus: '',
    get totalCards() { return document.querySelectorAll('[data-song-card]:not(.hidden)').length; },
    toggleOne(id, checked) {
      if (checked) {
        if (!this.selected.includes(id)) this.selected.push(id);
      } else {
        this.selected = this.selected.filter(item => item !== id);
      }
    },
    toggleAll(checked) {
      if (checked) {
        this.selected = Array.from(document.querySelectorAll('[data-song-card]:not(.hidden)')).map(el => el.id.replace('song-card-', ''));
      } else {
        this.selected = [];
      }
    },
    clearSelection() {
      this.selected = [];
      this.bulkStatus = '';
    },
    async applyBulkStatus() {
      if (!this.bulkStatus || !this.selected.length) return;
      const response = await fetch('/api/songs/bulk-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: [...this.selected], status: this.bulkStatus }),
      });
      const data = await response.json();
      if (!data.ok) return alert(data.error || 'Bulk status update failed');
      window.location.reload();
    },
    async archiveSelected() {
      this.bulkStatus = 'archived';
      await this.applyBulkStatus();
    },
    async runBulkAnalysis() {
      if (!this.selected.length) return;
      const response = await fetch('/api/batches/manual-selection/release-selection/analyze', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ songIds: [...this.selected], limit: this.selected.length }),
      });
      const data = await response.json();
      if (!data.ok) return alert(data.error || 'A&R analysis failed');
      window.location.reload();
    },
    async applyReleaseAction(action) {
      if (!this.selected.length) return;
      const results = await Promise.all(this.selected.map(async songId => {
        const response = await fetch('/api/songs/' + songId + '/release-selection/approve', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action }),
        });
        return response.json();
      }));
      const failed = results.find(item => !item.ok);
      if (failed) return alert(failed.error || 'Release-selection action failed');
      window.location.reload();
    },
  };
};

async function changeSongStatus(songId, status) {
  const response = await fetch('/api/songs/' + songId + '/status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status }),
  });
  const data = await response.json();
  if (!data.ok) {
    alert(data.error || 'Status update failed');
    return;
  }
  window.location.reload();
}

(function setupActivityFilter() {
  const params = new URLSearchParams(window.location.search);
  const activity = params.get('activity') || '';
  const select = document.getElementById('activity-filter');
  if (select) select.value = activity;

  const clearLink = document.getElementById('clear-catalog-filters');
  if (clearLink && activity) clearLink.classList.remove('hidden');

  const chips = document.getElementById('active-filter-chips');
  if (chips && activity) {
    const chip = document.createElement('span');
    chip.className = 'rounded-full border border-zinc-200 bg-white px-3 py-1.5 text-zinc-600 shadow-sm';
    chip.textContent = 'Latest activity: ' + activity + ' days';
    chips.appendChild(chip);
  }

  const days = Number(activity);
  if (!Number.isFinite(days) || days <= 0) return;

  const cutoff = Date.now() - (days * 24 * 60 * 60 * 1000);
  const cards = Array.from(document.querySelectorAll('[data-song-card]'));
  let visible = 0;

  for (const card of cards) {
    const raw = card.getAttribute('data-latest-activity');
    const timestamp = raw ? new Date(raw).getTime() : 0;
    const show = timestamp >= cutoff;
    card.classList.toggle('hidden', !show);
    if (show) visible += 1;
  }

  const count = document.getElementById('song-count');
  if (count) count.textContent = visible + ' song' + (visible === 1 ? '' : 's');

  const empty = document.getElementById('activity-empty-state');
  const list = document.getElementById('song-catalog-list');
  if (empty && list) {
    empty.classList.toggle('hidden', visible !== 0);
    list.classList.toggle('hidden', visible === 0);
  }
})();
</script>
