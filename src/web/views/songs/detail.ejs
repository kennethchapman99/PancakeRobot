<% title = song.title || song.id %>
<% const workflowAction = nextAction || {}; %>
<%
  const dkJob = distrokidJob || null;
  const dkStatus = dkJob?.status || 'not_queued';
  const dkLabels = {
    not_queued: 'Not queued',
    queued_for_distrokid: 'Queued',
    package_built: 'Package built',
    blocked_missing_fields: 'Blocked',
    auth_needed: 'Auth needed',
    dry_run_ready: 'Dry-run ready',
    upload_started: 'Upload started',
    awaiting_manual_review: 'Awaiting review',
    submitted: 'Submitted',
    submitted_pending_hyperfollow: 'Pending HyperFollow',
    failed: 'Failed',
    skipped: 'Skipped',
  };
  const dkPackagePath = dkJob?.package_path || `output/release-packages/${song.id}`;
  const dkManifestPath = `output/release-packages/${song.id}/manifest.json`;
  const dkBlocking = dkJob?.latest_error?.blocking_missing_fields || dkJob?.latest_error?.errors?.map(item => item.field).filter(Boolean) || [];
  const dkLatestError = dkJob?.latest_error?.message || dkJob?.latest_error?.error || (dkBlocking.length ? `Missing: ${dkBlocking.join(', ')}` : '');
  const dkReadiness = dkStatus === 'package_built' || dkStatus === 'dry_run_ready' || dkStatus === 'awaiting_manual_review' || dkStatus === 'submitted' || dkStatus === 'submitted_pending_hyperfollow'
    ? 'Ready for DistroKid dry-run upload'
    : dkStatus === 'blocked_missing_fields'
      ? 'Blocked until required package fields are present'
      : 'Build the package to calculate readiness';
  const dkCommands = {
    saveAuth: './bin/pancakerobot distrokid:save-auth',
    checkAuth: './bin/pancakerobot distrokid:check-auth',
    buildPackage: `./bin/pancakerobot distrokid:package --song-id ${song.id}`,
    uploadDryRun: `./bin/pancakerobot distrokid:upload --manifest ${dkManifestPath} --dry-run`,
    runQueued: './bin/pancakerobot distrokid:run-queued --limit 5 --dry-run',
    markSubmitted: `./bin/pancakerobot distrokid:mark-submitted --song-id ${song.id} --distrokid-url "URL_FROM_DISTROKID"`,
  };
  const albumReleaseContext = albumContext || null;
%>

<div class="p-8 max-w-4xl" x-data="songDetail()" @keydown.escape.window="editOpen = false">

  <!-- Back + header -->
  <a href="/songs" class="text-sm text-zinc-500 hover:text-zinc-700 mb-6 inline-flex items-center gap-1">← Song Catalog</a>

  <div class="flex items-start justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-bold"><%= song.title || song.topic || song.id %></h1>
      <div class="flex items-center gap-2 mt-2">
        <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-semibold <%= statusBadge(song.status) %>"><%= songStatusLabel(song.status) %></span>
        <span class="text-sm text-zinc-400">Created <%= formatDate(song.created_at) %></span>
        <% if (song.brand_score) { %>
        <span class="text-sm text-zinc-300">·</span>
        <span class="text-sm text-zinc-500">Brand: <%= song.brand_score %>/100</span>
        <% } %>
      </div>
    </div>
    <div class="flex gap-2 shrink-0 items-center">
      <%
        const noAssets = (!fsAssets.audioFiles || fsAssets.audioFiles.length === 0) && (!fsAssets.lyrics);
        const hasLyrics = !!fsAssets.lyrics;
        const releaseLocked = song.status === 'submitted to DistroKid' || song.status === 'outreach complete';
      %>
      <% if (hasLyrics && !releaseLocked) { %>
      <!-- Edit Song — AI lyric revision -->
      <button @click="editOpen = !editOpen"
         :class="editOpen ? 'bg-violet-700 text-white' : 'bg-violet-600 hover:bg-violet-700 text-white'"
         class="text-sm px-4 py-2 rounded-lg transition flex items-center gap-1.5 font-semibold">
        ✏️ Edit Song
      </button>
      <% } %>
      <a href="/releases/<%= albumReleaseContext ? 'album' : 'single' %>/<%= encodeURIComponent(albumReleaseContext ? albumReleaseContext.id : song.id) %>" class="border border-zinc-200 text-sm px-3 py-1.5 rounded-lg hover:bg-zinc-50 transition">Release Cockpit</a>
      <% if (!releaseLocked) { %>
      <!-- Generate / Regenerate -->
      <a href="/songs/<%= song.id %>/generate"
         class="<%= noAssets ? 'bg-amber-500 hover:bg-amber-600 text-white font-bold shadow' : 'border border-zinc-200 text-zinc-500 hover:bg-zinc-50' %> text-sm px-4 py-2 rounded-lg transition flex items-center gap-1.5">
        🚀 <%= noAssets ? 'Generate Song' : 'Regenerate' %>
      </a>
      <a href="/songs/<%= song.id %>/edit" class="border border-zinc-200 text-sm px-3 py-1.5 rounded-lg hover:bg-zinc-50 transition">Edit Details</a>
      <% } %>
      <select onchange="updateStatus('<%= song.id %>', this.value)"
        class="border border-zinc-200 text-sm px-3 py-1.5 rounded-lg focus:outline-none bg-white">
        <% for (const option of songStatusOptions) { %>
          <option value="<%= option.value %>" <%= song.status === option.value ? 'selected' : '' %>>
            <%= option.label %>
          </option>
        <% } %>
      </select>
    </div>
  </div>

  <% if (albumReleaseContext) { %>
  <section class="mb-6 rounded-2xl border border-indigo-200 bg-indigo-50 p-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-600">Album Release Context</div>
        <div class="mt-1 text-lg font-black text-zinc-900">
          Track <%= song.track_number || '?' %> on <a href="/albums/<%= encodeURIComponent(albumReleaseContext.id) %>" class="text-indigo-700 hover:underline"><%= albumReleaseContext.album_title || albumReleaseContext.id %></a>
        </div>
        <p class="mt-1 text-sm text-indigo-900">This song inherits release media, DistroKid submission, HyperFollow, social readiness, and campaign context from the album.</p>
      </div>
      <a href="/albums/<%= encodeURIComponent(albumReleaseContext.id) %>" class="inline-flex items-center justify-center rounded-xl bg-zinc-900 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-700">Manage Album Release</a>
    </div>
  </section>
  <% } %>

  <% const releaseRec = song.release_recommendation || null; %>
  <% const arInputs = song.marketing_inputs_from_ar || {}; %>
  <div class="mb-6 rounded-3xl border <%= releaseRec ? 'border-zinc-200 bg-white' : 'border-dashed border-zinc-300 bg-zinc-50' %> p-6 shadow-sm">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-zinc-500">Release Selection</span>
          <% if (releaseSelectionSummary.isAnalyzed) { %>
          <span class="inline-flex rounded-full px-2.5 py-1 text-[11px] font-semibold <%= recommendationBadgeClass(releaseSelectionSummary.value) %>"><%= recommendationLabel(releaseSelectionSummary.value) %></span>
          <span class="inline-flex rounded-full px-2.5 py-1 text-[11px] font-semibold <%= treatmentBadgeClass(releaseSelectionSummary.treatment) %>"><%= recommendationLabel(releaseSelectionSummary.treatment) %></span>
          <% } else { %>
          <span class="inline-flex rounded-full px-2.5 py-1 text-[11px] font-semibold bg-zinc-100 text-zinc-500 border border-zinc-200">Not Yet Analyzed</span>
          <% } %>
        </div>

        <% if (releaseRec) { %>
        <div class="mt-3 flex flex-wrap items-end gap-5">
          <div>
            <div class="text-4xl font-black leading-none <%= scoreBandClass(releaseSelectionSummary.score) %>"><%= releaseSelectionSummary.score %></div>
            <div class="mt-1 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-400">A&R Score / 100</div>
          </div>
          <div class="grid gap-3 sm:grid-cols-3">
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-400">Confidence</div>
              <div class="mt-1 text-sm font-semibold text-zinc-800"><%= recommendationLabel(releaseSelectionSummary.confidence) %></div>
            </div>
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-400">Best Clip</div>
              <div class="mt-1 text-sm font-semibold text-zinc-800"><%= releaseSelectionSummary.bestClipLabel %></div>
            </div>
            <div>
              <div class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-400">Asset Strategy</div>
              <div class="mt-1 text-sm font-semibold text-zinc-800"><%= recommendationLabel(releaseSelectionSummary.suggestedAssetStrategy) %></div>
            </div>
          </div>
        </div>

        <p class="mt-4 max-w-3xl text-sm leading-6 text-zinc-700"><%= releaseRec.reasoning_summary || 'Analysis complete.' %></p>

        <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-2xl bg-zinc-50 p-3">
            <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-400">Best Hook</div>
            <div class="mt-1 text-sm font-semibold text-zinc-800"><%= arInputs.best_hook_phrase || '—' %></div>
          </div>
          <div class="rounded-2xl bg-zinc-50 p-3">
            <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-400">Top Issue</div>
            <div class="mt-1 text-sm font-semibold text-zinc-800"><%= releaseSelectionSummary.topIssue %></div>
          </div>
          <div class="rounded-2xl bg-zinc-50 p-3">
            <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-400">Brand Profile</div>
            <div class="mt-1 text-sm font-semibold text-zinc-800"><%= releaseRec.brand_profile_id ? (releaseRec.detected_issues || []).includes('missing_brand_profile') ? 'Missing fallback used' : 'Loaded from profile JSON' : 'Unknown' %></div>
          </div>
          <div class="rounded-2xl bg-zinc-50 p-3">
            <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-400">Analyzed</div>
            <div class="mt-1 text-sm font-semibold text-zinc-800"><%= formatDateTime(releaseSelectionSummary.lastAnalyzed) %></div>
          </div>
        </div>

        <div class="mt-4 grid gap-3 lg:grid-cols-[minmax(0,1.8fr)_minmax(0,1fr)]">
          <div class="rounded-2xl border border-zinc-200 p-4">
            <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-400">Category Scores</div>
            <div class="mt-3 grid gap-2 sm:grid-cols-2">
              <% for (const [label, value] of Object.entries(releaseRec.scores || {})) { %>
              <div class="flex items-center justify-between rounded-xl bg-zinc-50 px-3 py-2 text-sm">
                <span class="text-zinc-600"><%= recommendationLabel(label) %></span>
                <span class="font-bold text-zinc-900"><%= value %></span>
              </div>
              <% } %>
            </div>
          </div>
          <div class="grid gap-3">
            <div class="rounded-2xl border border-zinc-200 p-4">
              <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-400">Issues</div>
              <div class="mt-2 flex flex-wrap gap-2">
                <% if ((releaseRec.detected_issues || []).length) { %>
                  <% for (const issue of releaseRec.detected_issues) { %>
                  <span class="inline-flex rounded-full bg-amber-50 px-2.5 py-1 text-[11px] font-semibold text-amber-800 border border-amber-200"><%= recommendationLabel(issue) %></span>
                  <% } %>
                <% } else { %>
                <span class="inline-flex rounded-full bg-emerald-50 px-2.5 py-1 text-[11px] font-semibold text-emerald-700 border border-emerald-200">No detected issues</span>
                <% } %>
              </div>
            </div>
            <div class="rounded-2xl border border-zinc-200 p-4">
              <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-400">Release Blockers</div>
              <div class="mt-2 flex flex-wrap gap-2">
                <% if ((releaseRec.release_blockers || []).length) { %>
                  <% for (const blocker of releaseRec.release_blockers) { %>
                  <span class="inline-flex rounded-full bg-rose-50 px-2.5 py-1 text-[11px] font-semibold text-rose-700 border border-rose-200"><%= recommendationLabel(blocker) %></span>
                  <% } %>
                <% } else { %>
                <span class="inline-flex rounded-full bg-zinc-100 px-2.5 py-1 text-[11px] font-semibold text-zinc-600 border border-zinc-200">No blockers</span>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <% } else { %>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-600">This song has not been analyzed yet. Run the release-selection pass to generate a recommendation, score breakdown, best hook, best clip, and marketing handoff.</p>
        <% } %>
      </div>

      <div class="flex min-w-[260px] flex-col gap-2">
        <% if (!releaseRec) { %>
        <button onclick="runReleaseSelection('<%= song.id %>')" class="inline-flex items-center justify-center rounded-2xl bg-zinc-900 px-5 py-3 text-sm font-bold text-white hover:bg-zinc-700 transition">Run A&R Analysis</button>
        <% } else if (releaseRec.value === 'recommend_to_publish') { %>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'publish')" class="inline-flex items-center justify-center rounded-2xl bg-zinc-900 px-5 py-3 text-sm font-bold text-white hover:bg-zinc-700 transition">Approve for DistroKid Package</button>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'edit')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Send to Editing</button>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'hold')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Hold</button>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'archive')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Archive</button>
        <% } else if (releaseRec.value === 'recommend_to_edit') { %>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'edit')" class="inline-flex items-center justify-center rounded-2xl bg-zinc-900 px-5 py-3 text-sm font-bold text-white hover:bg-zinc-700 transition">Send to Editing</button>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'hold')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Hold</button>
        <button onclick="runReleaseSelection('<%= song.id %>')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Re-run Analysis</button>
        <% } else if (releaseRec.value === 'recommend_to_hold') { %>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'hold')" class="inline-flex items-center justify-center rounded-2xl bg-zinc-900 px-5 py-3 text-sm font-bold text-white hover:bg-zinc-700 transition">Hold as Draft</button>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'edit')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Send to Editing</button>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'archive')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Archive</button>
        <% } else if (releaseRec.value === 'recommend_to_archive') { %>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'archive')" class="inline-flex items-center justify-center rounded-2xl bg-zinc-900 px-5 py-3 text-sm font-bold text-white hover:bg-zinc-700 transition">Archive Song</button>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'hold')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Keep as Draft</button>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'edit')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Send to Editing</button>
        <button onclick="runReleaseSelection('<%= song.id %>')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Re-run Analysis</button>
        <% } else { %>
        <button onclick="applyReleaseSelectionAction('<%= song.id %>', 'review_issues')" class="inline-flex items-center justify-center rounded-2xl bg-zinc-900 px-5 py-3 text-sm font-bold text-white hover:bg-zinc-700 transition">Review Issues</button>
        <button onclick="runReleaseSelection('<%= song.id %>')" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Re-run Analysis</button>
        <% } %>
      </div>
    </div>
  </div>

  <!-- ── EDIT SONG PANEL ── -->
  <% if (fsAssets.lyrics) { %>
  <div x-show="editOpen" x-cloak class="mb-6">
    <div class="bg-violet-950 rounded-2xl overflow-hidden shadow-xl">

      <!-- Header -->
      <div class="flex items-center gap-3 px-5 py-4 bg-violet-900 border-b border-violet-800">
        <span class="text-violet-300 text-lg">✏️</span>
        <div>
          <div class="font-bold text-white">Edit Song Lyrics</div>
          <div class="text-violet-300 text-xs mt-0.5">Your notes are merged with the latest A&amp;R analysis so the next revision/regeneration targets the actual release issues</div>
        </div>
        <button @click="editOpen = false" class="ml-auto text-violet-400 hover:text-white text-lg leading-none">✕</button>
      </div>

      <!-- Input area — shown when idle -->
      <div x-show="editState === 'idle'" class="p-5 space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <% const suggestions = [
            'Fewer lyrics — cut it by a third',
            'Make the chorus simpler and catchier',
            'Stronger opening hook',
            'Make it more emotionally specific',
            'Tighten the second verse',
            'Make the final chorus hit harder',
          ]; %>
          <% for (const s of suggestions) { %>
          <button @click="feedback = '<%= s %>'"
            class="text-left text-xs bg-violet-900 hover:bg-violet-800 text-violet-200 px-3 py-2 rounded-lg transition border border-violet-700 hover:border-violet-500">
            <%= s %>
          </button>
          <% } %>
        </div>
        <textarea x-model="feedback" rows="3" placeholder="Tell the AI what to change… e.g. 'less lyrics overall', 'make the chorus rhyme better', 'add more concrete detail', 'make it more serious'"
          class="w-full bg-violet-900 border border-violet-700 rounded-xl px-4 py-3 text-sm text-white placeholder-violet-400 focus:outline-none focus:ring-2 focus:ring-violet-400 resize-none"></textarea>
        <div class="flex items-center justify-between">
          <p class="text-xs text-violet-400">The current lyrics.md will be overwritten. Your notes and the latest A&amp;R findings become the regeneration brief, and Regenerate will reuse the revised lyrics/audio prompt.</p>
          <button @click="startRevision('<%= song.id %>')" :disabled="!feedback.trim()"
            class="bg-violet-500 hover:bg-violet-400 disabled:opacity-40 text-white font-bold px-5 py-2 rounded-xl transition text-sm">
            Revise →
          </button>
        </div>
      </div>

      <!-- Terminal — shown when running or done -->
      <div x-show="editState !== 'idle'">
        <div id="revise-log" class="p-5 font-mono text-sm space-y-0.5 overflow-y-auto" style="min-height:200px; max-height:360px;">
          <div class="text-violet-700 mb-2">$ node src/scripts/revise-song.js <%= song.id %></div>
          <div class="text-violet-800 mb-3">────────────────────────────────────────</div>
        </div>
        <div class="px-5 py-3 bg-violet-900 border-t border-violet-800 flex items-center justify-between">
          <span class="text-xs font-mono"
            :class="editState === 'running' ? 'text-green-400' : editState === 'done' ? 'text-emerald-400' : 'text-red-400'"
            x-text="editState === 'running' ? '⏳ Revising lyrics…' : editState === 'done' ? '✅ Done — reloading…' : '❌ ' + editError"></span>
          <button x-show="editState !== 'running'" @click="resetEdit()"
            class="text-xs text-violet-400 hover:text-white px-3 py-1 rounded border border-violet-700 hover:border-violet-500 transition">
            <span x-text="editState === 'done' ? 'Close' : 'Try Again'"></span>
          </button>
        </div>
      </div>

    </div>
  </div>
  <% } %>

  <!-- Distribution status -->
  <% if (song.status === 'submitted to DistroKid') { %>
  <div class="bg-gradient-to-r from-fuchsia-100 via-rose-50 to-amber-50 border border-fuchsia-200 rounded-3xl p-6 mb-6 shadow-sm">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
      <div class="space-y-3">
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center rounded-full bg-fuchsia-700 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">Submitted to DistroKid</span>
          <% if (song.distributor_submission_date) { %>
          <span class="text-sm text-fuchsia-700">Submitted <%= song.distributor_submission_date %></span>
          <% } %>
        </div>
        <div>
          <h2 class="text-2xl font-black text-zinc-900">Submitted to DistroKid</h2>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-700">Next step: add the HyperFollow link, generate the release assets from the base image, then start outreach. Release-kit sharing links are optional in phase 1.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="inline-flex rounded-full bg-white px-3 py-1.5 text-xs font-semibold text-zinc-700 border border-fuchsia-200">Next action: <%= workflowAction.label || 'Review marketing readiness' %></span>
          <% if (workflowAction.blocking) { %>
          <span class="inline-flex rounded-full bg-amber-100 px-3 py-1.5 text-xs font-semibold text-amber-800 border border-amber-200">Blocking step</span>
          <% } %>
        </div>
        <div>
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-500">Missing right now</div>
          <div class="mt-2 flex flex-wrap gap-2">
            <% if (workflowAction.missing && workflowAction.missing.length) { %>
              <% for (const item of workflowAction.missing.slice(0, 6)) { %>
              <span class="inline-flex rounded-full bg-white px-3 py-1.5 text-xs font-semibold text-zinc-700 border border-zinc-200"><%= item %></span>
              <% } %>
            <% } else { %>
            <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1.5 text-xs font-semibold text-emerald-700 border border-emerald-200">No blocking fields</span>
            <% } %>
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-2 shrink-0 min-w-64">
        <a href="<%= workflowAction.href || '/songs/' + encodeURIComponent(song.id) + '?tab=marketing' %>" class="inline-flex items-center justify-center rounded-2xl bg-zinc-950 px-5 py-3 text-sm font-bold text-white hover:bg-zinc-800 transition"><%= workflowAction.label || 'Open Marketing Tab' %></a>
        <% if (workflowAction.nextActionKey === 'START_OUTREACH') { %>
        <a href="/marketing/outlets" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Open Outlet Database</a>
        <% } else { %>
        <a href="/songs/<%= encodeURIComponent(song.id) %>?tab=marketing" class="inline-flex items-center justify-center rounded-2xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition">Open Marketing Tab</a>
        <% } %>
      </div>
    </div>
  </div>
  <% } else if (song.status === 'outreach complete') { %>
  <div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-5 mb-6 flex items-center gap-4">
    <div class="text-3xl">✅</div>
    <div>
      <div class="font-bold text-emerald-800">Outreach complete</div>
      <div class="text-sm text-emerald-600">This release has finished the current distribution and outreach cycle.</div>
    </div>
  </div>
  <% } %>

  <% if (albumReleaseContext) { %>
  <section class="mb-6 rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h2 class="text-sm font-bold text-zinc-900">DistroKid Automation</h2>
        <p class="mt-1 text-sm text-zinc-600">This track is submitted as part of its album. Preview, live submit, HyperFollow, and campaign readiness are managed on the album detail page.</p>
      </div>
      <a href="/albums/<%= encodeURIComponent(albumReleaseContext.id) %>" class="inline-flex items-center justify-center rounded-xl bg-zinc-900 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-700">Open Album</a>
    </div>
  </section>
  <% } else { %>
  <section class="mb-6 rounded-2xl border border-fuchsia-200 bg-white p-5 shadow-sm" x-data="distroKidAutomation('<%= song.id %>')">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <h2 class="text-sm font-bold text-zinc-900">DistroKid Automation</h2>
          <span class="rounded-full border border-fuchsia-200 bg-fuchsia-50 px-2.5 py-1 text-[11px] font-semibold text-fuchsia-700"><%= dkLabels[dkStatus] || dkStatus %></span>
        </div>
        <div class="mt-3 grid gap-2 text-xs text-zinc-600 sm:grid-cols-2">
          <div><span class="font-semibold text-zinc-500">Readiness:</span> <%= dkReadiness %></div>
          <div><span class="font-semibold text-zinc-500">Link:</span> <span class="break-all" x-text="link || '<%= (marketingKit?.marketing_links?.smart_link || dkJob?.distrokid_url || '—') %>'"></span></div>
          <div><span class="font-semibold text-zinc-500">Run log:</span> <span class="font-mono break-all"><%= dkJob?.latest_run_log_path || '—' %></span></div>
          <div><span class="font-semibold text-zinc-500">Attempts:</span> <%= dkJob?.attempt_count || 0 %></div>
          <div class="sm:col-span-2"><span class="font-semibold text-zinc-500">Latest error:</span> <span class="break-words"><%= dkLatestError || '—' %></span></div>
        </div>
        <div class="mt-3 rounded-xl border border-zinc-200 bg-zinc-50 p-3 text-xs text-zinc-600">
          <div class="font-semibold text-zinc-700">Recent automation log</div>
          <template x-if="log.length">
            <div class="mt-2 space-y-1">
              <template x-for="line in log" :key="line"><div x-text="line"></div></template>
            </div>
          </template>
          <div x-show="!log.length" class="mt-2 text-zinc-400">No automation run recorded yet.</div>
          <div x-show="message" x-cloak class="mt-2 rounded-lg border border-fuchsia-200 bg-white px-2 py-1 text-[11px] text-fuchsia-800" x-text="message"></div>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          <% if (dkBlocking.length) { %>
            <% for (const field of dkBlocking.slice(0, 8)) { %>
            <span class="rounded-full border border-amber-200 bg-amber-50 px-2.5 py-1 text-[11px] font-semibold text-amber-800"><%= field %></span>
            <% } %>
          <% } else { %>
            <span class="rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-[11px] font-semibold text-emerald-700">No blocking fields recorded</span>
          <% } %>
        </div>
      </div>
      <div class="flex min-w-[240px] flex-col gap-2">
        <button type="button" @click="runPreview()" :disabled="saving" class="rounded-xl bg-fuchsia-700 px-4 py-2 text-sm font-semibold text-white hover:bg-fuchsia-600 disabled:opacity-50">Run Automation Preview</button>
        <button type="button" @click="runLiveSubmit()" :disabled="saving" class="rounded-xl bg-zinc-900 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-700 disabled:opacity-50">Run Live Submit</button>
        <button type="button" @click="fetchHyperFollow()" :disabled="saving" class="rounded-xl border border-zinc-200 px-4 py-2 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 disabled:opacity-50">Fetch HyperFollow Link</button>
        <details class="mt-2 rounded-xl border border-zinc-200 bg-zinc-50 p-3">
          <summary class="cursor-pointer text-xs font-semibold text-zinc-600">Advanced</summary>
          <div class="mt-3 flex flex-col gap-2">
            <button type="button" @click="queue()" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 text-xs font-semibold text-zinc-700 hover:bg-zinc-50">Queue for DistroKid</button>
            <button type="button" @click="clear()" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 text-xs font-semibold text-zinc-700 hover:bg-zinc-50">Clear Queue</button>
            <button type="button" @click="buildPackage()" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 text-xs font-semibold text-zinc-700 hover:bg-zinc-50">Build Package</button>
            <button type="button" @click="showDryRunCommand()" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 text-xs font-semibold text-zinc-700 hover:bg-zinc-50">Show Dry-Run Upload Command</button>
          </div>
          <div class="mt-3 space-y-1 font-mono text-[11px] text-zinc-500">
            <button type="button" @click="copy('<%= dkCommands.saveAuth %>')" class="block w-full break-all rounded-lg px-2 py-1 text-left hover:bg-white"><%= dkCommands.saveAuth %></button>
            <button type="button" @click="copy('<%= dkCommands.checkAuth %>')" class="block w-full break-all rounded-lg px-2 py-1 text-left hover:bg-white"><%= dkCommands.checkAuth %></button>
            <button type="button" @click="copy('<%= dkCommands.buildPackage %>')" class="block w-full break-all rounded-lg px-2 py-1 text-left hover:bg-white"><%= dkCommands.buildPackage %></button>
            <button type="button" @click="copy('<%= dkCommands.uploadDryRun %>')" class="block w-full break-all rounded-lg px-2 py-1 text-left hover:bg-white"><%= dkCommands.uploadDryRun %></button>
            <button type="button" @click="copy('<%= dkCommands.runQueued %>')" class="block w-full break-all rounded-lg px-2 py-1 text-left hover:bg-white"><%= dkCommands.runQueued %></button>
          </div>
          <div x-show="commandMessage" x-cloak class="mt-2 rounded-lg border border-fuchsia-200 bg-white px-2 py-1 font-mono text-[11px] text-fuchsia-800" x-text="commandMessage"></div>
        </details>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Checklist progress banner -->
  <div class="bg-white border border-zinc-200 rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-2">
      <span class="text-sm font-medium text-zinc-700">Publishing Progress</span>
      <span class="text-sm font-bold text-zinc-900" id="pct-label"><%= progress.pct %>%</span>
    </div>
    <div class="h-2 bg-zinc-100 rounded-full overflow-hidden">
      <div id="progress-bar" class="h-full rounded-full transition-all duration-300
        <%= progress.pct >= 100 ? 'bg-emerald-500' : progress.pct >= 60 ? 'bg-green-500' : 'bg-amber-400' %>"
        style="width: <%= progress.pct %>%"></div>
    </div>
    <div class="text-xs text-zinc-400 mt-1.5"><%= progress.done %> of <%= progress.total %> steps complete</div>
  </div>

  <!-- ── MEDIA ROW: Audio ── -->
  <% const hasAudio = fsAssets.audioFiles && fsAssets.audioFiles.length > 0; %>
  <% if (hasAudio) { %>
  <div class="mb-6">
    <div class="bg-zinc-900 rounded-2xl p-5 text-white">
      <div class="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-3">Audio</div>
      <% for (let i = 0; i < fsAssets.audioFiles.length; i++) { const af = fsAssets.audioFiles[i]; %>
      <div class="mb-3">
        <div class="text-xs text-zinc-500 mb-1.5 truncate"><%= af.name || 'Track ' + (i+1) %></div>
        <audio controls class="w-full" style="height:38px;" preload="metadata">
          <source src="<%= af.url %>" type="audio/mpeg">
        </audio>
        <% if (af.size) { %><div class="text-xs text-zinc-600 mt-1"><%= (af.size / 1024 / 1024).toFixed(1) %> MB</div><% } %>
      </div>
      <% } %>
    </div>
  </div>
  <% } else { %>
  <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mb-6 text-center">
    <div class="text-4xl mb-3">🎵</div>
    <div class="text-sm text-zinc-600 mb-4">No audio generated yet. Generate the song first, then review the release asset flow in the marketing tab.</div>
    <a href="/songs/<%= song.id %>/generate"
       class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-bold px-6 py-2.5 rounded-xl transition text-sm shadow">
      🚀 Generate Song
    </a>
  </div>
  <% } %>

  <!-- ── CONTENT TABS: Lyrics / Audio Prompt / Metadata / Marketing / Performance ── -->
  <div class="mb-6" x-data="{ tab: '<%= initialTab %>' }" @switch-tab="tab = $event.detail">
    <!-- Tab bar -->
    <div class="flex gap-1 border-b border-zinc-200 mb-4">
      <% if (lyricsContent) { %>
      <button @click="tab='lyrics'"
        :class="tab==='lyrics' ? 'border-b-2 border-zinc-900 text-zinc-900 font-semibold' : 'text-zinc-400 hover:text-zinc-600'"
        class="px-4 py-2.5 text-sm transition">✍️ Lyrics</button>
      <% } %>
      <% if (audioPromptContent) { %>
      <button @click="tab='prompt'"
        :class="tab==='prompt' ? 'border-b-2 border-zinc-900 text-zinc-900 font-semibold' : 'text-zinc-400 hover:text-zinc-600'"
        class="px-4 py-2.5 text-sm transition">🎵 Audio Prompt</button>
      <% } %>
      <% if (metadataParsed) { %>
      <button @click="tab='meta'"
        :class="tab==='meta' ? 'border-b-2 border-zinc-900 text-zinc-900 font-semibold' : 'text-zinc-400 hover:text-zinc-600'"
        class="px-4 py-2.5 text-sm transition">📋 Metadata</button>
      <% } %>
      <button @click="tab='marketing'"
        :class="tab==='marketing' ? 'border-b-2 border-zinc-900 text-zinc-900 font-semibold' : 'text-zinc-400 hover:text-zinc-600'"
        class="px-4 py-2.5 text-sm transition">📦 Marketing</button>
      <button @click="tab='performance'"
        :class="tab==='performance' ? 'border-b-2 border-zinc-900 text-zinc-900 font-semibold' : 'text-zinc-400 hover:text-zinc-600'"
        class="px-4 py-2.5 text-sm transition">📈 Performance</button>
    </div>

    <!-- Lyrics tab -->
    <% if (lyricsContent) { %>
    <div x-show="tab==='lyrics'" class="bg-white border border-zinc-200 rounded-xl p-6">
      <pre class="whitespace-pre-wrap text-sm text-zinc-800 font-mono leading-relaxed"><%= lyricsContent %></pre>
    </div>
    <% } %>

    <!-- Audio Prompt tab -->
    <% if (audioPromptContent) { %>
    <div x-show="tab==='prompt'" class="bg-white border border-zinc-200 rounded-xl p-6">
      <pre class="whitespace-pre-wrap text-sm text-zinc-700 leading-relaxed"><%= audioPromptContent %></pre>
    </div>
    <% } %>

    <!-- Metadata tab -->
    <% if (metadataParsed) { %>
    <div x-show="tab==='meta'" class="bg-white border border-zinc-200 rounded-xl divide-y divide-zinc-100">
      <% const meta = metadataParsed; %>
      <% if (meta.title) { %>
      <div class="px-5 py-4"><div class="text-xs font-medium text-zinc-400 uppercase tracking-wide mb-1">Title</div><div class="text-sm text-zinc-800 font-medium"><%= meta.title %></div></div>
      <% } %>
      <% if (meta.youtube_title) { %>
      <div class="px-5 py-4"><div class="text-xs font-medium text-zinc-400 uppercase tracking-wide mb-1">YouTube Title</div><div class="text-sm text-zinc-800"><%= meta.youtube_title %></div></div>
      <% } %>
      <% if (meta.youtube_description) { %>
      <div class="px-5 py-4"><div class="text-xs font-medium text-zinc-400 uppercase tracking-wide mb-1">YouTube Description</div><div class="text-sm text-zinc-700 whitespace-pre-wrap leading-relaxed"><%= meta.youtube_description %></div></div>
      <% } %>
      <% if (meta.youtube_tags && meta.youtube_tags.length) { %>
      <div class="px-5 py-4">
        <div class="text-xs font-medium text-zinc-400 uppercase tracking-wide mb-2">YouTube Tags (<%= meta.youtube_tags.length %>)</div>
        <div class="flex flex-wrap gap-1.5">
          <% for (const tag of meta.youtube_tags) { %><span class="bg-zinc-100 text-zinc-600 text-xs px-2 py-0.5 rounded-full"><%= tag %></span><% } %>
        </div>
      </div>
      <% } %>
      <% if (meta.spotify_genre_tags && meta.spotify_genre_tags.length) { %>
      <div class="px-5 py-4">
        <div class="text-xs font-medium text-zinc-400 uppercase tracking-wide mb-2">Genre Tags</div>
        <div class="flex flex-wrap gap-1.5">
          <% for (const tag of meta.spotify_genre_tags) { %><span class="bg-blue-50 text-blue-600 text-xs px-2 py-0.5 rounded-full"><%= tag %></span><% } %>
        </div>
      </div>
      <% } %>
      <% if (meta.isrc) { %>
      <div class="px-5 py-4"><div class="text-xs font-medium text-zinc-400 uppercase tracking-wide mb-1">ISRC</div><div class="text-sm font-mono text-zinc-800"><%= meta.isrc %></div></div>
      <% } %>
    </div>
    <% } %>

    <!-- Marketing tab -->
    <div x-show="tab==='marketing'" x-cloak>
      <% const mk = marketingKit || {}; const mLinks = mk.marketing_links || {}; const mAssets = mk.marketing_assets || {}; const releaseState = releaseAssetState || {}; const inheritedAssets = !!releaseState.inheritedFrom; const assetVersion = releaseState.metadata?.generated_at || mAssets.generated_at || ''; const withAssetVersion = (url) => !url ? '' : url + (url.includes('?') ? '&' : '?') + 'v=' + encodeURIComponent(assetVersion); const releaseAssetFormats = ['spotify-cover-3000x3000.png','youtube-thumbnail-1280x720.png','instagram-square-1080x1080.png','instagram-vertical-1080x1920.png','facebook-post-1200x630.png']; const hasGeneratedPreviewAssets = (releaseState.assets || []).some(asset => !!asset.publicUrl); const assetPackDownloadUrl = releaseState.downloadUrl || ('/api/songs/' + encodeURIComponent(song.id) + '/release-assets/download'); const linkLabels = { smart_link:'HyperFollow URL', spotify_url:'Spotify URL', apple_music_url:'Apple Music URL', youtube_music_url:'YouTube Music URL', youtube_video_url:'YouTube video URL', artist_website_url:'Artist website URL', instagram_url:'Instagram URL', tiktok_url:'TikTok URL', contact_email:'Contact email' }; %>
      <section id="marketing-links" class="bg-white border border-zinc-200 rounded-xl mb-6">
        <div class="px-4 py-3 border-b border-zinc-100 flex items-center justify-between">
          <div>
            <h2 class="font-semibold text-sm text-zinc-700">Release Marketing</h2>
          </div>
          <div class="flex items-center gap-2">
            <button form="marketing-kit-form" class="border border-zinc-200 rounded-lg px-3 py-2 text-sm font-medium text-zinc-700 hover:bg-zinc-50">Save Changes</button>
          </div>
        </div>
        <form id="marketing-kit-form" method="POST" action="/songs/<%= song.id %>/marketing-kit" class="p-4 space-y-5">
          <section id="release-kit-actions" class="border border-zinc-200 rounded-xl p-4" data-reload-url="/songs/<%= encodeURIComponent(song.id) %>?tab=marketing#release-kit-actions" x-data="marketingPack('<%= song.id %>')" x-init="register()">
            <div class="flex items-center justify-between gap-3">
              <div>
                <h3 class="text-lg font-bold text-zinc-900"><%= inheritedAssets ? 'Inherited Release Assets' : 'Song Release Assets' %></h3>
                <% if (inheritedAssets) { %>
                  <div class="mt-1 text-sm text-zinc-500">Inherited from album: <a href="/albums/<%= encodeURIComponent(releaseState.inheritedFrom.id) %>" class="underline hover:text-zinc-700"><%= releaseState.inheritedFrom.title %></a></div>
                <% } else { %>
                  <div class="mt-1 text-sm text-zinc-500">Upload/select a primary image, then derive Spotify, YouTube, Instagram, and Facebook assets.</div>
                <% } %>
              </div>
              <div class="flex flex-wrap gap-2">
                <% if (releaseState.primaryImage) { %><a href="<%= releaseState.previewUrl %>" target="_blank" class="rounded-lg border border-zinc-200 px-3 py-2 text-sm hover:bg-zinc-50">Preview</a><% } %>
                <a href="<%= assetPackDownloadUrl %>" class="rounded-lg border border-zinc-200 px-3 py-2 text-sm hover:bg-zinc-50">Download Pack</a>
              </div>
            </div>

            <div class="mt-4 grid gap-4 md:grid-cols-2">
              <div class="rounded-lg border border-zinc-200 p-3">
                <div class="text-sm font-semibold text-zinc-600">Primary image</div>
                <% if (releaseState.primaryImage) { %>
                  <img src="<%= withAssetVersion(releaseState.primaryImage.url) %>" alt="Primary image" class="mt-3 h-44 w-full rounded-lg border border-zinc-200 object-cover">
                <% } else { %>
                  <div class="mt-3 flex h-44 items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-zinc-50 text-sm text-zinc-400">No primary image</div>
                <% } %>
                <% if (releaseState.derivativesStale && releaseState.primaryImage) { %><div class="mt-2 text-xs text-amber-700">Derivatives will refresh automatically on preview or download.</div><% } %>
                <% if (inheritedAssets) { %>
                  <a href="/albums/<%= encodeURIComponent(releaseState.inheritedFrom.id) %>" class="mt-3 inline-flex text-xs text-zinc-600 underline hover:text-zinc-800">Open album media</a>
                <% } else { %>
                  <label class="mt-3 block">
                    <input type="file" accept=".png,.jpg,.jpeg,.webp" class="block w-full text-xs text-zinc-600 file:mr-2 file:rounded-md file:border file:border-zinc-200 file:bg-zinc-50 file:px-2 file:py-1 file:text-xs" onchange="uploadBaseImage('<%= song.id %>', this)">
                  </label>
                  <div class="mt-3 flex flex-wrap gap-2">
                    <button type="button" onclick="generateOpenAIPrimaryImage('<%= song.id %>')" class="rounded-lg border border-zinc-200 px-3 py-2 text-xs hover:bg-zinc-50">Generate with OpenAI</button>
                    <button type="button" onclick="selectDefaultPrimaryImage('<%= song.id %>')" class="rounded-lg border border-zinc-200 px-3 py-2 text-xs hover:bg-zinc-50">Use Base Library</button>
                    <button id="clear-base-image-button-<%= song.id %>" type="button" onclick="clearBaseImage('<%= song.id %>')" class="rounded-lg border border-zinc-200 px-3 py-2 text-xs hover:bg-zinc-50 disabled:opacity-50"><span id="clear-base-image-label-<%= song.id %>">Clear Primary Image</span></button>
                  </div>
                <% } %>
                <div id="base-image-status-<%= song.id %>" class="mt-3 hidden rounded-lg border px-3 py-2 text-xs font-medium"></div>
              </div>

              <div class="rounded-lg border border-zinc-200 p-3">
                <div class="flex items-center justify-between gap-3">
                  <div class="text-sm font-semibold text-zinc-600">Platform derivatives</div>
                  <% if (!inheritedAssets) { %>
                    <button id="pack-trigger-<%= song.id %>" data-song-id="<%= song.id %>" data-release-assets-build="1" type="button" onclick="buildPackAllFormats('<%= song.id %>', <%- JSON.stringify(releaseAssetFormats) %>)" :disabled="packState === 'running'" class="rounded-lg bg-emerald-600 px-3 py-2 text-xs font-semibold text-white hover:bg-emerald-500 disabled:opacity-50">
                      <span id="pack-trigger-idle-<%= song.id %>" x-show="packState !== 'running'"><%= hasGeneratedPreviewAssets ? 'Rebuild Derivatives' : 'Generate Derivatives' %></span>
                      <span id="pack-trigger-running-<%= song.id %>" x-show="packState === 'running'" class="hidden">Generating...</span>
                    </button>
                  <% } %>
                </div>
                <% if (inheritedAssets) { %>
                  <div class="mt-2 rounded-lg border border-zinc-100 bg-zinc-50 px-3 py-2 text-xs text-zinc-600">This track uses album media. Change or rebuild it on the album page.</div>
                <% } %>
                <div class="mt-3 space-y-2">
                  <% for (const asset of (releaseState.assets || [])) { const assetUrl = asset.publicUrl || ''; const assetPreviewUrl = withAssetVersion(assetUrl); %>
                    <div class="rounded-lg border border-zinc-100 px-3 py-2 text-xs">
                      <div class="flex items-center justify-between gap-3">
                        <div class="font-semibold text-zinc-700"><%= asset.label || asset.name %> <span class="font-normal text-zinc-400"><%= asset.dimensions?.width %>x<%= asset.dimensions?.height %></span></div>
                        <span class="<%= assetUrl ? 'text-emerald-600' : 'text-zinc-400' %>"><%= assetUrl ? 'ready' : 'missing' %></span>
                      </div>
                      <% if (assetUrl) { %>
                        <div class="mt-1 flex flex-wrap gap-2">
                          <a href="<%= assetPreviewUrl %>" target="_blank" rel="noopener" class="underline hover:text-zinc-700">Open</a>
                          <button type="button" class="underline hover:text-zinc-700" onclick="copyText('<%= assetPreviewUrl %>')">Copy URL</button>
                          <a href="<%= assetPreviewUrl %>" download class="underline hover:text-zinc-700">Download</a>
                        </div>
                      <% } %>
                    </div>
                  <% } %>
                </div>
                <div id="pack-status-<%= song.id %>" class="mt-3 hidden rounded-lg border px-3 py-3 text-sm font-medium shadow-sm"></div>
              </div>
            </div>

            <div id="pack-terminal-<%= song.id %>" x-show="packState !== 'idle'" x-cloak class="mt-3 border border-zinc-200 bg-zinc-950 rounded-xl overflow-hidden">
              <div class="flex items-center justify-between px-4 py-2 bg-zinc-900 border-b border-zinc-800">
                <span class="text-zinc-300 text-xs font-mono">Release Asset Build</span>
                <span x-html="packBadge" class="text-xs" id="pack-badge-<%= song.id %>"></span>
              </div>
              <div id="pack-log-<%= song.id %>" class="font-mono text-xs p-4 max-h-48 overflow-y-auto space-y-0.5 text-zinc-300"></div>
              <div class="px-4 py-2 text-xs text-zinc-500" x-text="packFooter" id="pack-footer-<%= song.id %>"></div>
            </div>
          </section>

          <section class="border border-zinc-200 rounded-xl p-4">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-semibold text-sm text-zinc-700">Release Links</h3>
              <button type="button" onclick="copyMarketingLinkBlock()" class="text-xs border border-zinc-200 rounded-lg px-2 py-1 hover:bg-zinc-50">Copy Outreach Link Block</button>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3 text-sm">
              <% for (const field of ['smart_link','spotify_url','apple_music_url','youtube_music_url','youtube_video_url','artist_website_url','instagram_url','tiktok_url','contact_email']) { %>
