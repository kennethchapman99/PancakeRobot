<script type="module" src="/song-detail-marketing.js"></script>
<script>
function songDetail() {
  return {
    editOpen: false,
    editState: 'idle',  // idle | running | done | error
    feedback: '',
    editError: '',

    startRevision(songId) {
      if (!this.feedback.trim()) return;
      this.editState = 'running';
      this.editError = '';

      // Reset log area
      const log = document.getElementById('revise-log');
      log.innerHTML = `
        <div class="text-violet-700 mb-2">$ node src/scripts/revise-song.js ${songId}</div>
        <div class="text-violet-800 mb-3">────────────────────────────────────────</div>
      `;

      fetch('/api/songs/' + songId + '/revise', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ feedback: this.feedback }),
      })
        .then(r => r.json())
        .then(d => {
          if (!d.jobId) throw new Error(d.error || 'No job ID');
          const es = new EventSource('/api/songs/revise/stream/' + d.jobId);

          es.addEventListener('log', e => {
            const { message } = JSON.parse(e.data);
            const div = document.createElement('div');
            div.className = 'leading-relaxed whitespace-pre-wrap break-words ' + (
              message.startsWith('✅') ? 'text-emerald-400 font-semibold' :
              message.startsWith('❌') ? 'text-red-400' :
              message.startsWith('📝') || message.startsWith('✍️') || message.startsWith('🤖') ? 'text-violet-300' :
              message.startsWith('⚠') ? 'text-amber-400' :
              'text-violet-200'
            );
            div.textContent = message;
            log.appendChild(div);
            log.scrollTop = log.scrollHeight;
          });

          es.addEventListener('complete', () => {
            es.close();
            this.editState = 'done';
            setTimeout(() => window.location.reload(), 1500);
          });

          es.addEventListener('error', e => {
            if (e.data) {
              es.close();
              this.editState = 'error';
              try { this.editError = JSON.parse(e.data).message; } catch { this.editError = e.data; }
            }
          });
        })
        .catch(err => { this.editState = 'error'; this.editError = err.message; });
    },

    resetEdit() {
      this.editState = 'idle';
      this.feedback = '';
      this.editError = '';
    },
  };
}

window.distributorSubmit = function() {
  return {
    open: false, url: '', saving: false,
    async submit(songId) {
      this.saving = true;
      const r = await fetch('/api/songs/' + songId + '/publish', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: this.url.trim() }),
      });
      const d = await r.json();
      if (d.ok) window.location.assign('/songs/' + encodeURIComponent(songId) + '?tab=marketing&message=' + encodeURIComponent('Submitted to distributor. Release asset build started automatically.'));
      else { alert('Failed: ' + (d.error || 'unknown')); this.saving = false; }
    }
  };
};

window.distroKidAutomation = function(songId) {
  return {
    url: '',
    saving: false,
    commandMessage: '',
    message: '',
    link: '',
    log: <%- JSON.stringify(distrokidRecentLog || []) %>,
    async copy(command) {
      this.commandMessage = command;
      try {
        await navigator.clipboard.writeText(command);
        this.commandMessage = 'Copied: ' + command;
      } catch {
        this.commandMessage = command;
      }
    },
    async queue() {
      const response = await fetch('/api/distrokid/jobs/queue', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ songIds: [songId] }),
      });
      const data = await response.json();
      if (!data.ok) return alert((data.errors || [data.error || 'Queue failed']).join('\n'));
      window.location.reload();
    },
    async clear() {
      const response = await fetch('/api/distrokid/jobs/clear', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ songIds: [songId] }),
      });
      const data = await response.json();
      if (!data.ok) return alert((data.errors || [data.error || 'Clear failed']).join('\n'));
      window.location.reload();
    },
    async buildPackage() {
      const response = await fetch('/api/distrokid/jobs/' + encodeURIComponent(songId) + '/package', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await response.json();
      if (!data.ok) return alert((data.errors || [data.error || 'Package command lookup failed']).join('\n'));
      this.copy(data.commands?.build_package || ('./bin/pancakerobot distrokid:package --song-id ' + songId));
    },
    async showDryRunCommand() {
      const response = await fetch('/api/distrokid/jobs/' + encodeURIComponent(songId));
      const data = await response.json();
      if (!data.ok) return alert((data.errors || [data.error || 'Dry-run command lookup failed']).join('\n'));
      this.copy(data.commands?.upload_dry_run || ('./bin/pancakerobot distrokid:upload --manifest output/release-packages/' + songId + '/manifest.json --dry-run'));
    },
    async runPreview() {
      this.saving = true;
      this.message = 'Running automation preview...';
      const response = await fetch('/api/distrokid/jobs/' + encodeURIComponent(songId) + '/automation-preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await response.json();
      this.saving = false;
      if (!data.ok) {
        this.message = (data.errors || [data.error || 'Automation preview failed']).join('\n');
        return;
      }
      this.message = data.message || 'Automation preview finished.';
      this.log = data.recent_log_summary || (data.result?.log || []).map(item => item.message || item);
    },
    async runLiveSubmit() {
      if (!confirm('Run the live DistroKid submit for this release?')) return;
      this.saving = true;
      this.message = 'Running live submit...';
      const response = await fetch('/api/distrokid/jobs/' + encodeURIComponent(songId) + '/live-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ confirm: true }),
      });
      const data = await response.json();
      this.saving = false;
      if (!data.ok) {
        this.message = (data.errors || [data.error || 'Live submit failed']).join('\n');
        return;
      }
      this.message = data.message || 'Live submit finished.';
      this.link = data.result?.hyperfollow?.url || data.result?.releaseUrl || '';
      this.log = data.recent_log_summary || (data.result?.log || []).map(item => item.message || item);
    },
    async fetchHyperFollow() {
      this.saving = true;
      this.message = 'Checking HyperFollow...';
      const response = await fetch('/api/distrokid/jobs/' + encodeURIComponent(songId) + '/hyperfollow', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await response.json();
      this.saving = false;
      if (!data.ok) {
        this.message = (data.errors || [data.error || 'HyperFollow capture failed']).join('\n');
        return;
      }
      this.message = data.message || 'HyperFollow check finished.';
      this.link = data.hyperfollow?.url || this.link;
    },
  };
};

function updateStatus(songId, status) {
  fetch('/api/songs/' + songId + '/status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status })
  }).then(r => r.json().then(d => ({ ok: r.ok, data: d })))
    .then(({ ok, data }) => {
      if (!ok || !data.ok) throw new Error(data.error || 'Status update failed');
      if (status === 'submitted to DistroKid') {
        window.location.assign('/songs/' + encodeURIComponent(songId) + '?tab=marketing&message=' + encodeURIComponent('Marked submitted. Release asset build started automatically.'));
        return;
      }
      window.location.reload();
    })
    .catch(err => alert('Status update failed: ' + err.message));
}

function updateChecklist(songId, key, status) {
  fetch('/api/songs/' + songId + '/checklist/' + key, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status })
  }).then(r => r.json()).then(d => {
    if (d.progress) {
      document.getElementById('pct-label').textContent = d.progress.pct + '%';
      const bar = document.getElementById('progress-bar');
      bar.style.width = d.progress.pct + '%';
      bar.className = bar.className.replace(/bg-\w+-\d+/, d.progress.pct >= 100 ? 'bg-emerald-500' : d.progress.pct >= 60 ? 'bg-green-500' : 'bg-amber-400');
    }
    // Update row icon
    const row = document.getElementById('cl-' + key);
    if (row) {
      const icon = row.querySelector('span:first-child');
      const icons = { done: '✓', in_progress: '◐', blocked: '✗', not_started: '○' };
      const colors = { done: 'text-emerald-500', in_progress: 'text-amber-500', blocked: 'text-red-500', not_started: 'text-zinc-300' };
      if (icon) {
        icon.textContent = icons[status] || '○';
        icon.className = icon.className.replace(/text-\w+-\d+|text-zinc-300/, colors[status] || 'text-zinc-300');
      }
    }
  });
}

function copyText(value) {
  if (!value) return;
  navigator.clipboard.writeText(value).catch(() => {});
}

function copyMarketingLinkBlock() {
  const value = document.getElementById('marketing-link-block')?.value || '';
  if (!value) return;
  copyText(value);
}

function approveMarketingAsset(songId, assetKey) {
  fetch('/api/songs/' + songId + '/marketing-assets/approve', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ assetKey, approved: true }),
  }).then(r => r.json()).then(d => {
    if (!d.ok) throw new Error(d.error || 'Approval failed');
    window.location.reload();
  }).catch(err => alert(err.message));
}

function runReleaseSelection(songId) {
  fetch('/api/songs/' + songId + '/release-selection/analyze', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
  }).then(r => r.json().then(d => ({ ok: r.ok, data: d })))
    .then(({ ok, data }) => {
      if (!ok || !data.ok) throw new Error(data.error || 'Analysis failed');
      window.location.reload();
    })
    .catch(err => alert('Release-selection analysis failed: ' + err.message));
}

function applyReleaseSelectionAction(songId, action) {
  fetch('/api/songs/' + songId + '/release-selection/approve', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action }),
  }).then(r => r.json().then(d => ({ ok: r.ok, data: d })))
    .then(({ ok, data }) => {
      if (!ok || !data.ok) throw new Error(data.error || 'Action failed');
      window.location.reload();
    })
    .catch(err => alert('Release-selection action failed: ' + err.message));
}

</script>
