<% title = 'Generating — ' + (song.title || song.topic) %>
<% const requestedRenderMode = (typeof renderMode !== 'undefined' && renderMode === 'free') ? 'free' : 'paid'; %>

<script>
window.pipelineData = function() {
  return {
    state: 'idle',
    logs: [],
    errorMsg: '',
    jobId: null,
    completeSongId: null,
    eventSource: null,
    renderMode: '<%= requestedRenderMode %>',

    init() {
      this.startPipeline();
    },

    async startPipeline() {
      this.state = 'running';
      this.logs = [];
      this.errorMsg = '';
      try {
        const res = await fetch('/api/songs/<%= song.id %>/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ renderMode: this.renderMode })
        });
        const data = await res.json();
        if (!data.ok) throw new Error(data.error || 'Failed to start pipeline');
        this.jobId = data.jobId;
        if (data.renderMode) this.renderMode = data.renderMode;
        this.listenToStream(data.jobId);
      } catch (err) {
        this.state = 'error';
        this.errorMsg = err.message;
      }
    },

    switchMode(mode) {
      if (this.state === 'running') return;
      window.location.href = '/songs/<%= song.id %>/generate?renderMode=' + encodeURIComponent(mode);
    },

    listenToStream(jobId) {
      if (this.eventSource) this.eventSource.close();
      this.eventSource = new EventSource('/api/songs/pipeline/stream/' + jobId);

      this.eventSource.addEventListener('log', (e) => {
        const { message } = JSON.parse(e.data);
        this.logs.push(message);
        this.$nextTick(() => {
          const el = document.getElementById('pipeline-log');
          if (el) el.scrollTop = el.scrollHeight;
        });
      });

      this.eventSource.addEventListener('complete', (e) => {
        const d = JSON.parse(e.data);
        this.completeSongId = d.songId || null;
        this.state = 'done';
        this.eventSource.close();
      });

      this.eventSource.addEventListener('error', (e) => {
        if (e.data) {
          try { this.errorMsg = JSON.parse(e.data).message || 'Pipeline error'; }
          catch { this.errorMsg = e.data; }
          this.state = 'error';
          this.eventSource.close();
        }
      });

      this.eventSource.onerror = (e) => {
        if (this.state === 'running') {
          this.logs.push('⚠ Connection interrupted — reconnecting…');
        }
      };
    },

    get songUrl() {
      return '/songs/' + (this.completeSongId || '<%= song.id %>');
    },

    get renderModeLabel() {
      return this.renderMode === 'free' ? '🧪 Free audition — MiniMax music-2.6-free' : '💎 Paid render — MiniMax music-2.6';
    },
  };
};
</script>

<div class="p-8 max-w-3xl" x-data="pipelineData()" x-init="init()">

  <a href="/songs/<%= song.id %>" class="text-sm text-zinc-500 hover:text-zinc-700 mb-6 inline-flex items-center gap-1">← Back to Song</a>

  <div class="flex items-center gap-4 mb-6">
    <img src="/logo.png" alt="" class="w-14 h-14 object-contain">
    <div>
      <h1 class="text-2xl font-bold">Generating Song</h1>
      <p class="text-zinc-500 mt-0.5 text-sm font-medium"><%= song.title || song.topic %></p>
    </div>
  </div>

  <!-- Render model selector -->
  <div class="bg-white border border-zinc-200 rounded-2xl p-4 mb-8 flex items-center justify-between gap-4">
    <div>
      <div class="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-1">Music Render Mode</div>
      <div class="text-sm font-semibold text-zinc-800" x-text="renderModeLabel"></div>
      <div class="text-xs text-zinc-500 mt-1">Paid is the default. Free is for auditions; switch back to paid before final render.</div>
    </div>
    <div class="flex bg-zinc-100 rounded-xl p-1 shrink-0">
      <button @click="switchMode('paid')" :disabled="state === 'running'"
        :class="renderMode === 'paid' ? 'bg-zinc-900 text-white shadow' : 'text-zinc-500 hover:text-zinc-800'"
        class="px-4 py-2 rounded-lg text-sm font-semibold transition disabled:opacity-50">
        💎 Paid
      </button>
      <button @click="switchMode('free')" :disabled="state === 'running'"
        :class="renderMode === 'free' ? 'bg-amber-500 text-white shadow' : 'text-zinc-500 hover:text-zinc-800'"
        class="px-4 py-2 rounded-lg text-sm font-semibold transition disabled:opacity-50">
        🧪 Free
      </button>
    </div>
  </div>

  <!-- Pipeline steps indicator -->
  <div class="grid grid-cols-4 gap-2 mb-8 text-center text-xs text-zinc-500">
    <% for (const [icon, label] of [['✍️','Lyrics'],['🎵','Music'],['🖼️','Thumbnails'],['📦','Package']]) { %>
    <div class="bg-white border border-zinc-200 rounded-xl py-3 px-2">
      <div class="text-2xl mb-1"><%= icon %></div>
      <div class="font-medium"><%= label %></div>
    </div>
    <% } %>
  </div>

  <!-- Terminal -->
  <div class="bg-zinc-950 rounded-2xl shadow-xl overflow-hidden mb-4">
    <div class="flex items-center gap-2 px-4 py-3 bg-zinc-900 border-b border-zinc-800">
      <span class="w-3 h-3 rounded-full bg-red-500"></span>
      <span class="w-3 h-3 rounded-full bg-amber-500"></span>
      <span class="w-3 h-3 rounded-full bg-green-500"></span>
      <span class="ml-3 text-xs text-zinc-500 font-mono">pancake-robot — song pipeline</span>
      <span class="ml-auto text-xs font-semibold font-mono"
            :class="state === 'running' ? 'text-green-400' : state === 'done' ? 'text-emerald-400' : state === 'error' ? 'text-red-400' : 'text-zinc-600'">
        <span x-show="state === 'running'" class="inline-flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span> Running
        </span>
        <span x-show="state === 'done'">✓ Complete</span>
        <span x-show="state === 'error'">✗ Failed</span>
        <span x-show="state === 'idle'">Starting…</span>
      </span>
    </div>

    <div id="pipeline-log"
         class="p-5 font-mono text-sm space-y-0.5 overflow-y-auto"
         style="min-height: 320px; max-height: 520px;">
      <div class="text-zinc-600 mb-1">$ node src/orchestrator.js --new "<%= (song.topic || song.title || '').replace(/"/g, '\\"') %>"</div>
      <div class="text-zinc-600 mb-2">$ render mode: <span x-text="renderMode"></span></div>
      <div class="text-zinc-700 mb-3">────────────────────────────────────────</div>
      <template x-for="(line, i) in logs" :key="i">
        <div class="leading-relaxed whitespace-pre-wrap break-words"
             :class="{
               'text-emerald-400 font-semibold': line.startsWith('✅') || line.startsWith('✓ '),
               'text-green-300':  line.startsWith('✓') && !line.startsWith('✅'),
               'text-amber-400':  line.startsWith('⚠') || line.includes('[WARN]'),
               'text-red-400':    line.startsWith('❌') || line.startsWith('✗'),
               'text-cyan-300':   line.startsWith('📌') || line.startsWith('🎵') || line.startsWith('🖼') || line.startsWith('📦') || line.startsWith('📀'),
               'text-zinc-500':   line.startsWith('$') || line.startsWith('──'),
               'text-zinc-300':   !line.startsWith('✅') && !line.startsWith('✓') && !line.startsWith('⚠') && !line.startsWith('❌') && !line.startsWith('✗') && !line.startsWith('📌') && !line.startsWith('🎵') && !line.startsWith('🖼') && !line.startsWith('📦') && !line.startsWith('📀') && !line.startsWith('$'),
             }"
             x-text="line">
        </div>
      </template>
      <div class="text-zinc-600 animate-pulse mt-2" x-show="state === 'running'">▌</div>
      <div x-show="logs.length === 0 && state === 'running'" class="text-zinc-600">Starting pipeline…</div>
    </div>
  </div>

  <div x-show="state === 'running'" class="text-xs text-zinc-400 text-center mb-6">
    Full pipeline takes 2–5 minutes — lyrics → music → thumbnails → packaging
  </div>

  <div x-show="state === 'done'" style="display:none"
       class="bg-emerald-50 border border-emerald-200 rounded-2xl p-6 flex items-center justify-between gap-4">
    <div>
      <div class="font-bold text-emerald-800 text-lg mb-1">🎉 Song Ready!</div>
      <div class="text-sm text-emerald-700">Lyrics, audio, and thumbnails generated. Click to review and approve.</div>
      <div class="text-xs text-zinc-400 mt-1 font-mono" x-show="completeSongId" x-text="'Song ID: ' + completeSongId"></div>
    </div>
    <a :href="songUrl"
       class="shrink-0 bg-emerald-600 hover:bg-emerald-700 text-white font-bold px-6 py-3 rounded-xl transition text-sm shadow">
      Review Song →
    </a>
  </div>

  <div x-show="state === 'error'" style="display:none"
       class="bg-red-50 border border-red-200 rounded-2xl p-6">
    <div class="font-bold text-red-800 mb-1">❌ Pipeline Failed</div>
    <p class="text-sm text-red-600 font-mono mb-1" x-text="errorMsg"></p>
    <p class="text-xs text-zinc-500 mb-4">Scroll up in the terminal to find the error. Common causes: API key missing, network timeout, or lyrics QA failure.</p>
    <div class="flex gap-3">
      <button @click="startPipeline()"
        class="bg-zinc-900 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-zinc-700 transition">
        🔄 Retry
      </button>
      <a href="/songs/<%= song.id %>"
        class="border border-zinc-200 text-zinc-600 px-5 py-2 rounded-lg text-sm hover:bg-zinc-50 transition">
        Back to Song
      </a>
    </div>
  </div>

</div>
