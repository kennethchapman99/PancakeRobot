<% title = 'Select Release Audio' %>
<div class="p-8 max-w-5xl">
  <a href="<%= returnTo || ('/songs/' + encodeURIComponent(song.id)) %>" class="mb-4 inline-flex text-sm text-zinc-500 hover:text-zinc-700">← Back</a>

  <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Release Master Audio</div>
        <h1 class="mt-1 text-3xl font-black tracking-tight text-zinc-900"><%= song.title || song.topic || song.id %></h1>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-zinc-600">Pick the exact audio file that should be used for song detail, album release packaging, and DistroKid submission. This does not delete the other versions.</p>
      </div>
      <div class="rounded-xl border <%= releaseAudio.status === 'selected' || releaseAudio.status === 'auto' ? 'border-emerald-200 bg-emerald-50 text-emerald-900' : releaseAudio.status === 'needs_selection' ? 'border-amber-200 bg-amber-50 text-amber-950' : 'border-rose-200 bg-rose-50 text-rose-950' %> px-4 py-3 text-sm">
        <div class="text-xs font-semibold uppercase tracking-wide opacity-75">Current state</div>
        <div class="mt-1 font-black"><%= releaseAudio.status === 'selected' ? 'Release master selected' : releaseAudio.status === 'auto' ? 'Auto-selected single file' : releaseAudio.status === 'needs_selection' ? 'Choose a release master' : 'No audio found' %></div>
        <div class="mt-1 text-xs leading-5 opacity-90"><%= releaseAudio.message %></div>
      </div>
    </div>
  </div>

  <% if ((releaseAudio.candidates || []).length) { %>
    <section class="mt-6 space-y-4">
      <% releaseAudio.candidates.forEach((candidate, index) => { %>
        <% const selected = releaseAudio.selected && candidate.relativePath === releaseAudio.selected.relativePath; %>
        <div class="rounded-2xl border <%= selected ? 'border-emerald-300 bg-emerald-50' : 'border-zinc-200 bg-white' %> p-4 shadow-sm">
          <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2">
                <div class="font-black text-zinc-900"><%= candidate.name || ('Audio option ' + (index + 1)) %></div>
                <% if (selected) { %><span class="badge-green">Selected release master</span><% } %>
                <span class="badge-gray"><%= candidate.source %></span>
                <% if (candidate.size) { %><span class="badge-gray"><%= (candidate.size / 1024 / 1024).toFixed(1) %> MB</span><% } %>
              </div>
              <div class="mt-1 truncate text-xs text-zinc-500"><%= candidate.relativePath %></div>
              <audio controls class="mt-3 w-full" preload="metadata">
                <source src="<%= candidate.url %>" type="<%= candidate.relativePath.toLowerCase().endsWith('.wav') ? 'audio/wav' : 'audio/mpeg' %>">
              </audio>
            </div>
            <form method="POST" action="/songs/<%= encodeURIComponent(song.id) %>/release-audio" class="shrink-0">
              <input type="hidden" name="file_path" value="<%= candidate.relativePath %>">
              <input type="hidden" name="return_to" value="<%= returnTo || ('/songs/' + encodeURIComponent(song.id)) %>">
              <button <%= selected ? 'disabled' : '' %> class="rounded-xl <%= selected ? 'bg-emerald-100 text-emerald-700' : 'bg-zinc-900 text-white hover:bg-zinc-700' %> px-4 py-2 text-sm font-bold disabled:cursor-default"> <%= selected ? 'Selected' : 'Use this as release master' %></button>
            </form>
          </div>
        </div>
      <% }) %>
    </section>
  <% } else { %>
    <div class="mt-6 rounded-2xl border border-dashed border-zinc-300 bg-zinc-50 p-8 text-center text-sm text-zinc-500">No MP3 or WAV files were found for this song.</div>
  <% } %>
</div>
