<% title = 'Brand Bible' %>

<!-- Safely embed the profile JSON so Alpine can read it without escaping issues -->
<script id="profile-data" type="application/json"><%- profileJson %></script>

<script>
window.brandEditor = function() {
  const p = JSON.parse(document.getElementById('profile-data').textContent);

  function lines(text) {
    return String(text || '').split('\n').map(s => s.trim()).filter(Boolean);
  }
  function csv(text) {
    return String(text || '').split(',').map(s => s.trim()).filter(Boolean);
  }

  return {
    saving: false,
    saved: false,
    errorMsg: '',
    original: p,

    // Brand basics
    brand_name:          p.brand_name || '',
    brand_description:   p.brand_description || '',
    audience_age_range:  p.audience?.age_range || '',
    audience_description:p.audience?.description || '',
    audience_guardrail:  p.audience?.guardrail || '',

    // Character
    char_name:           p.character?.name || '',
    char_core_concept:   p.character?.core_concept || '',
    char_visual_identity:p.character?.visual_identity || '',
    char_traits:         (p.character?.personality_traits || []).join('\n'),
    char_catchphrases:   (p.character?.catchphrases || []).join('\n'),

    // Music
    music_style:         p.music?.default_style || '',
    music_bpm:           p.music?.default_bpm || 118,
    music_key:           p.music?.default_key || '',
    music_prompt:        p.music?.default_prompt || '',
    music_target_length: p.music?.target_length || '',
    music_word_range:    p.music?.normal_word_range || '',

    // Lyrics
    lyrics_title_examples:  (p.lyrics?.title_examples || []).join('\n'),
    lyrics_topic_variety:    p.lyrics?.topic_variety || '',
    lyrics_required_closing: p.lyrics?.required_closing || '',

    // Songwriting — voice
    sw_goal:        p.songwriting?.primary_emotional_goal || '',
    cv_person:      p.songwriting?.character_voice?.person || '',
    cv_tone:        p.songwriting?.character_voice?.tone || '',
    cv_vocabulary:  p.songwriting?.character_voice?.vocabulary || '',
    cv_sounds:      (p.songwriting?.character_voice?.signature_sounds || []).join(', '),
    cv_comedy:      p.songwriting?.character_voice?.comedy_mode || '',
    cv_kids:        p.songwriting?.character_voice?.kid_relationship || '',

    // Songwriting — hook & structure
    earworm_stack:        (p.songwriting?.earworm_stack || []).join('\n'),
    hook_rules:           (p.songwriting?.hook_design_rules || []).join('\n'),
    energy_arc_pattern:   p.songwriting?.energy_arc?.pattern || '',
    energy_arc_rules:     (p.songwriting?.energy_arc?.rules || []).join('\n'),
    participation:        (p.songwriting?.participation_patterns || []).join('\n'),
    structure_prefs:      (p.songwriting?.structure_preferences || []).join('\n'),

    // Songwriting — rules
    allowed_elements:  (p.songwriting?.allowed_elements || []).join('\n'),
    forbidden_elements:(p.songwriting?.forbidden_elements || []).join('\n'),
    render_safety:     (p.songwriting?.render_safety || []).join('\n'),
    required_elements: (p.songwriting?.required_elements || []).join('\n'),
    qa_rules:          (p.songwriting?.qa_rules || []).join('\n'),

    buildProfile() {
      const o = this.original;
      return {
        ...o,
        brand_name:        this.brand_name,
        brand_description: this.brand_description,
        audience: { ...o.audience,
          age_range:   this.audience_age_range,
          description: this.audience_description,
          guardrail:   this.audience_guardrail,
        },
        character: { ...o.character,
          name:               this.char_name,
          core_concept:       this.char_core_concept,
          visual_identity:    this.char_visual_identity,
          personality_traits: lines(this.char_traits),
          catchphrases:       lines(this.char_catchphrases),
        },
        music: { ...o.music,
          default_style:  this.music_style,
          default_bpm:    Number(this.music_bpm),
          default_key:    this.music_key,
          default_prompt: this.music_prompt,
          target_length:  this.music_target_length,
          normal_word_range: this.music_word_range,
        },
        lyrics: { ...o.lyrics,
          title_examples:   lines(this.lyrics_title_examples),
          topic_variety:    this.lyrics_topic_variety,
          required_closing: this.lyrics_required_closing,
        },
        songwriting: { ...o.songwriting,
          primary_emotional_goal: this.sw_goal,
          character_voice: { ...(o.songwriting?.character_voice || {}),
            person:           this.cv_person,
            tone:             this.cv_tone,
            vocabulary:       this.cv_vocabulary,
            signature_sounds: csv(this.cv_sounds),
            comedy_mode:      this.cv_comedy,
            kid_relationship: this.cv_kids,
          },
          earworm_stack:        lines(this.earworm_stack),
          hook_design_rules:    lines(this.hook_rules),
          energy_arc: {
            pattern: this.energy_arc_pattern,
            rules:   lines(this.energy_arc_rules),
          },
          participation_patterns: lines(this.participation),
          structure_preferences:  lines(this.structure_prefs),
          allowed_elements:       lines(this.allowed_elements),
          forbidden_elements:     lines(this.forbidden_elements),
          render_safety:          lines(this.render_safety),
          required_elements:      lines(this.required_elements),
          qa_rules:               lines(this.qa_rules),
        },
      };
    },

    async save() {
      this.saving = true;
      this.saved = false;
      this.errorMsg = '';
      try {
        const profileId = document.getElementById('profileId').value;
        const res = await fetch('/api/brand', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ profileId, profileJson: JSON.stringify(this.buildProfile()) }),
        });
        const d = await res.json();
        if (!d.ok) throw new Error(d.error || 'Save failed');
        this.saved = true;
        this.original = this.buildProfile();
        setTimeout(() => this.saved = false, 3000);
      } catch (err) {
        this.errorMsg = err.message;
      } finally {
        this.saving = false;
      }
    }
  };
};
</script>

<%- /* ─── helpers ─────────────────────────────────────────────────── */ '' %>

<div class="p-8 max-w-4xl" x-data="brandEditor()">
<input type="hidden" id="profileId" value="<%= activeProfileId || 'default' %>">

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold">Brand Bible</h1>
      <p class="text-sm text-zinc-500 mt-1">Every field here is injected into song generation. Changes take effect on the next run.</p>
    </div>
    <div class="flex items-center gap-3">
      <span x-show="saved" x-cloak class="text-sm text-emerald-600 font-medium">✓ Saved</span>
      <span x-show="errorMsg" x-cloak x-text="errorMsg" class="text-sm text-red-600 max-w-xs truncate"></span>
      <button @click="save()" :disabled="saving"
        class="bg-zinc-900 hover:bg-zinc-700 disabled:opacity-40 text-white font-semibold px-5 py-2 rounded-xl transition text-sm">
        <span x-show="!saving">Save</span>
        <span x-show="saving" x-cloak>Saving…</span>
      </button>
    </div>
  </div>

  <!-- Profile switcher -->
  <div class="bg-white border border-zinc-200 rounded-xl p-4 mb-6">
    <div class="flex items-center justify-between gap-4">
      <span class="text-sm text-zinc-500">Edit profile</span>
      <div class="flex items-center gap-3">
        <form method="GET" action="/brand" class="flex items-center gap-2">
          <select name="profile" onchange="this.form.submit()"
            class="border border-zinc-200 rounded-lg px-3 py-2 text-sm bg-white min-w-64">
            <% (profiles || []).forEach(function(prof) { %>
              <option value="<%= prof.id %>" <%= prof.id === activeProfileId ? 'selected' : '' %>>
                <%= prof.name %><%= prof.isDefault ? ' — default' : '' %><%= prof.id === activeForGenerationId ? ' ✓' : '' %>
              </option>
            <% }) %>
          </select>
        </form>
        <% if (activeProfileId !== activeForGenerationId) { %>
          <button onclick="activateProfile('<%= activeProfileId %>')"
            class="bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold px-4 py-2 rounded-xl transition">
            Set as Active
          </button>
        <% } else { %>
          <span class="text-sm text-emerald-600 font-medium">✓ Active for generation</span>
        <% } %>
      </div>
    </div>
  </div>

  <script>
  async function activateProfile(profileId) {
    const res = await fetch('/api/brand/activate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ profileId }),
    });
    if (res.ok) window.location.reload();
    else alert('Failed to set active profile: ' + ((await res.json()).error || 'unknown error'));
  }
  </script>

  <!-- ── BRAND BASICS ──────────────────────────────────────────── -->
  <section class="bg-white border border-zinc-200 rounded-xl mb-5 overflow-hidden">
    <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
      <h2 class="font-bold text-zinc-800">Brand Basics</h2>
    </div>
    <div class="px-6 py-5 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="field-label">Brand Name</label>
          <input type="text" x-model="brand_name" class="field-input">
        </div>
        <div>
          <label class="field-label">Audience Age Range</label>
          <input type="text" x-model="audience_age_range" class="field-input" placeholder="e.g. 4-10">
        </div>
      </div>
      <div>
        <label class="field-label">Brand Description</label>
        <input type="text" x-model="brand_description" class="field-input" placeholder="one-line description used in prompts">
      </div>
      <div>
        <label class="field-label">Audience Description <span class="field-hint">— used in prompts</span></label>
        <input type="text" x-model="audience_description" class="field-input">
      </div>
      <div>
        <label class="field-label">Content Guardrail</label>
        <input type="text" x-model="audience_guardrail" class="field-input" placeholder="e.g. age-appropriate for ages 4-10">
      </div>
    </div>
  </section>

  <!-- ── CHARACTER ─────────────────────────────────────────────── -->
  <section class="bg-white border border-zinc-200 rounded-xl mb-5 overflow-hidden">
    <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
      <h2 class="font-bold text-zinc-800">Character</h2>
      <p class="text-xs text-zinc-500 mt-0.5">Who is singing? This shapes every lyric.</p>
    </div>
    <div class="px-6 py-5 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="field-label">Name</label>
          <input type="text" x-model="char_name" class="field-input">
        </div>
        <div>
          <label class="field-label">Core Concept</label>
          <input type="text" x-model="char_core_concept" class="field-input" placeholder="one-line character summary">
        </div>
      </div>
      <div>
        <label class="field-label">Visual Identity <span class="field-hint">— used in image generation prompts</span></label>
        <textarea x-model="char_visual_identity" rows="2" class="field-input resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Personality Traits <span class="field-hint">— one per line</span></label>
        <textarea x-model="char_traits" rows="6" class="field-input font-mono resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Catchphrases <span class="field-hint">— one per line</span></label>
        <textarea x-model="char_catchphrases" rows="5" class="field-input font-mono resize-y"></textarea>
      </div>
    </div>
  </section>

  <!-- ── MUSIC ─────────────────────────────────────────────────── -->
  <section class="bg-white border border-zinc-200 rounded-xl mb-5 overflow-hidden">
    <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
      <h2 class="font-bold text-zinc-800">Music</h2>
      <p class="text-xs text-zinc-500 mt-0.5">Defaults sent to the music generator.</p>
    </div>
    <div class="px-6 py-5 space-y-4">
      <div class="grid grid-cols-3 gap-4">
        <div>
          <label class="field-label">Default Style</label>
          <input type="text" x-model="music_style" class="field-input">
        </div>
        <div>
          <label class="field-label">BPM</label>
          <input type="number" x-model="music_bpm" class="field-input">
        </div>
        <div>
          <label class="field-label">Key</label>
          <input type="text" x-model="music_key" class="field-input" placeholder="e.g. C Major">
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="field-label">Target Length</label>
          <input type="text" x-model="music_target_length" class="field-input" placeholder="e.g. 1:30-3:00">
        </div>
        <div>
          <label class="field-label">Word Count Range</label>
          <input type="text" x-model="music_word_range" class="field-input" placeholder="e.g. 140-320">
        </div>
      </div>
      <div>
        <label class="field-label">Audio Prompt <span class="field-hint">— sent directly to music generation API</span></label>
        <textarea x-model="music_prompt" rows="2" class="field-input resize-y"></textarea>
      </div>
    </div>
  </section>

  <!-- ── LYRICS ─────────────────────────────────────────────────── -->
  <section class="bg-white border border-zinc-200 rounded-xl mb-5 overflow-hidden">
    <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
      <h2 class="font-bold text-zinc-800">Lyrics</h2>
    </div>
    <div class="px-6 py-5 space-y-4">
      <div>
        <label class="field-label">Title Examples <span class="field-hint">— one per line, shown to lyricist as style reference</span></label>
        <textarea x-model="lyrics_title_examples" rows="4" class="field-input font-mono resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Topic Variety <span class="field-hint">— comma-separated topics the lyricist can draw from</span></label>
        <textarea x-model="lyrics_topic_variety" rows="2" class="field-input resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Required Closing</label>
        <input type="text" x-model="lyrics_required_closing" class="field-input">
      </div>
    </div>
  </section>

  <!-- ── CHARACTER VOICE ───────────────────────────────────────── -->
  <section class="bg-white border border-zinc-200 rounded-xl mb-5 overflow-hidden">
    <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
      <h2 class="font-bold text-zinc-800">Character Voice</h2>
      <p class="text-xs text-zinc-500 mt-0.5">How the character speaks and sounds — injected into every lyric prompt.</p>
    </div>
    <div class="px-6 py-5 space-y-4">
      <div>
        <label class="field-label">Primary Emotional Goal</label>
        <input type="text" x-model="sw_goal" class="field-input" placeholder="e.g. high-energy replayability, joy, silliness, kid participation">
      </div>
      <div>
        <label class="field-label">Person / POV</label>
        <input type="text" x-model="cv_person" class="field-input" placeholder="e.g. First-person — Pancake Robot speaks directly to kids">
      </div>
      <div>
        <label class="field-label">Tone</label>
        <textarea x-model="cv_tone" rows="2" class="field-input resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Vocabulary Rules</label>
        <textarea x-model="cv_vocabulary" rows="2" class="field-input resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Signature Sounds <span class="field-hint">— comma-separated, singable sounds the character makes</span></label>
        <input type="text" x-model="cv_sounds" class="field-input font-mono" placeholder="BEEP, BOOP, CLANK, WHIRR, DING">
      </div>
      <div>
        <label class="field-label">Comedy Mode</label>
        <textarea x-model="cv_comedy" rows="2" class="field-input resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Relationship to Kids</label>
        <input type="text" x-model="cv_kids" class="field-input">
      </div>
    </div>
  </section>

  <!-- ── EARWORM & HOOKS ───────────────────────────────────────── -->
  <section class="bg-white border border-zinc-200 rounded-xl mb-5 overflow-hidden">
    <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
      <h2 class="font-bold text-zinc-800">Earworm Stack & Hook Rules</h2>
      <p class="text-xs text-zinc-500 mt-0.5">The formulas that make songs stick. Injected directly into the lyricist prompt.</p>
    </div>
    <div class="px-6 py-5 space-y-4">
      <div>
        <label class="field-label">Earworm Stack <span class="field-hint">— one step per line</span></label>
        <textarea x-model="earworm_stack" rows="7" class="field-input font-mono resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Hook Design Rules <span class="field-hint">— one rule per line</span></label>
        <textarea x-model="hook_rules" rows="7" class="field-input font-mono resize-y"></textarea>
      </div>
    </div>
  </section>

  <!-- ── ENERGY ARC & STRUCTURE ────────────────────────────────── -->
  <section class="bg-white border border-zinc-200 rounded-xl mb-5 overflow-hidden">
    <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
      <h2 class="font-bold text-zinc-800">Energy Arc & Structure</h2>
    </div>
    <div class="px-6 py-5 space-y-4">
      <div>
        <label class="field-label">Energy Arc Pattern</label>
        <input type="text" x-model="energy_arc_pattern" class="field-input" placeholder="e.g. BURST → BUILD → BURST → BREATHE → BIGGER BURST → LAND">
      </div>
      <div>
        <label class="field-label">Energy Arc Rules <span class="field-hint">— one per line</span></label>
        <textarea x-model="energy_arc_rules" rows="5" class="field-input font-mono resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Structure Options <span class="field-hint">— one per line, lyricist picks from these</span></label>
        <textarea x-model="structure_prefs" rows="4" class="field-input font-mono resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Participation Patterns <span class="field-hint">— one per line</span></label>
        <textarea x-model="participation" rows="5" class="field-input font-mono resize-y"></textarea>
      </div>
    </div>
  </section>

  <!-- ── RULES ─────────────────────────────────────────────────── -->
  <section class="bg-white border border-zinc-200 rounded-xl mb-5 overflow-hidden">
    <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
      <h2 class="font-bold text-zinc-800">Rules & Guardrails</h2>
      <p class="text-xs text-zinc-500 mt-0.5">Used for both lyric generation and brand review scoring.</p>
    </div>
    <div class="px-6 py-5 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="field-label text-emerald-700">Allowed Elements <span class="field-hint">— one per line</span></label>
          <textarea x-model="allowed_elements" rows="10" class="field-input font-mono border-emerald-200 focus:ring-emerald-400 resize-y"></textarea>
        </div>
        <div>
          <label class="field-label text-red-700">Forbidden Elements <span class="field-hint">— one per line</span></label>
          <textarea x-model="forbidden_elements" rows="10" class="field-input font-mono border-red-200 focus:ring-red-300 resize-y"></textarea>
        </div>
      </div>
      <div>
        <label class="field-label">Required Elements <span class="field-hint">— one per line, lyricist must include all of these</span></label>
        <textarea x-model="required_elements" rows="6" class="field-input font-mono resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">Render Safety Rules <span class="field-hint">— enforced before audio generation</span></label>
        <textarea x-model="render_safety" rows="5" class="field-input font-mono resize-y"></textarea>
      </div>
      <div>
        <label class="field-label">QA Rules <span class="field-hint">— checked after lyrics are generated</span></label>
        <textarea x-model="qa_rules" rows="5" class="field-input font-mono resize-y"></textarea>
      </div>
    </div>
  </section>

  <!-- Sticky save bar -->
  <div class="sticky bottom-0 bg-white border-t border-zinc-200 -mx-8 px-8 py-3 flex items-center justify-between">
    <p class="text-xs text-zinc-400">Changes take effect on the next song generation.</p>
    <div class="flex items-center gap-3">
      <span x-show="saved" x-cloak class="text-sm text-emerald-600 font-medium">✓ Saved</span>
      <span x-show="errorMsg" x-cloak x-text="errorMsg" class="text-sm text-red-600 max-w-xs truncate"></span>
      <button @click="save()" :disabled="saving"
        class="bg-zinc-900 hover:bg-zinc-700 disabled:opacity-40 text-white font-semibold px-6 py-2.5 rounded-xl transition text-sm">
        <span x-show="!saving">Save Changes</span>
        <span x-show="saving" x-cloak>Saving…</span>
      </button>
    </div>
  </div>

</div>

<style>
  .field-label { display: block; font-size: 0.75rem; font-weight: 600; color: #71717a; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.375rem; }
  .field-hint  { font-weight: 400; text-transform: none; letter-spacing: 0; color: #a1a1aa; }
  .field-input { width: 100%; border: 1px solid #e4e4e7; border-radius: 0.5rem; padding: 0.5rem 0.75rem; font-size: 0.875rem; background: white; }
  .field-input:focus { outline: none; box-shadow: 0 0 0 2px #18181b; }
</style>
