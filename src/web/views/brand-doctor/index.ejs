<% title = 'Brand Doctor' %>

<div class="p-8 max-w-5xl mx-auto">

  <!-- Header -->
  <div class="bg-white border border-zinc-200 rounded-2xl px-8 py-6 shadow-sm mb-8">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-3xl font-extrabold text-zinc-900 tracking-tight">🩺 Brand Doctor</h1>
        <p class="text-zinc-500 mt-1 text-sm">Tune a brand profile using candidate directions or audio analysis. Changes require your explicit approval before writing.</p>
      </div>
    </div>

    <% if (message) { %>
    <div class="mt-4 bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm"><%= message %></div>
    <% } %>
    <% if (error) { %>
    <div class="mt-4 bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm"><%= error %></div>
    <% } %>
  </div>

  <!-- New Session Card -->
  <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm mb-8">
    <h2 class="text-lg font-bold text-zinc-900 mb-4">Start a New Session</h2>

    <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 text-sm text-amber-800 mb-5">
      ⚠️ <strong>Cost notice:</strong> Candidate mode is text-only and does not generate audio renders.
      Audio generation requires explicit approval via a separate action.
    </div>

    <form method="POST" action="/api/brand-doctor/sessions" class="space-y-5">

      <div>
        <label class="block text-sm font-semibold text-zinc-700 mb-1">Brand Profile</label>
        <select name="brandId" required
          class="w-full border border-zinc-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-zinc-400">
          <% for (const profile of profiles) { %>
            <option value="<%= profile.id %>"><%= profile.name %><% if (profile.isDefault) { %> (default)<% } %></option>
          <% } %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-semibold text-zinc-700 mb-2">Mode</label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="relative flex gap-3 items-start p-4 border border-zinc-200 rounded-xl cursor-pointer hover:border-zinc-400 transition has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
            <input type="radio" name="mode" value="candidates" class="mt-0.5 accent-indigo-600" checked>
            <div>
              <div class="font-semibold text-sm text-zinc-900">Tune with Candidates</div>
              <div class="text-xs text-zinc-500 mt-0.5">Generate 4–6 differentiated creative directions, rate them, and get a profile patch proposal. Text-only.</div>
            </div>
          </label>
          <label class="relative flex gap-3 items-start p-4 border border-zinc-200 rounded-xl cursor-pointer hover:border-zinc-400 transition has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
            <input type="radio" name="mode" value="analyze" class="mt-0.5 accent-indigo-600">
            <div>
              <div class="font-semibold text-sm text-zinc-900">Analyze Existing Songs</div>
              <div class="text-xs text-zinc-500 mt-0.5">Upload MP3s, tag them, run local audio analysis, and get a profile patch proposal.</div>
            </div>
          </label>
        </div>
      </div>

      <button type="submit"
        class="bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition">
        Start Session →
      </button>
    </form>
  </div>

  <!-- Session History -->
  <% if (sessions.length > 0) { %>
  <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm">
    <h2 class="text-lg font-bold text-zinc-900 mb-4">Session History</h2>
    <div class="space-y-2">
      <% for (const s of sessions) { %>
        <%
          const statusColors = {
            in_progress: 'bg-zinc-100 text-zinc-600',
            candidates_generated: 'bg-blue-100 text-blue-700',
            audio_analyzed: 'bg-blue-100 text-blue-700',
            feedback_submitted: 'bg-yellow-100 text-yellow-700',
            patch_proposed: 'bg-purple-100 text-purple-700',
            draft_saved: 'bg-indigo-100 text-indigo-700',
            applied: 'bg-green-100 text-green-700',
            rejected: 'bg-red-100 text-red-600',
            aborted: 'bg-zinc-100 text-zinc-400',
          };
          const badgeClass = statusColors[s.status] || 'bg-zinc-100 text-zinc-600';
          const modeLabel = s.mode === 'candidates' ? 'Candidates' : 'Analyze';
        %>
        <a href="/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>"
           class="flex items-center justify-between gap-4 px-4 py-3 rounded-xl border border-zinc-100 hover:border-zinc-200 hover:bg-zinc-50 transition">
          <div class="min-w-0">
            <div class="font-semibold text-sm text-zinc-900 truncate"><%= s.currentProfileSummary?.brand_name || s.brandId %></div>
            <div class="text-xs text-zinc-400 mt-0.5"><%= new Date(s.timestamp).toLocaleString() %> · <%= modeLabel %></div>
          </div>
          <span class="shrink-0 text-xs font-medium px-2.5 py-0.5 rounded-full <%= badgeClass %>"><%= s.status.replace(/_/g, ' ') %></span>
        </a>
      <% } %>
    </div>
  </div>
  <% } %>

</div>
