<% title = 'Brand Doctor — ' + (session.currentProfileSummary?.brand_name || session.brandId) %>

<%
  const isCandidateMode = session.mode === 'candidates';
  const isAnalyzeMode = session.mode === 'analyze';
  const s = session;
  const summary = s.currentProfileSummary || {};
  const isApplied = s.status === 'applied';
  const isRejected = s.status === 'rejected' || s.status === 'aborted';
  const hasPatch = !!s.proposedPatch;
  const validationOk = s.validationResult?.valid;
%>

<div class="p-6 max-w-5xl mx-auto space-y-6" x-data="brandDoctorSession()">

  <!-- Back + status bar -->
  <div class="flex items-center justify-between gap-4">
    <a href="/brand-doctor" class="text-sm text-zinc-500 hover:text-zinc-800 transition">← All Sessions</a>
    <div class="flex items-center gap-3">
      <span class="text-xs font-mono text-zinc-400"><%= s.id %></span>
      <%
        const statusColors = {
          in_progress: 'bg-zinc-100 text-zinc-600',
          candidates_generated: 'bg-blue-100 text-blue-700',
          audio_analyzed: 'bg-blue-100 text-blue-700',
          feedback_submitted: 'bg-yellow-100 text-yellow-700',
          patch_proposed: 'bg-purple-100 text-purple-700',
          draft_saved: 'bg-indigo-100 text-indigo-700',
          applied: 'bg-green-100 text-green-700',
          rejected: 'bg-red-100 text-red-600',
          aborted: 'bg-zinc-100 text-zinc-400',
        };
        const badgeClass = statusColors[s.status] || 'bg-zinc-100 text-zinc-600';
      %>
      <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= badgeClass %>"><%= s.status.replace(/_/g, ' ') %></span>
    </div>
  </div>

  <% if (locals.error || locals.message) { %>
  <div class="<%= locals.error ? 'bg-red-50 border-red-200 text-red-800' : 'bg-green-50 border-green-200 text-green-800' %> border rounded-lg px-4 py-3 text-sm">
    <%= locals.error || locals.message %>
  </div>
  <% } %>

  <!-- Applied / Rejected banner -->
  <% if (isApplied) { %>
  <div class="bg-green-50 border border-green-300 rounded-xl px-5 py-4 text-green-800 text-sm font-medium">
    ✅ Patch applied at <%= new Date(s.appliedAt).toLocaleString() %>. Profile has been updated.
  </div>
  <% } %>
  <% if (isRejected) { %>
  <div class="bg-zinc-100 border border-zinc-300 rounded-xl px-5 py-4 text-zinc-600 text-sm font-medium">
    Session <%= s.status %>. No changes were made to the profile.
  </div>
  <% } %>

  <!-- Brand Summary -->
  <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm">
    <h2 class="text-lg font-bold text-zinc-900 mb-4">Brand Summary</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
      <div><span class="text-zinc-500">Brand:</span> <span class="font-semibold"><%= summary.brand_name %></span></div>
      <div><span class="text-zinc-500">Type:</span> <%= summary.brand_type %></div>
      <div><span class="text-zinc-500">Genre / Style:</span> <%= summary.genre_style_center %></div>
      <div><span class="text-zinc-500">Mode:</span> <strong><%= isCandidateMode ? 'Tune with Candidates' : 'Analyze Existing Songs' %></strong></div>
      <% if (summary.character_name) { %>
      <div><span class="text-zinc-500">Character:</span> <%= summary.character_name %></div>
      <% } %>
      <% if (summary.core_concept) { %>
      <div class="sm:col-span-2"><span class="text-zinc-500">Core concept:</span> <%= summary.core_concept %></div>
      <% } %>
    </div>

    <% if (summary.anti_generic_rules?.length) { %>
    <div class="mt-4">
      <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-2">Anti-Generic Rules</div>
      <ul class="text-xs text-zinc-700 space-y-1">
        <% for (const rule of summary.anti_generic_rules) { %><li class="flex gap-2"><span class="text-zinc-400">•</span><%= typeof rule === 'string' ? rule : JSON.stringify(rule) %></li><% } %>
      </ul>
    </div>
    <% } %>

    <% if (summary.weak_areas?.length) { %>
    <div class="mt-4 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3">
      <div class="text-xs font-semibold text-amber-700 uppercase tracking-wide mb-1">Weak / Missing Areas</div>
      <ul class="text-xs text-amber-800 space-y-0.5">
        <% for (const area of summary.weak_areas) { %><li>• <%= area %></li><% } %>
      </ul>
    </div>
    <% } %>
  </div>

  <!-- ── MODE 1: Candidates ─────────────────────────────────────────────── -->
  <% if (isCandidateMode) { %>

    <!-- Generate Candidates -->
    <% if (!s.candidateDirections && !isRejected) { %>
    <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-zinc-900 mb-3">Step 1 — Generate Candidate Directions</h2>
      <p class="text-sm text-zinc-500 mb-4">The system will propose 4–6 differentiated creative directions for this brand. <strong>Text-only — no audio renders.</strong></p>
      <form method="POST" action="/api/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>/candidates"
            x-data="{ loading: false }" @submit="loading = true">
        <button type="submit" :disabled="loading"
          :class="loading ? 'opacity-60 cursor-not-allowed bg-indigo-600' : 'bg-indigo-600 hover:bg-indigo-500'"
          class="text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition inline-flex items-center gap-2">
          <svg x-show="loading" class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
          <span x-text="loading ? 'Generating…' : 'Generate Candidate Directions'">Generate Candidate Directions</span>
        </button>
      </form>
    </div>
    <% } %>

    <!-- Candidate Directions + Feedback -->
    <% if (s.candidateDirections) { %>
    <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-zinc-900 mb-1">Candidate Directions</h2>
      <p class="text-xs text-zinc-400 mb-4">Rate each direction using the feedback tags. At least tag the ones you find strongest or want to reject.</p>

      <div class="space-y-4" id="candidates-list">
        <% for (const c of s.candidateDirections) { %>
        <div class="border border-zinc-100 rounded-xl p-5 space-y-3">
          <div class="flex items-start justify-between gap-2">
            <div>
              <span class="text-xs font-mono text-zinc-400 mr-2"><%= c.id %></span>
              <span class="font-bold text-sm text-zinc-900"><%= c.name %></span>
            </div>
            <span class="text-xs text-zinc-500 bg-zinc-50 border border-zinc-200 px-2 py-0.5 rounded-full shrink-0"><%= c.testing %></span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-zinc-700">
            <div><span class="font-semibold text-zinc-500">Vocal identity:</span> <%= c.vocal_identity %></div>
            <div><span class="font-semibold text-zinc-500">Articulation:</span> <%= c.articulation_phonetics %></div>
            <div><span class="font-semibold text-zinc-500">Hook behavior:</span> <%= c.hook_behavior %></div>
            <div><span class="font-semibold text-zinc-500">Production:</span> <%= c.production_texture %></div>
            <div><span class="font-semibold text-zinc-500">Emotional posture:</span> <%= c.emotional_posture %></div>
            <div><span class="font-semibold text-zinc-500">Conceit:</span> <%= c.performance_conceit %></div>
            <div class="sm:col-span-2"><span class="font-semibold text-zinc-500">Anti-generic risk addressed:</span> <%= c.anti_generic_risk_addressed %></div>
          </div>

          <details class="text-xs">
            <summary class="cursor-pointer text-zinc-400 hover:text-zinc-700">Sample prompts</summary>
            <div class="mt-2 space-y-1 text-zinc-600">
              <div><span class="font-semibold">Audio prompt:</span> <%= c.sample_audio_prompt %></div>
              <div><span class="font-semibold">Negative prompt:</span> <%= c.sample_negative_prompt %></div>
            </div>
          </details>

          <!-- Feedback tags for this candidate -->
          <% const existingFb = s.userFeedback?.candidates?.[c.id]; %>
          <% if (!isApplied && !isRejected && s.status !== 'feedback_submitted') { %>
          <div x-data="candidateFeedback('<%= c.id %>')" class="border-t border-zinc-100 pt-3">
            <div class="text-xs font-semibold text-zinc-500 mb-2">Your feedback tags:</div>
            <div class="flex flex-wrap gap-1.5">
              <% for (const tag of candidateFeedbackTags) { %>
              <button type="button" @click="toggleTag('<%= tag %>')"
                :class="hasTag('<%= tag %>') ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-zinc-50 text-zinc-700 border-zinc-200 hover:border-zinc-400'"
                class="text-xs px-2.5 py-1 border rounded-full transition font-medium">
                <%= tag %>
              </button>
              <% } %>
            </div>
          </div>
          <% } else if (existingFb) { %>
          <div class="border-t border-zinc-100 pt-3">
            <div class="text-xs font-semibold text-zinc-500 mb-1">Submitted feedback:</div>
            <div class="flex flex-wrap gap-1">
              <% for (const tag of (existingFb.tags || [])) { %>
              <span class="text-xs bg-indigo-100 text-indigo-700 px-2 py-0.5 rounded-full"><%= tag %></span>
              <% } %>
            </div>
          </div>
          <% } %>

        </div>
        <% } %>
      </div>

      <!-- Submit Feedback button (candidates) -->
      <% if (!isApplied && !isRejected && s.status !== 'feedback_submitted' && s.status !== 'patch_proposed' && s.status !== 'draft_saved') { %>
      <div class="mt-5 border-t border-zinc-100 pt-5">
        <button type="button" @click="submitCandidateFeedback('<%= s.id %>')"
          class="bg-amber-500 hover:bg-amber-400 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition">
          Submit Feedback →
        </button>
      </div>
      <% } %>
    </div>
    <% } %>

  <% } %>

  <!-- ── MODE 2: Analyze ────────────────────────────────────────────────── -->
  <% if (isAnalyzeMode) { %>

    <!-- Upload / analyze -->
    <% if (!s.audioAnalyses && !isRejected) { %>
    <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-zinc-900 mb-3">Step 1 — Upload MP3s for Analysis</h2>
      <p class="text-sm text-zinc-500 mb-4">Upload one or more audio files. Local analysis uses ffprobe/ffmpeg — no paid model calls for analysis itself.</p>

      <form method="POST" action="/api/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>/analyze"
        enctype="multipart/form-data" class="space-y-4"
        x-data="{ loading: false }" @submit="loading = true">
        <div>
          <label class="block text-sm font-semibold text-zinc-700 mb-1">Audio Files (MP3, WAV, FLAC, etc.)</label>
          <input type="file" name="audio" multiple accept=".mp3,.wav,.flac,.aac,.m4a,.ogg"
            class="block w-full text-sm text-zinc-600 file:mr-3 file:py-1.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100">
        </div>
        <div x-show="loading" class="text-sm text-indigo-700 bg-indigo-50 border border-indigo-200 rounded-lg px-4 py-3 flex items-center gap-3">
          <svg class="animate-spin h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
          Uploading and analyzing audio — this may take 30–60 seconds…
        </div>
        <button type="submit" :disabled="loading"
          :class="loading ? 'opacity-60 cursor-not-allowed bg-indigo-600' : 'bg-indigo-600 hover:bg-indigo-500'"
          class="text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition inline-flex items-center gap-2">
          <svg x-show="loading" class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
          <span x-text="loading ? 'Analyzing…' : 'Analyze Audio'">Analyze Audio</span>
        </button>
      </form>
    </div>
    <% } %>

    <!-- Analysis Results + Feedback -->
    <% if (s.audioAnalyses) { %>
    <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm">
      <h2 class="text-lg font-bold text-zinc-900 mb-1">Audio Analysis Results</h2>
      <p class="text-xs text-zinc-400 mb-4">Note: local audio analysis cannot fully assess vocal originality, copyright safety, or true emotional performance.</p>

      <div class="space-y-4">
        <% for (const analysis of s.audioAnalyses) { %>
        <%
          const m = analysis.raw?.ok ? analysis.raw.metrics : null;
          const impl = analysis.brandImplications;
        %>
        <div class="border border-zinc-100 rounded-xl p-5 space-y-3">
          <div class="font-bold text-sm text-zinc-900"><%= analysis.filename %></div>

          <% if (m) { %>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-xs text-zinc-700">
            <div><span class="text-zinc-500">Duration:</span> <%= m.duration_seconds ? Math.round(m.duration_seconds) + 's' : '—' %></div>
            <div><span class="text-zinc-500">Bitrate:</span> <%= m.bitrate ? Math.round(m.bitrate/1000) + 'kbps' : '—' %></div>
            <div><span class="text-zinc-500">RMS mean:</span> <%= m.rms_energy_mean != null ? m.rms_energy_mean + ' dB' : '—' %></div>
            <div><span class="text-zinc-500">Peak:</span> <%= m.peak_db != null ? m.peak_db + ' dB' : '—' %></div>
            <div><span class="text-zinc-500">Clipping:</span> <%= m.clipping_detected ? '⚠️ Yes' : 'No' %></div>
            <div><span class="text-zinc-500">High-energy segments:</span> <%= m.high_energy_segments?.length ?? 0 %></div>
          </div>
          <% } else if (analysis.raw) { %>
          <div class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded px-3 py-2"><%= analysis.raw.error || analysis.raw.reason || 'Analysis failed or unavailable' %></div>
          <% } %>

          <% if (impl) { %>
          <div class="space-y-2 text-xs text-zinc-700">
            <% if (impl.file_summary) { %><div><span class="font-semibold text-zinc-500">Summary:</span> <%= impl.file_summary %></div><% } %>
            <% if (impl.detected_audio_traits?.length) { %>
            <div><span class="font-semibold text-zinc-500">Detected traits:</span> <%= impl.detected_audio_traits.join(' · ') %></div>
            <% } %>
            <% if (impl.genericness_risk) { %>
            <%
              const riskColors = { low: 'text-green-700 bg-green-50 border-green-200', medium: 'text-yellow-700 bg-yellow-50 border-yellow-200', high: 'text-red-700 bg-red-50 border-red-200' };
              const riskClass = riskColors[impl.genericness_risk] || 'text-zinc-600 bg-zinc-50 border-zinc-200';
            %>
            <div class="inline-flex items-center gap-1 border px-2 py-0.5 rounded-full text-xs font-medium <%= riskClass %>">
              Genericness risk: <%= impl.genericness_risk %>
            </div>
            <% } %>
            <% if (impl.production_notes) { %><div><span class="font-semibold text-zinc-500">Production:</span> <%= impl.production_notes %></div><% } %>
            <% if (impl.suggested_brand_profile_implications?.length) { %>
            <div>
              <span class="font-semibold text-zinc-500">Profile implications:</span>
              <ul class="mt-1 space-y-0.5">
                <% for (const imp of impl.suggested_brand_profile_implications) { %><li>• <%= imp %></li><% } %>
              </ul>
            </div>
            <% } %>
          </div>
          <% } %>

          <!-- Feedback tags for this song -->
          <% const existingFb = s.userFeedback?.songs?.[analysis.filename]; %>
          <% if (!isApplied && !isRejected && s.status !== 'feedback_submitted') { %>
          <div x-data="songFeedback('<%= analysis.filename %>')" class="border-t border-zinc-100 pt-3">
            <div class="text-xs font-semibold text-zinc-500 mb-2">Your feedback tags:</div>
            <div class="flex flex-wrap gap-1.5">
              <% for (const tag of songAnalysisTags) { %>
              <button type="button" @click="toggleTag('<%= tag %>')"
                :class="hasTag('<%= tag %>') ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-zinc-50 text-zinc-700 border-zinc-200 hover:border-zinc-400'"
                class="text-xs px-2.5 py-1 border rounded-full transition font-medium">
                <%= tag %>
              </button>
              <% } %>
            </div>
          </div>
          <% } else if (existingFb) { %>
          <div class="border-t border-zinc-100 pt-3">
            <div class="text-xs font-semibold text-zinc-500 mb-1">Submitted feedback:</div>
            <div class="flex flex-wrap gap-1">
              <% for (const tag of (existingFb.tags || [])) { %>
              <span class="text-xs bg-indigo-100 text-indigo-700 px-2 py-0.5 rounded-full"><%= tag %></span>
              <% } %>
            </div>
          </div>
          <% } %>

        </div>
        <% } %>
      </div>

      <!-- Submit feedback button (analyze mode) -->
      <% if (!isApplied && !isRejected && s.status !== 'feedback_submitted' && s.status !== 'patch_proposed' && s.status !== 'draft_saved') { %>
      <div class="mt-5 border-t border-zinc-100 pt-5">
        <button type="button" @click="submitSongFeedback('<%= s.id %>')"
          class="bg-amber-500 hover:bg-amber-400 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition">
          Submit Feedback →
        </button>
      </div>
      <% } %>
    </div>
    <% } %>

  <% } %>

  <!-- Propose Patch (after feedback) -->
  <% if (s.status === 'feedback_submitted' && !isRejected) { %>
  <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm">
    <h2 class="text-lg font-bold text-zinc-900 mb-3">Step 2 — Propose Profile Patch</h2>
    <p class="text-sm text-zinc-500 mb-4">Generate a proposed patch based on your feedback. You will review it before anything is written.</p>
    <form method="POST" action="/api/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>/propose-patch"
          x-data="{ loading: false }" @submit="loading = true">
      <div x-show="loading" class="mb-4 text-sm text-purple-700 bg-purple-50 border border-purple-200 rounded-lg px-4 py-3 flex items-center gap-3">
        <svg class="animate-spin h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
        </svg>
        Generating patch — Claude is reviewing your feedback and drafting profile changes…
      </div>
      <button type="submit" :disabled="loading"
        :class="loading ? 'opacity-60 cursor-not-allowed bg-purple-600' : 'bg-purple-600 hover:bg-purple-500'"
        class="text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition inline-flex items-center gap-2">
        <svg x-show="loading" class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
        </svg>
        <span x-text="loading ? 'Generating…' : 'Propose Profile Patch'">Propose Profile Patch</span>
      </button>
    </form>
  </div>
  <% } %>

  <!-- Patch Review Panel -->
  <% if (hasPatch && !isRejected) { %>
  <div class="bg-white border border-zinc-200 rounded-2xl p-6 shadow-sm">
    <h2 class="text-lg font-bold text-zinc-900 mb-4">Proposed Profile Patch</h2>

    <!-- Validation result -->
    <% if (s.validationResult) { %>
    <div class="mb-4 <%= validationOk ? 'bg-green-50 border-green-200' : 'bg-red-50 border-red-200' %> border rounded-lg px-4 py-3 text-sm">
      <% if (validationOk) { %>
      <span class="font-semibold text-green-800">✅ Patch is valid</span>
      <% } else { %>
      <span class="font-semibold text-red-800">❌ Validation failed:</span>
      <ul class="mt-1 text-red-700 text-xs space-y-0.5">
        <% for (const err of (s.validationResult.errors || [])) { %><li>• <%= err %></li><% } %>
      </ul>
      <% } %>
      <% if (s.validationResult.warnings?.length) { %>
      <ul class="mt-2 text-amber-700 text-xs space-y-0.5">
        <% for (const w of s.validationResult.warnings) { %><li>⚠️ <%= w %></li><% } %>
      </ul>
      <% } %>
    </div>
    <% } %>

    <!-- Patch tabs -->
    <div x-data="{ tab: 'explanation' }" class="space-y-3">
      <div class="flex gap-2 border-b border-zinc-100 pb-2">
        <button @click="tab='explanation'" :class="tab==='explanation' ? 'border-indigo-600 text-indigo-700 font-semibold' : 'border-transparent text-zinc-500 hover:text-zinc-700'" class="text-sm border-b-2 px-1 py-1 transition">Explanation</button>
        <button @click="tab='json'" :class="tab==='json' ? 'border-indigo-600 text-indigo-700 font-semibold' : 'border-transparent text-zinc-500 hover:text-zinc-700'" class="text-sm border-b-2 px-1 py-1 transition">JSON Patch</button>
        <button @click="tab='diff'" :class="tab==='diff' ? 'border-indigo-600 text-indigo-700 font-semibold' : 'border-transparent text-zinc-500 hover:text-zinc-700'" class="text-sm border-b-2 px-1 py-1 transition">Before / After Diff</button>
      </div>

      <div x-show="tab==='explanation'" class="text-sm text-zinc-700 bg-zinc-50 rounded-xl p-4 leading-relaxed">
        <%= s.patchExplanation || '(no explanation)' %>
      </div>

      <div x-show="tab==='json'" x-cloak>
        <pre class="text-xs bg-zinc-900 text-green-300 rounded-xl p-4 overflow-x-auto whitespace-pre-wrap"><%= JSON.stringify(s.proposedPatch, null, 2) %></pre>
      </div>

      <div x-show="tab==='diff'" x-cloak>
        <pre class="text-xs bg-zinc-900 text-zinc-300 rounded-xl p-4 overflow-x-auto whitespace-pre-wrap font-mono"><% const diffLines = (s.beforeAfterDiff || '(no diff)').split('\n'); for (const line of diffLines) { if (line.startsWith('+')) { %><span class="text-green-400"><%= line %></span>
<% } else if (line.startsWith('-')) { %><span class="text-red-400"><%= line %></span>
<% } else { %><%= line %>
<% } } %></pre>
      </div>
    </div>

    <!-- Action buttons -->
    <% if (!isApplied && validationOk) { %>
    <div class="mt-6 flex flex-wrap gap-3 border-t border-zinc-100 pt-5">
      <form method="POST" action="/api/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>/apply-patch">
        <button type="submit"
          class="bg-green-600 hover:bg-green-500 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition"
          onclick="return confirm('Apply this patch to the brand profile? This writes to the profile file.')">
          ✅ Apply Patch
        </button>
      </form>
      <form method="POST" action="/api/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>/save-draft">
        <button type="submit"
          class="bg-indigo-100 hover:bg-indigo-200 text-indigo-800 text-sm font-semibold px-6 py-2.5 rounded-lg transition">
          💾 Save Draft
        </button>
      </form>
      <form method="POST" action="/api/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>/reject">
        <button type="submit"
          class="bg-zinc-100 hover:bg-zinc-200 text-zinc-700 text-sm font-semibold px-6 py-2.5 rounded-lg transition"
          onclick="return confirm('Reject this patch? No changes will be made.')">
          Reject
        </button>
      </form>
    </div>
    <% } else if (!isApplied && !validationOk) { %>
    <div class="mt-5 flex flex-wrap gap-3 border-t border-zinc-100 pt-5">
      <p class="w-full text-xs text-zinc-500 mb-1">Validation failed. Re-propose asks Claude to try again with stricter artist-name constraints. Reject discards this patch with no changes.</p>
      <form method="POST" action="/api/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>/propose-patch"
            x-data="{ loading: false }" @submit="loading = true">
        <button type="submit" :disabled="loading"
          :class="loading ? 'opacity-60 cursor-not-allowed bg-purple-600' : 'bg-purple-600 hover:bg-purple-500'"
          class="text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition inline-flex items-center gap-2">
          <svg x-show="loading" class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
          <span x-text="loading ? 'Re-proposing…' : '↻ Re-propose Patch'">↻ Re-propose Patch</span>
        </button>
      </form>
      <form method="POST" action="/api/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>/reject">
        <button type="submit"
          class="bg-zinc-100 hover:bg-zinc-200 text-zinc-700 text-sm font-semibold px-6 py-2.5 rounded-lg transition">
          Reject
        </button>
      </form>
    </div>
    <% } %>

    <% if (s.draftPatchPath) { %>
    <div class="mt-3 text-xs text-zinc-400">Draft saved to: <code><%= s.draftPatchPath %></code></div>
    <% } %>
    <% if (isApplied) { %>
    <div class="mt-3 text-xs text-green-600 font-medium">Applied at <%= new Date(s.appliedAt).toLocaleString() %></div>
    <% } %>
  </div>
  <% } %>

  <!-- Abort (any non-terminal state) -->
  <% if (!isApplied && !isRejected) { %>
  <div class="flex justify-end">
    <form method="POST" action="/api/brand-doctor/sessions/<%= encodeURIComponent(s.id) %>/reject">
      <input type="hidden" name="_action" value="abort">
      <button type="submit"
        class="text-xs text-zinc-400 hover:text-red-500 transition"
        onclick="return confirm('Abort this session? No changes will be made.')">
        Abort session
      </button>
    </form>
  </div>
  <% } %>

</div>

<script>
// Alpine.js component for candidate feedback collection
document.addEventListener('alpine:init', () => {

  // Per-candidate tag state
  const candidateState = {};
  const songState = {};

  Alpine.data('candidateFeedback', (candidateId) => ({
    candidateId,
    tags: [],
    init() {
      if (!candidateState[candidateId]) candidateState[candidateId] = { tags: [] };
      this.tags = candidateState[candidateId].tags;
    },
    toggleTag(tag) {
      const idx = this.tags.indexOf(tag);
      if (idx >= 0) this.tags.splice(idx, 1);
      else this.tags.push(tag);
      candidateState[this.candidateId].tags = this.tags;
    },
    hasTag(tag) {
      return this.tags.includes(tag);
    },
  }));

  Alpine.data('songFeedback', (filename) => ({
    filename,
    tags: [],
    init() {
      if (!songState[filename]) songState[filename] = { tags: [] };
      this.tags = songState[filename].tags;
    },
    toggleTag(tag) {
      const idx = this.tags.indexOf(tag);
      if (idx >= 0) this.tags.splice(idx, 1);
      else this.tags.push(tag);
      songState[this.filename].tags = this.tags;
    },
    hasTag(tag) {
      return this.tags.includes(tag);
    },
  }));

  Alpine.data('brandDoctorSession', () => ({
    submitCandidateFeedback(sessionId) {
      const feedback = { candidates: {} };
      for (const [id, state] of Object.entries(candidateState)) {
        feedback.candidates[id] = { tags: state.tags, notes: '' };
      }
      this._postFeedback(sessionId, feedback);
    },
    submitSongFeedback(sessionId) {
      const feedback = { songs: {} };
      for (const [filename, state] of Object.entries(songState)) {
        feedback.songs[filename] = { tags: state.tags, notes: '' };
      }
      this._postFeedback(sessionId, feedback);
    },
    _postFeedback(sessionId, feedback) {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = `/api/brand-doctor/sessions/${sessionId}/feedback`;
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'feedback';
      input.value = JSON.stringify(feedback);
      form.appendChild(input);
      document.body.appendChild(form);
      form.submit();
    },
  }));
});
</script>
