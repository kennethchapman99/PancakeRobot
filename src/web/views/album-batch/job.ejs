<% title = 'Album Generation' %>
<div class="p-8 max-w-5xl">
  <a href="/album-batch" class="text-sm text-zinc-500 hover:text-zinc-700 mb-4 inline-flex items-center gap-1">← All albums</a>
  <h1 class="text-3xl font-black tracking-tight text-zinc-900">Album generation: <%= jobId %></h1>
  <p class="mt-2 text-sm text-zinc-600">Status: <strong><%= job.status %></strong><% if (job.albumId) { %> · <a href="/albums/<%= encodeURIComponent(job.albumId) %>" class="text-indigo-700 hover:underline"><%= job.albumId %></a><% } %></p>
  <% if (job.error) { %>
    <div class="mt-4 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"><%= job.error %></div>
  <% } %>
  <h2 class="mt-6 text-lg font-bold">Progress</h2>
  <ul class="mt-3 space-y-1 rounded-2xl border border-zinc-200 bg-white p-4 text-xs font-mono">
    <% (job.events || []).forEach(event => { %>
      <li><span class="text-zinc-400"><%= event.timestamp %></span> · <%= event.type %><% if (event.line) { %> — <%= event.line %><% } %><% if (event.error) { %> — <span class="text-rose-700">FAIL: <%= event.error %></span><% } %></li>
    <% }) %>
  </ul>
  <% if (album) { %>
    <h2 class="mt-6 text-lg font-bold">Tracks</h2>
    <ul class="mt-3 divide-y divide-zinc-100 rounded-2xl border border-zinc-200 bg-white">
      <% album.songs.forEach(song => { %>
        <li class="flex items-center justify-between px-4 py-3 text-sm">
          <span>#<%= song.track_number || '?' %> · <a href="/songs/<%= encodeURIComponent(song.id) %>" class="text-indigo-700 hover:underline"><%= song.title || song.id %></a> <span class="text-zinc-400">(<%= song.album_role || 'track' %>)</span></span>
          <span class="text-xs text-zinc-500"><%= song.status %></span>
        </li>
      <% }) %>
    </ul>
  <% } %>
</div>
