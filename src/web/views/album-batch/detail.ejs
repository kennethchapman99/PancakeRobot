<% title = album.album_title || album.id %>
<div class="p-8 max-w-5xl">
  <a href="/album-batch" class="text-sm text-zinc-500 hover:text-zinc-700 mb-4 inline-flex items-center gap-1">← All albums</a>
  <h1 class="text-3xl font-black tracking-tight text-zinc-900"><%= album.album_title || album.id %></h1>
  <p class="mt-2 text-sm text-zinc-600"><%= album.album_theme || '(no theme)' %></p>
  <div class="mt-2 text-xs text-zinc-500"><%= album.number_of_songs %> tracks · cost mode <%= album.cost_mode %> · status <%= album.status %></div>
  <% const planTracks = album.shared_orchestration?.plan?.tracks || []; %>
  <% const latestEvent = album.shared_orchestration?.latest_event || null; %>
  <% const latestError = album.shared_orchestration?.latest_error || null; %>
  <% const trackJobsMissing = album.status === 'generating_tracks' && planTracks.length > 0 && songs.length === 0; %>
  <% const incompleteRows = songs.filter(song => song.pipeline_stage !== 'album_track_generated'); %>

  <% if (trackJobsMissing) { %>
    <div class="mt-5 rounded-lg border border-amber-300 bg-amber-50 p-4 text-sm text-amber-900">
      <div class="font-bold">Track jobs missing — repair/resume required</div>
      <div class="mt-1">The album plan has <%= planTracks.length %> tracks, but no child song rows are visible yet.</div>
    </div>
  <% } else if (album.status === 'generating_tracks' && incompleteRows.length > 0) { %>
    <div class="mt-5 rounded-lg border border-sky-200 bg-sky-50 p-4 text-sm text-sky-900">
      <div class="font-bold">Generation can resume</div>
      <div class="mt-1"><%= incompleteRows.length %> track<%= incompleteRows.length === 1 ? '' : 's' %> are missing or incomplete.</div>
    </div>
  <% } %>

  <div class="mt-4 flex gap-2">
    <form method="POST" action="/albums/<%= encodeURIComponent(album.id) %>/repair">
      <button class="rounded-lg bg-white px-4 py-2 text-sm font-semibold text-zinc-900 ring-1 ring-zinc-300 hover:bg-zinc-50" type="submit">
        Repair
      </button>
    </form>
    <form method="POST" action="/albums/<%= encodeURIComponent(album.id) %>/resume">
      <button class="rounded-lg bg-zinc-900 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-700" type="submit">
        Resume
      </button>
    </form>
  </div>

  <section class="mt-6 rounded-xl border border-fuchsia-200 bg-white p-4" x-data="albumDistroKidAutomation('<%= album.id %>')">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <h2 class="text-lg font-bold">DistroKid Automation</h2>
        <p class="mt-1 text-xs text-zinc-500">Album fields are filled once, then track metadata is filled from the generated album songs.</p>
        <div class="mt-3 rounded-lg border border-zinc-200 bg-zinc-50 p-3 text-xs text-zinc-600">
          <div class="font-semibold text-zinc-700">Status</div>
          <div class="mt-1" x-text="message || 'Ready'"></div>
          <template x-if="log.length">
            <div class="mt-2 space-y-1">
              <template x-for="line in log" :key="line"><div x-text="line"></div></template>
            </div>
          </template>
        </div>
      </div>
      <div class="flex min-w-[240px] flex-col gap-2">
        <button type="button" @click="runPreview()" :disabled="saving" class="rounded-xl bg-fuchsia-700 px-4 py-2 text-sm font-semibold text-white hover:bg-fuchsia-600 disabled:opacity-50">Run Automation Preview</button>
        <button type="button" @click="runLiveSubmit()" :disabled="saving" class="rounded-xl bg-zinc-900 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-700 disabled:opacity-50">Run Live Submit</button>
      </div>
    </div>
  </section>

  <% const albumAssetsState = albumAssets || {}; %>
  <section class="mt-6 rounded-xl border border-zinc-200 bg-white p-4">
    <div class="flex items-center justify-between gap-3">
      <div>
        <h2 class="text-lg font-bold">Album Release Assets</h2>
        <p class="mt-1 text-xs text-zinc-500">Upload/select a primary album image, then derive Spotify, YouTube, Instagram, and Facebook assets.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <% if (albumAssetsState.primaryImage) { %><a href="<%= albumAssetsState.previewUrl %>" target="_blank" class="rounded-lg border border-zinc-200 px-3 py-2 text-xs hover:bg-zinc-50">Preview</a><% } %>
        <a href="<%= albumAssetsState.downloadUrl %>" class="rounded-lg border border-zinc-200 px-3 py-2 text-xs hover:bg-zinc-50">Download Pack</a>
      </div>
    </div>
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-zinc-200 p-3">
        <div class="text-xs font-semibold text-zinc-600">Primary image</div>
        <% if (albumAssetsState.primaryImage) { %>
          <img src="<%= albumAssetsState.primaryImage.url %>" alt="Album primary image" class="mt-2 h-44 w-full rounded-lg border border-zinc-200 object-cover">
          <div class="mt-2 break-all text-[11px] text-zinc-500"><%= albumAssetsState.primaryImage.url %></div>
        <% } else { %>
          <div class="mt-2 flex h-44 items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-zinc-50 text-xs text-zinc-400">No primary album image</div>
        <% } %>
        <form class="mt-3" method="POST" enctype="multipart/form-data" action="/api/albums/<%= encodeURIComponent(album.id) %>/primary-image">
          <input type="file" name="base_image" accept=".png,.jpg,.jpeg,.webp" class="block w-full text-xs text-zinc-600 file:mr-2 file:rounded-md file:border file:border-zinc-200 file:bg-zinc-50 file:px-2 file:py-1 file:text-xs">
          <button class="mt-2 rounded-lg bg-zinc-900 px-3 py-2 text-xs font-semibold text-white hover:bg-zinc-700">Upload / Replace Image</button>
        </form>
        <button type="button" onclick="generateAlbumOpenAIImage('<%= album.id %>')" class="mt-2 rounded-lg border border-zinc-200 px-3 py-2 text-xs hover:bg-zinc-50">Generate with OpenAI</button>
      </div>
      <div class="rounded-lg border border-zinc-200 p-3">
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold text-zinc-600">Platform derivatives</div>
          <form method="POST" action="/api/albums/<%= encodeURIComponent(album.id) %>/release-assets/build">
            <button class="rounded-lg bg-emerald-600 px-3 py-2 text-xs font-semibold text-white hover:bg-emerald-500">Rebuild Derivatives</button>
          </form>
        </div>
        <% if (albumAssetsState.derivativesStale && albumAssetsState.primaryImage) { %>
          <div class="mt-2 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-800">Derivatives will refresh automatically on preview or download.</div>
        <% } %>
        <div class="mt-3 space-y-2">
          <% if ((albumAssetsState.assets || []).length) { %>
            <% albumAssetsState.assets.forEach(asset => { %>
              <div class="rounded-lg border border-zinc-100 px-3 py-2 text-xs">
                <div class="font-semibold text-zinc-700"><%= asset.label || asset.name %> <span class="font-normal text-zinc-400"><%= asset.dimensions?.width %>x<%= asset.dimensions?.height %></span></div>
                <div class="mt-1 break-all text-zinc-500"><%= asset.publicUrl || asset.filePath %></div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="rounded-lg border border-dashed border-zinc-300 bg-zinc-50 p-4 text-xs text-zinc-500">No album asset pack generated yet.</div>
          <% } %>
        </div>
      </div>
    </div>
  </section>
  <script>
    function albumDistroKidAutomation(albumId) {
      return {
        saving: false,
        message: '',
        log: [],
        async runPreview() {
          this.saving = true;
          this.message = 'Running album automation preview...';
          const res = await fetch('/api/distrokid/albums/' + encodeURIComponent(albumId) + '/automation-preview', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
          const data = await res.json();
          this.saving = false;
          this.message = data.message || (data.ok ? 'Album automation preview finished.' : 'Album automation preview failed.');
          this.log = (data.result?.log || []).map(item => item.message || item);
        },
        async runLiveSubmit() {
          if (!confirm('Run the live DistroKid submit for this album?')) return;
          this.saving = true;
          this.message = 'Running album live submit...';
          const res = await fetch('/api/distrokid/albums/' + encodeURIComponent(albumId) + '/live-submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ confirm: true })
          });
          const data = await res.json();
          this.saving = false;
          this.message = data.message || (data.ok ? 'Album live submit finished.' : 'Album live submit failed.');
          this.log = (data.result?.log || []).map(item => item.message || item);
        }
      };
    }

    async function generateAlbumOpenAIImage(albumId) {
      const prompt = window.prompt('Describe the album cover art style or scene. Text will not be rendered in the image.', '');
      if (prompt === null) return;
      const res = await fetch('/api/albums/' + encodeURIComponent(albumId) + '/release-assets/generate-image', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ prompt })
      });
      const data = await res.json();
      if (!res.ok || data.ok === false) {
        window.alert(data.error || 'OpenAI image generation failed.');
        return;
      }
      window.location.reload();
    }
  </script>

  <% if (latestEvent || latestError) { %>
    <div class="mt-4 rounded-lg border border-zinc-200 bg-white p-4 text-sm">
      <div class="text-xs uppercase text-zinc-500">Latest job event</div>
      <% if (latestEvent) { %>
        <div class="mt-1 font-semibold"><%= latestEvent.message || latestEvent.type %></div>
        <div class="text-xs text-zinc-500"><%= formatDateTime(latestEvent.timestamp) %></div>
      <% } %>
      <% if (latestError) { %>
        <div class="mt-2 text-rose-700"><%= latestError %></div>
      <% } %>
    </div>
  <% } %>

  <% const fin = album.finance_summary || {}; %>
  <% const budget = fin.cost_mode_budget || {}; %>
  <h2 class="mt-6 text-lg font-bold">Finance Manager</h2>
  <div class="mt-3 grid gap-3 lg:grid-cols-3">
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Total Album Cost</div>
      <div class="text-2xl font-black">$<%= (fin.total_album_cost_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Average Cost Per Song</div>
      <div class="text-2xl font-black">$<%= (fin.average_cost_per_song_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Shared Thinking Cost</div>
      <div class="text-2xl font-black">$<%= (fin.shared_thinking_cost_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Allocated Shared / Song</div>
      <div class="text-2xl font-black">$<%= (fin.allocated_shared_cost_per_song_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Cached Savings</div>
      <div class="text-2xl font-black">$<%= (fin.cached_savings_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border <%= budget.over_budget ? 'border-rose-300 bg-rose-50' : 'border-zinc-200 bg-white' %> p-4">
      <div class="text-xs uppercase text-zinc-500">Cost Mode Budget</div>
      <div class="text-sm">per-song cap: $<%= budget.per_song_usd == null ? '—' : Number(budget.per_song_usd).toFixed(4) %></div>
      <div class="text-sm">album cap: $<%= budget.total_usd == null ? '—' : Number(budget.total_usd).toFixed(4) %></div>
      <% if (budget.over_budget) { %><div class="text-xs font-bold text-rose-700 mt-1">OVER BUDGET</div><% } %>
    </div>
  </div>

  <h2 class="mt-6 text-lg font-bold">Per-track breakdown</h2>
  <% if ((fin.per_track || []).length === 0) { %>
    <div class="mt-3 rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-sm text-zinc-600">
      <% if (planTracks.length > 0) { %>
        Planned track rows are available below. Run repair to create the missing child song jobs and allocate shared cost per track.
      <% } else { %>
        No per-track costs are available yet. Shared album orchestration cost is shown above.
      <% } %>
    </div>
  <% } %>
  <table class="mt-3 w-full text-sm">
    <thead class="text-xs text-zinc-500 uppercase">
      <tr><th class="text-left">Track</th><th class="text-left">Song</th><th class="text-left">Stage</th><th class="text-right">Track Cost</th><th class="text-right">+ Shared</th><th class="text-right">Total</th></tr>
    </thead>
    <tbody>
      <% if ((fin.per_track || []).length === 0 && planTracks.length > 0) { %>
        <% planTracks.forEach((track) => { %>
          <tr class="border-t border-zinc-100">
            <td class="py-2">#<%= track.track_number %></td>
            <td><%= track.title %></td>
            <td class="text-amber-700">track job missing</td>
            <td class="text-right">$0.0000</td>
            <td class="text-right">$0.0000</td>
            <td class="text-right">$0.0000</td>
          </tr>
        <% }) %>
      <% } %>
      <% (fin.per_track || []).forEach((row, idx) => {
         const song = songs.find(s => s.id === row.song_id) || {};
      %>
        <tr class="border-t border-zinc-100">
          <td class="py-2">#<%= song.track_number || (idx + 1) %></td>
          <td><a class="text-indigo-700 hover:underline" href="/songs/<%= encodeURIComponent(row.song_id) %>"><%= song.title || row.song_id %></a></td>
          <td class="text-zinc-500"><%= song.pipeline_stage || 'pending' %></td>
          <td class="text-right">$<%= (row.track_cost_usd || 0).toFixed(4) %></td>
          <td class="text-right">$<%= (row.allocated_shared_cost_usd || 0).toFixed(4) %></td>
          <td class="text-right">$<%= (row.total_attributed_cost_usd || 0).toFixed(4) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
