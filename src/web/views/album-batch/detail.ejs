<% title = album.album_title || album.id %>
<div class="p-8 max-w-5xl">
  <a href="/album-batch" class="text-sm text-zinc-500 hover:text-zinc-700 mb-4 inline-flex items-center gap-1">← All albums</a>
  <h1 class="text-3xl font-black tracking-tight text-zinc-900"><%= album.album_title || album.id %></h1>
  <p class="mt-2 text-sm text-zinc-600"><%= album.album_theme || '(no theme)' %></p>
  <div class="mt-2 text-xs text-zinc-500"><%= album.number_of_songs %> tracks · cost mode <%= album.cost_mode %> · status <%= album.status %></div>

  <% const fin = album.finance_summary || {}; %>
  <% const budget = fin.cost_mode_budget || {}; %>
  <h2 class="mt-6 text-lg font-bold">Finance Manager</h2>
  <div class="mt-3 grid gap-3 lg:grid-cols-3">
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Total Album Cost</div>
      <div class="text-2xl font-black">$<%= (fin.total_album_cost_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Average Cost Per Song</div>
      <div class="text-2xl font-black">$<%= (fin.average_cost_per_song_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Shared Thinking Cost</div>
      <div class="text-2xl font-black">$<%= (fin.shared_thinking_cost_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Allocated Shared / Song</div>
      <div class="text-2xl font-black">$<%= (fin.allocated_shared_cost_per_song_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border border-zinc-200 bg-white p-4">
      <div class="text-xs uppercase text-zinc-500">Cached Savings</div>
      <div class="text-2xl font-black">$<%= (fin.cached_savings_usd || 0).toFixed(4) %></div>
    </div>
    <div class="rounded-2xl border <%= budget.over_budget ? 'border-rose-300 bg-rose-50' : 'border-zinc-200 bg-white' %> p-4">
      <div class="text-xs uppercase text-zinc-500">Cost Mode Budget</div>
      <div class="text-sm">per-song cap: $<%= budget.per_song_usd == null ? '—' : Number(budget.per_song_usd).toFixed(4) %></div>
      <div class="text-sm">album cap: $<%= budget.total_usd == null ? '—' : Number(budget.total_usd).toFixed(4) %></div>
      <% if (budget.over_budget) { %><div class="text-xs font-bold text-rose-700 mt-1">OVER BUDGET</div><% } %>
    </div>
  </div>

  <h2 class="mt-6 text-lg font-bold">Per-track breakdown</h2>
  <table class="mt-3 w-full text-sm">
    <thead class="text-xs text-zinc-500 uppercase">
      <tr><th class="text-left">Track</th><th class="text-left">Song</th><th class="text-right">Track Cost</th><th class="text-right">+ Shared</th><th class="text-right">Total</th></tr>
    </thead>
    <tbody>
      <% (fin.per_track || []).forEach((row, idx) => {
        const song = songs.find(s => s.id === row.song_id) || {};
      %>
        <tr class="border-t border-zinc-100">
          <td class="py-2">#<%= song.track_number || (idx + 1) %></td>
          <td><a class="text-indigo-700 hover:underline" href="/songs/<%= encodeURIComponent(row.song_id) %>"><%= song.title || row.song_id %></a></td>
          <td class="text-right">$<%= (row.track_cost_usd || 0).toFixed(4) %></td>
          <td class="text-right">$<%= (row.allocated_shared_cost_usd || 0).toFixed(4) %></td>
          <td class="text-right">$<%= (row.total_attributed_cost_usd || 0).toFixed(4) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
