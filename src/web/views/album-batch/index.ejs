<% title = 'GENERATE ALBUM' %>

<div class="p-8 max-w-5xl">
  <a href="/" class="text-sm text-zinc-500 hover:text-zinc-700 mb-6 inline-flex items-center gap-1">← Dashboard</a>

  <div class="rounded-[32px] border border-indigo-200 bg-gradient-to-br from-indigo-50 via-white to-amber-50 p-8 shadow-sm">
    <div class="inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white px-3 py-1 text-[11px] font-bold uppercase tracking-[0.24em] text-indigo-700">GENERATE ALBUM</div>
    <h1 class="mt-4 text-4xl font-black tracking-tight text-zinc-900">One orchestration pass. Many tracks.</h1>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-600">
      Generates an entire album/EP/song batch from a single brand profile plus a song count. Shared "thinking" runs once; each track inherits the album plan, so per-song non-music cost is materially lower than single-song generation.
    </p>
  </div>

  <% if (error) { %>
    <div class="mt-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"><%= error %></div>
  <% } %>

  <form method="POST" action="/album-batch" class="mt-8 rounded-[28px] border border-zinc-200 bg-white p-8 shadow-sm">
    <div class="grid gap-6 lg:grid-cols-2">
      <div>
        <label class="block text-sm font-bold text-zinc-900">Brand Profile</label>
        <select name="brandProfileId" required class="mt-2 w-full rounded-2xl border border-zinc-200 px-4 py-3 text-sm">
          <% profiles.forEach(profile => { %>
            <option value="<%= profile.id %>" <%= profile.id === activeBrandId ? 'selected' : '' %>><%= profile.name || profile.id %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-bold text-zinc-900">Number of Songs</label>
        <input type="number" name="numberOfSongs" min="1" max="20" required value="6" class="mt-2 w-full rounded-2xl border border-zinc-200 px-4 py-3 text-sm">
      </div>
      <div>
        <label class="block text-sm font-bold text-zinc-900">Cost Mode</label>
        <select name="costMode" class="mt-2 w-full rounded-2xl border border-zinc-200 px-4 py-3 text-sm">
          <% costModes.forEach(mode => { %>
            <option value="<%= mode %>" <%= mode === 'album_batch' ? 'selected' : '' %>><%= mode %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-bold text-zinc-900">Album Theme <span class="text-zinc-400 font-normal">(optional)</span></label>
        <input type="text" name="albumTheme" placeholder="leave blank to infer from brand profile" class="mt-2 w-full rounded-2xl border border-zinc-200 px-4 py-3 text-sm">
      </div>
      <div>
        <label class="block text-sm font-bold text-zinc-900">Release Intent <span class="text-zinc-400 font-normal">(optional)</span></label>
        <input type="text" name="releaseIntent" class="mt-2 w-full rounded-2xl border border-zinc-200 px-4 py-3 text-sm">
      </div>
      <div class="lg:col-span-2">
        <label class="block text-sm font-bold text-zinc-900">Notes <span class="text-zinc-400 font-normal">(optional)</span></label>
        <textarea name="notes" rows="3" class="mt-2 w-full rounded-2xl border border-zinc-200 px-4 py-3 text-sm"></textarea>
      </div>
    </div>
    <div class="mt-6 flex justify-end">
      <button type="submit" class="rounded-2xl bg-indigo-600 px-6 py-3 text-sm font-bold text-white hover:bg-indigo-500">Generate Album</button>
    </div>
  </form>

  <% if (albums && albums.length > 0) { %>
    <h2 class="mt-10 text-xl font-bold text-zinc-900">Recent albums</h2>
    <ul class="mt-3 divide-y divide-zinc-100 rounded-2xl border border-zinc-200 bg-white">
      <% albums.forEach(album => { %>
        <li class="flex items-center justify-between px-5 py-4">
          <div>
            <a href="/albums/<%= encodeURIComponent(album.id) %>" class="font-semibold text-indigo-700 hover:underline"><%= album.album_title || album.id %></a>
            <div class="text-xs text-zinc-500"><%= album.number_of_songs %> tracks · cost mode <%= album.cost_mode %> · <%= album.status %></div>
          </div>
          <div class="text-right text-xs text-zinc-500">
            <% if (album.finance) { %>
              total $<%= (album.finance.total_album_cost_usd || 0).toFixed(4) %> · avg/song $<%= (album.finance.average_cost_per_song_usd || 0).toFixed(4) %>
            <% } else { %>—<% } %>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</div>
