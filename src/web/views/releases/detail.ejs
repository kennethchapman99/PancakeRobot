<% title = cockpit.title + ' Release Cockpit' %>
<%
  const playBtn = (url) => url
    ? `<button data-pr-play data-audio-url="${url}" title="Play master" class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-violet-100 text-violet-600 hover:bg-violet-200 transition flex-shrink-0"><svg data-play-icon class="w-2.5 h-2.5" viewBox="0 0 10 10" fill="currentColor"><polygon points="2,1 9,5 2,9"/></svg><svg data-pause-icon class="w-2.5 h-2.5 hidden" viewBox="0 0 10 10" fill="currentColor"><rect x="1" y="1" width="3" height="8"/><rect x="6" y="1" width="3" height="8"/></svg></button>`
    : '';
%>
<%
  const activeFocus = ['metadata', 'audio'].includes(String(focus || '').toLowerCase()) ? String(focus).toLowerCase() : 'all';
  const statusClass = (status) => ({
    complete: 'badge-green',
    blocked: 'badge-red',
    ready: 'badge-blue',
    running: 'badge-blue',
    not_started: 'badge-gray',
    skipped: 'badge-gray',
    cancelled: 'badge-gray',
    failed: 'badge-red',
  }[status] || 'badge-gray');
  const outcomeClass = (outcome) => ({
    passed: 'badge-green',
    failed: 'badge-red',
    incomplete: 'badge-yellow',
    needs_review: 'badge-blue',
  }[outcome] || 'badge-gray');
  const lifecycleClass = (status) => ({
    draft: 'badge-gray',
    editing: 'badge-yellow',
    submitted_to_distrokid: 'badge-blue',
    hyperfollow_ready: 'badge-blue',
    pre_release_marketing_ready: 'badge-green',
    archived: 'badge-gray',
    post_release_complete: 'badge-green',
  }[status] || 'badge-gray');
  const buttonClass = (label, enabled) => {
    if (!enabled) return 'border-zinc-200 bg-zinc-100 text-zinc-500';
    if (/stop|cancel/i.test(label)) return 'border-rose-300 bg-rose-500 text-white';
    if (/skip|remove|delete/i.test(label)) return 'border-rose-300 bg-rose-500 text-white';
    if (/approve|paste|save/i.test(label)) return 'border-amber-300 bg-amber-500 text-white';
    if (/build outreach|send outreach/i.test(label)) return 'border-emerald-300 bg-emerald-600 text-white';
    return 'border-sky-300 bg-sky-600 text-white';
  };
  const feedbackClass = (level) => ({
    error: 'border-rose-200 bg-rose-50 text-rose-900',
    warning: 'border-amber-200 bg-amber-50 text-amber-900',
    success: 'border-emerald-200 bg-emerald-50 text-emerald-900',
    info: 'border-sky-200 bg-sky-50 text-sky-900',
  }[level] || 'border-sky-200 bg-sky-50 text-sky-900');
  const manualHyperfollowFormAction = `/releases/${encodeURIComponent(cockpit.type)}/${encodeURIComponent(cockpit.id)}/actions/hyperfollow`;
  const runHistory = cockpit.runHistory || [];
  const commandActions = cockpit.commandCenter.primaryActions.filter(action => !['preview', 'live_submit', 'browsy_dry_run'].includes(action.key));
%>

<div class="p-8 max-w-7xl">
  <a href="/releases" class="mb-4 inline-flex text-sm text-zinc-500 hover:text-zinc-700">← Release Cockpit</a>

  <% if (actionFeedback) { %>
    <section class="mb-6 rounded-2xl border p-4 <%= feedbackClass(actionFeedback.level) %>">
      <div class="text-sm font-semibold"><%= actionFeedback.message %></div>
    </section>
  <% } %>

  <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="flex items-start gap-4">
        <div class="relative h-16 w-16 shrink-0 overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-50 shadow-sm">
          <% if (cockpit.headerArtwork?.url) { %>
            <img
              src="<%= cockpit.headerArtwork.url %>"
              alt="<%= cockpit.headerArtwork.alt || cockpit.title %>"
              data-release-header-art
              data-release-header-art-source="<%= cockpit.headerArtwork.source || '' %>"
              onerror="this.classList.add('hidden'); this.nextElementSibling.classList.remove('hidden');"
              class="h-full w-full object-cover"
            >
            <div data-release-header-placeholder class="hidden h-full w-full items-center justify-center bg-zinc-100 text-[10px] font-semibold uppercase tracking-[0.18em] text-zinc-400">No Art</div>
          <% } else { %>
            <div data-release-header-placeholder class="flex h-full w-full items-center justify-center bg-zinc-100 text-[10px] font-semibold uppercase tracking-[0.18em] text-zinc-400">No Art</div>
          <% } %>
        </div>
        <div>
        <div class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500"><%= cockpit.type === 'album' ? 'Album Release' : 'Single Release' %></div>
        <h1 class="mt-1 text-3xl font-black tracking-tight text-zinc-900"><%= cockpit.title %></h1>
        <div class="mt-3 flex flex-wrap items-center gap-2 text-sm text-zinc-600">
          <span>ID <span class="font-semibold text-zinc-900"><%= cockpit.id %></span></span>
          <span>·</span>
          <span><%= cockpit.tracks.length %> track<%= cockpit.tracks.length === 1 ? '' : 's' %></span>
          <span>·</span>
          <span>Release date <span class="font-semibold text-zinc-900"><%= cockpit.releaseDate || '—' %></span></span>
          <span>·</span>
          <span>Brand profile <span class="font-semibold text-zinc-900"><%= cockpit.brandProfileId || '—' %></span></span>
        </div>
        <form method="POST" action="/releases/<%= encodeURIComponent(cockpit.type) %>/<%= encodeURIComponent(cockpit.id) %>/actions/release-date" class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-end">
          <label class="text-sm font-semibold text-zinc-700">
            <span class="block text-xs uppercase tracking-[0.18em] text-zinc-500">Release date</span>
            <input type="date" name="release_date" value="<%= cockpit.releaseDate || '' %>" data-release-date-input class="mt-1 w-full rounded-xl border border-zinc-200 px-3 py-2 text-sm text-zinc-900">
          </label>
          <button data-submit-label="Saving…" data-save-release-date class="rounded-xl border border-amber-300 bg-amber-500 px-4 py-2 text-sm font-bold text-white shadow-sm">Save release date</button>
        </form>
        </div>
      </div>
      <div>
        <span class="<%= lifecycleClass(cockpit.lifecycle.current) %>"><%= cockpit.lifecycle.current.replace(/_/g, ' ') %></span>
      </div>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5">
    <div class="mb-4 flex items-center justify-between gap-3">
      <h2 class="text-lg font-bold text-zinc-900">Magic Release command bar</h2>
      <div class="text-xs text-zinc-500">Disabled actions show the exact blocking reason.</div>
    </div>
    <div class="grid gap-3 lg:grid-cols-5">
      <% commandActions.forEach(action => { %>
        <form data-action-form method="POST" action="<%= action.url %>" data-confirm="<%= action.confirmation || '' %>">
          <% if (action.key === 'live_submit') { %><input type="hidden" name="confirm" value="true"><% } %>
          <button data-submit-label="Running…" <%= action.enabled ? '' : 'disabled' %> class="flex h-full w-full flex-col justify-between rounded-2xl border px-4 py-4 text-left text-sm font-bold shadow-sm transition hover:brightness-95 disabled:cursor-not-allowed disabled:opacity-100 <%= buttonClass(action.label, action.enabled) %>">
            <span><%= action.label %></span>
            <% if (action.disabledReason) { %><span class="mt-2 text-xs font-medium opacity-90"><%= action.disabledReason %></span><% } %>
          </button>
        </form>
      <% }) %>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5">
    <div class="mb-4 flex items-center justify-between gap-3">
      <div>
        <h2 class="text-lg font-bold text-zinc-900">Release Readiness</h2>
        <p class="mt-1 text-sm text-zinc-600">This list is the source of truth for the release. Every row shows status, blocking reason or last result, and the next direct action.</p>
      </div>
      <div class="text-xs text-zinc-500">Statuses: complete, blocked, ready, running, not started, skipped, failed. Process completion is shown separately from preview outcome.</div>
    </div>

    <div class="space-y-3">
      <% cockpit.stages.forEach((stage, index) => { %>
        <div class="rounded-2xl border border-zinc-200 bg-zinc-50/60 p-4">
          <div class="grid gap-4 lg:grid-cols-[64px_minmax(0,1fr)_160px]">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-sm font-black text-zinc-500 ring-1 ring-zinc-200"><%= index + 1 %></div>
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <div class="font-semibold text-zinc-900"><%= stage.label %></div>
                <span class="rounded-full border border-zinc-200 bg-white px-2 py-0.5 text-[11px] font-semibold text-zinc-500"><%= stage.owner %></span>
                <% if (stage.outcome) { %>
                  <span class="<%= outcomeClass(stage.outcome) %>"><%= stage.outcomeLabel %></span>
                <% } %>
              </div>
              <div class="mt-2 text-sm text-zinc-700"><%= stage.detail %></div>

              <% if ((stage.validationIssues || []).length) { %>
                <div class="mt-3 rounded-xl border border-zinc-200 bg-white px-3 py-3 text-xs text-zinc-600">
                  <div class="font-semibold text-zinc-900">Exact missing inputs</div>
                  <ul class="mt-2 space-y-1">
                    <% stage.validationIssues.forEach(issue => { %>
                      <li>• <%= issue %></li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>

              <% if (stage.latestRun) { %>
                <div class="mt-3 rounded-xl border border-zinc-200 bg-white px-3 py-3 text-xs text-zinc-600">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="font-semibold text-zinc-900">Run <%= stage.latestRun.runId %></span>
                    <span>·</span>
                    <span><%= stage.latestRun.processStatusLabel || stage.latestRun.displayStatus || stage.latestRun.status %></span>
                    <span>·</span>
                    <span><%= formatDateTime(stage.latestRun.latestAt) %></span>
                    <% if (stage.latestRun.command) { %><span>·</span><span class="break-all"><%= stage.latestRun.command %></span><% } %>
                  </div>
                  <% if (stage.latestRun.error) { %><div class="mt-2 text-rose-700"><%= stage.latestRun.error %></div><% } %>
                  <% if (stage.diagnostics || stage.latestRun.logUrl) { %>
                    <div class="mt-3 rounded-xl border border-zinc-200 bg-zinc-50 px-3 py-3">
                      <div class="flex flex-wrap items-center justify-between gap-2">
                        <div class="font-semibold text-zinc-900">Open diagnostics / log output</div>
                        <% if (stage.latestRun.logUrl) { %><a href="<%= stage.latestRun.logUrl %>" target="_blank" class="font-semibold text-sky-700 hover:underline">Open log output</a><% } %>
                      </div>
                      <% if (stage.diagnostics) { %>
                        <div class="mt-2 flex flex-wrap gap-3 text-zinc-700">
                          <span><strong><%= stage.diagnostics.filledCount %></strong> filled</span>
                          <span><strong><%= stage.diagnostics.skippedCount %></strong> skipped</span>
                          <span><strong><%= stage.diagnostics.errorCount %></strong> errors</span>
                        </div>
                        <% if (stage.diagnostics.trackCountValidation) { %>
                          <div class="mt-2 flex flex-wrap gap-3 text-zinc-700">
                            <span><strong><%= stage.diagnostics.trackCountValidation.requestedTrackCount %></strong> requested tracks</span>
                            <span><strong><%= stage.diagnostics.trackCountValidation.selectedOption || 'n/a' %></strong> selected</span>
                            <span><strong><%= stage.diagnostics.trackCountValidation.renderedTrackCount %></strong> rendered tracks</span>
                          </div>
                        <% } %>
                        <% if ((stage.diagnostics.missingGroups || []).length) { %>
                          <div class="mt-3 space-y-2">
                            <% stage.diagnostics.missingGroups.forEach(group => { %>
                              <div>
                                <div class="font-semibold text-zinc-900"><%= group.label %></div>
                                <ul class="mt-1 space-y-1">
                                  <% group.items.forEach(item => { %>
                                    <li>• <%= item %></li>
                                  <% }) %>
                                </ul>
                              </div>
                            <% }) %>
                          </div>
                        <% } %>
                        <% if ((stage.diagnostics.artifacts || []).length) { %>
                          <div class="mt-3 flex flex-wrap gap-3">
                            <% stage.diagnostics.artifacts.forEach(artifact => { %>
                              <a href="<%= artifact.url %>" target="_blank" class="font-semibold text-sky-700 hover:underline"><%= artifact.label %></a>
                            <% }) %>
                          </div>
                        <% } %>
                      <% } %>
                    </div>
                  <% } %>
                </div>
              <% } %>

              <% if (stage.key === 'distrokid_preview') { %>
                <% const wf = cockpit.distrokidBrowsyWorkflow; %>
                <% const wfBase = `/releases/${encodeURIComponent(cockpit.type)}/${encodeURIComponent(cockpit.id)}/magic-release`; %>
                <% const wfBadge = (label) => ({ ready: 'bg-emerald-100 text-emerald-700', 'scaffold-only': 'bg-amber-100 text-amber-700', incomplete: 'bg-amber-100 text-amber-700', failed: 'bg-rose-100 text-rose-700', unavailable: 'bg-rose-100 text-rose-700', missing: 'bg-zinc-100 text-zinc-600' }[label] || 'bg-zinc-100 text-zinc-600'); %>
                <% const wfNote = wf.ready ? 'border-emerald-200 bg-emerald-50 text-emerald-900' : ((wf.readinessLabel === 'failed' || wf.readinessLabel === 'unavailable') ? 'border-rose-200 bg-rose-50 text-rose-900' : 'border-amber-200 bg-amber-50 text-amber-900'); %>

                <div data-distrokid-browsy-panel class="mt-3 rounded-2xl border-2 border-sky-300 bg-sky-50/40 p-4">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="text-[11px] font-bold uppercase tracking-[0.18em] text-sky-700">Primary</span>
                    <h3 class="text-base font-bold text-zinc-900">Browsy automation</h3>
                    <span class="text-xs font-semibold text-zinc-500">(<%= wf.workflowName %>)</span>
                    <span data-distrokid-browsy-readiness class="rounded-full px-2 py-0.5 text-[11px] font-semibold <%= wfBadge(wf.readinessLabel) %>"><%= wf.readinessLabel %></span>
                    <% if (wf.recordingStatus) { %><span class="rounded-full border border-zinc-200 bg-white px-2 py-0.5 text-[11px] font-semibold text-zinc-500">recording: <%= wf.recordingStatus %></span><% } %>
                  </div>
                  <div class="mt-1 text-xs text-zinc-500"><%= wf.configured ? `Browsy ${wf.baseUrl}` : 'Browsy unavailable or not configured' %></div>

                  <div class="mt-2 rounded-xl border px-3 py-2 text-sm <%= wfNote %>">
                    <div class="font-semibold"><%= wf.nextStep.headline %></div>
                    <% if (wf.nextStep.detail) { %><div class="mt-1 text-xs"><%= wf.nextStep.detail %></div><% } %>
                  </div>

                  <% if (wf.lastError) { %><div class="mt-2 text-xs text-rose-700"><%= wf.lastError %></div><% } %>

                  <div data-distrokid-payload-readiness class="mt-2 rounded-xl border border-zinc-200 bg-white px-3 py-2 text-xs text-zinc-600">
                    <div class="font-semibold text-zinc-700">Release payload readiness</div>
                    <div class="mt-1 flex flex-wrap gap-3">
                      <% wf.payloadReadiness.indicators.forEach(ind => { %>
                        <span class="<%= ind.ok ? 'text-emerald-700' : 'text-rose-700' %>"><%= ind.ok ? '✓' : '✗' %> <%= ind.label %></span>
                      <% }) %>
                    </div>
                    <div class="mt-1 text-zinc-500"><%= wf.payloadReadiness.summary %></div>
                    <% if (wf.sourcePayloadValidation && !wf.sourcePayloadValidation.ok) { %>
                      <div class="mt-2 rounded-lg border border-rose-200 bg-rose-50 p-2 text-rose-800">
                        <div class="font-semibold">Source payload blocked</div>
                        <div class="mt-1"><%= wf.sourcePayloadValidation.errors.join(' ') %></div>
                      </div>
                    <% } %>
                  </div>

                  <div class="mt-3 flex flex-wrap gap-2">
                    <% if (wf.wizardUrl) { %>
                      <a href="<%= wf.wizardUrl %>" target="_blank" class="rounded-xl border border-zinc-300 bg-white px-3 py-2 text-xs font-bold text-zinc-900">Open Existing Recording</a>
                    <% } %>
                    <form data-action-form method="POST" action="<%= wfBase %>/record-automation">
                      <input type="hidden" name="task_key" value="<%= wf.taskKey %>">
                      <% const sourcePayloadOk = !wf.sourcePayloadValidation || wf.sourcePayloadValidation.ok; %>
                      <button data-submit-label="Opening…" <%= sourcePayloadOk ? '' : 'disabled' %> class="rounded-xl border px-3 py-2 text-xs font-bold <%= sourcePayloadOk ? 'border-sky-300 bg-sky-600 text-white' : 'border-zinc-200 bg-zinc-100 text-zinc-400 cursor-not-allowed' %>">Record Automation</button>
                    </form>
                  </div>
                  <% if (!wf.ready) { %>
                    <div class="mt-2 text-xs text-zinc-500">No live automation can run until Browsy has a reusable, verified workflow contract. Record the workflow first.</div>
                  <% } %>
                </div>

                <% const upload = cockpit.uploadManifest; %>
                <% if (upload && (upload.cover || (upload.tracks && upload.tracks.length))) { %>
                  <div id="upload-files" class="mt-3 rounded-2xl border border-zinc-200 bg-white p-4">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                      <div>
                        <h3 class="text-base font-bold text-zinc-900">Files to upload during recording</h3>
                        <div class="mt-1 text-xs text-zinc-500">These are the exact files Browsy re-uploads on replay. Prepare the folder, then in DistroKid's file picker select the audio files in order.</div>
                      </div>
                      <form data-action-form method="POST" action="/releases/<%= encodeURIComponent(cockpit.type) %>/<%= encodeURIComponent(cockpit.id) %>/upload-bundle/open">
                        <button data-submit-label="Opening…" class="rounded-xl border border-sky-300 bg-sky-600 px-3 py-2 text-xs font-bold text-white">Prepare & open upload folder</button>
                      </form>
                    </div>
                    <div class="mt-3 overflow-hidden rounded-xl border border-zinc-200">
                      <table class="w-full text-left text-xs">
                        <thead class="bg-zinc-50 text-[11px] uppercase tracking-[0.12em] text-zinc-500">
                          <tr><th class="px-3 py-2 font-semibold">#</th><th class="px-3 py-2 font-semibold">File</th><th class="px-3 py-2 font-semibold">Source path</th></tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-100">
                          <% if (upload.cover) { %>
                            <tr class="<%= upload.cover.exists ? '' : 'bg-rose-50' %>">
                              <td class="px-3 py-2 font-semibold text-zinc-500">art</td>
                              <td class="px-3 py-2 font-semibold text-zinc-900"><%= upload.cover.bundleName %></td>
                              <td class="px-3 py-2 font-mono text-[11px] text-zinc-500">
                                <span class="inline-flex items-center gap-1.5">
                                  <button type="button" data-copy-path="<%= upload.cover.sourcePath %>" title="Copy path" aria-label="Copy path" class="copy-path-btn shrink-0 rounded-md border border-zinc-200 bg-white p-1 text-zinc-400 hover:bg-zinc-50 hover:text-zinc-700">
                                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                  </button>
                                  <span><%= upload.cover.sourcePath %></span>
                                </span>
                                <% if (!upload.cover.exists) { %> <span class="font-sans font-bold text-rose-600">(missing)</span><% } %>
                              </td>
                            </tr>
                          <% } %>
                          <% upload.tracks.forEach(track => { %>
                            <tr class="<%= track.exists ? '' : 'bg-rose-50' %>">
                              <td class="px-3 py-2 font-semibold text-zinc-500"><%= String(track.number).padStart(2, '0') %></td>
                              <td class="px-3 py-2 font-semibold text-zinc-900"><%= track.bundleName %></td>
                              <td class="px-3 py-2 font-mono text-[11px] text-zinc-500">
                                <span class="inline-flex items-center gap-1.5">
                                  <button type="button" data-copy-path="<%= track.sourcePath %>" title="Copy path" aria-label="Copy path" class="copy-path-btn shrink-0 rounded-md border border-zinc-200 bg-white p-1 text-zinc-400 hover:bg-zinc-50 hover:text-zinc-700">
                                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                  </button>
                                  <span><%= track.sourcePath %></span>
                                </span>
                                <% if (!track.exists) { %> <span class="font-sans font-bold text-rose-600">(missing)</span><% } %>
                              </td>
                            </tr>
                          <% }) %>
                        </tbody>
                      </table>
                    </div>
                    <div class="mt-2 text-[11px] text-zinc-500">Tip: the numbered filenames make picking files in order easy and let DistroKid pre-fill titles while you record. For reuse, still type each track's real title/metadata during recording so Browsy binds it to the payload — on replay the files come from the raw package paths, not these names.</div>
                  </div>
                <% } %>
              <% } %>

              <% if (stage.key === 'hyperfollow') { %>
                <form data-action-form method="POST" action="<%= manualHyperfollowFormAction %>" class="mt-3 rounded-xl border border-zinc-200 bg-white p-3">
                  <label class="text-xs font-semibold text-zinc-600" for="hyperfollow-url">Paste / save HyperFollow URL</label>
                  <div class="mt-2 flex flex-col gap-2 sm:flex-row">
                    <input id="hyperfollow-url" name="hyperfollow_url" value="<%= cockpit.hyperfollow?.url || '' %>" placeholder="https://distrokid.com/hyperfollow/..." class="w-full rounded-xl border border-zinc-200 px-3 py-2 text-sm">
                    <button data-submit-label="Saving…" <%= stage.actions.some(action => action.label === 'Save HyperFollow' && action.enabled) || cockpit.hyperfollow?.url ? '' : 'disabled' %> class="rounded-xl border px-4 py-2 text-sm font-bold <%= buttonClass('Save HyperFollow', stage.actions.some(action => action.label === 'Save HyperFollow' && action.enabled) || Boolean(cockpit.hyperfollow?.url)) %>">Save HyperFollow</button>
                  </div>
                  <% if (!stage.actions.some(action => action.label === 'Save HyperFollow' && action.enabled) && !cockpit.hyperfollow?.url) { %>
                    <div class="mt-2 text-xs text-amber-700">Available after live submit.</div>
                  <% } %>
                </form>
              <% } %>

              <% if (stage.key !== 'distrokid_preview' && (stage.actions || []).length) { %>
                <div class="mt-3 flex flex-wrap gap-2">
                  <% stage.actions.forEach(action => { %>
                    <% if (stage.key === 'hyperfollow' && action.label === 'Save HyperFollow') { return; } %>
                    <% if (stage.key === 'hyperfollow' && action.label === 'Paste HyperFollow URL') { return; } %>
                    <% if (action.method === 'GET') { %>
                      <a href="<%= action.url %>" class="rounded-xl border px-3 py-2 text-xs font-bold <%= buttonClass(action.label, action.enabled) %> <%= action.enabled ? '' : 'pointer-events-none opacity-100' %>"><%= action.label %></a>
                    <% } else { %>
                      <form data-action-form method="POST" action="<%= action.url %>" data-confirm="<%= action.confirmation || '' %>">
                        <% if (action.label === 'Run live submit automation') { %><input type="hidden" name="confirm" value="true"><% } %>
                        <button data-submit-label="Running…" <%= action.enabled ? '' : 'disabled' %> class="rounded-xl border px-3 py-2 text-xs font-bold shadow-sm <%= buttonClass(action.label, action.enabled) %>"><%= action.label %></button>
                      </form>
                    <% } %>
                    <% if (!action.enabled && action.disabledReason) { %><div class="basis-full text-xs text-zinc-500"><%= action.disabledReason %></div><% } %>
                  <% }) %>
                </div>
              <% } %>
            </div>
            <div class="space-y-2">
              <div><span class="<%= statusClass(stage.status) %>"><%= stage.displayStatus %></span></div>
              <% if (stage.processStatusLabel) { %><div class="text-xs text-zinc-500"><%= stage.processStatusLabel %></div><% } %>
              <div class="text-xs text-zinc-500"><%= stage.blockerCount %> item<%= stage.blockerCount === 1 ? '' : 's' %></div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <% if (showBrowsyDebug && cockpit.browsyRecordings && (cockpit.browsyRecordings.items || []).length) { %>
    <% const recBase = `/releases/${encodeURIComponent(cockpit.type)}/${encodeURIComponent(cockpit.id)}/magic-release`; %>
    <% function recBadge(sev) {
         if (sev === 'ready') return 'rounded-full bg-emerald-100 px-2 py-0.5 text-[11px] font-semibold text-emerald-700';
         if (sev === 'missing') return 'rounded-full bg-zinc-100 px-2 py-0.5 text-[11px] font-semibold text-zinc-600';
         if (sev === 'error') return 'rounded-full bg-rose-100 px-2 py-0.5 text-[11px] font-semibold text-rose-700';
         return 'rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-semibold text-amber-700';
       } %>
    <% function recLabel(item) {
         if (item.ready) return 'ready';
         if (item.readinessSeverity === 'missing') return 'not recorded';
         if (item.readinessSeverity === 'scaffold') return 'scaffold-only';
         if (item.readinessSeverity === 'error') return 'error';
         return 'incomplete';
       } %>
    <details class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5">
      <summary class="cursor-pointer text-sm font-bold text-zinc-700">Advanced Browsy recording diagnostics</summary>
      <div class="mb-4 flex items-center justify-between gap-3">
        <div>
          <h2 class="text-lg font-bold text-zinc-900">Browsy Recording Management</h2>
          <p class="mt-1 text-sm text-zinc-600">Advanced/admin view. Use the Automation Setup Wizard as the canonical authoring path. <%= cockpit.browsyRecordings.readyCount %> of <%= cockpit.browsyRecordings.items.length %> ready.</p>
        </div>
        <div class="text-xs text-zinc-500"><%= cockpit.browsyRecordings.configured ? `Browsy: ${cockpit.browsyRecordings.baseUrl}` : 'Browsy base URL not configured' %></div>
      </div>

      <div class="space-y-3">
        <% cockpit.browsyRecordings.items.forEach(item => { %>
          <% if (item.taskKey === 'distrokid_submit_dry_run') { return; } %>
          <div class="rounded-2xl border border-zinc-200 bg-zinc-50/60 p-4">
            <div class="flex flex-wrap items-center gap-2">
              <div class="font-semibold text-zinc-900"><%= item.workflowName || item.taskTitle %></div>
              <span class="<%= recBadge(item.ready ? 'ready' : item.readinessSeverity) %>"><%= recLabel(item) %></span>
              <% if (item.recordingStatus) { %><span class="rounded-full border border-zinc-200 bg-white px-2 py-0.5 text-[11px] font-semibold text-zinc-500"><%= item.recordingStatus %></span><% } %>
              <span class="text-[11px] text-zinc-400"><%= item.workflowId %></span>
            </div>

            <% if (!item.supported) { %>
              <div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-800"><%= item.unsupportedReason %></div>
            <% } %>

            <div class="mt-2 text-sm text-zinc-700"><%= item.readinessSummary %></div>

            <div class="mt-3 flex flex-wrap gap-3 text-xs text-zinc-600">
              <span><strong><%= item.counts.tabs %></strong> tabs</span>
              <span><strong><%= item.counts.recordedSteps %></strong> steps</span>
              <span><strong><%= item.counts.fileUploadBindings %></strong> uploads</span>
              <span><strong><%= item.counts.humanApprovalCheckpoints %></strong> checkpoints</span>
              <% if (item.importedWorkflowRef) { %><span class="break-all">ref: <%= item.importedWorkflowRef %></span><% } %>
            </div>

            <% if (item.lastError) { %><div class="mt-2 text-xs text-rose-700"><%= item.lastError %></div><% } %>

            <% if ((item.readinessChecks || []).length) { %>
              <details class="mt-2 text-xs text-zinc-600">
                <summary class="cursor-pointer font-semibold text-zinc-700">Contract checks</summary>
                <ul class="mt-2 space-y-1">
                  <% item.readinessChecks.forEach(check => { %>
                    <li><%= check.ok ? '✓' : '✗' %> <%= check.label %> <span class="text-zinc-400">(<%= check.actual %> / <%= check.expected %>)</span></li>
                  <% }) %>
                </ul>
              </details>
            <% } %>

            <% if (item.supported) { %>
              <div class="mt-3 flex flex-wrap gap-2">
                <% if (item.workflowId) { %>
                  <a href="<%= recBase %>/recordings/contract?workflow_id=<%= encodeURIComponent(item.workflowId) %>" target="_blank" class="rounded-xl border border-zinc-300 bg-white px-3 py-2 text-xs font-bold text-zinc-900">View Contract</a>
                <% } %>
                <form data-action-form method="POST" action="<%= recBase %>/recordings/refresh-contract">
                  <input type="hidden" name="task_key" value="<%= item.taskKey %>">
                  <button data-submit-label="Refreshing…" class="rounded-xl border border-zinc-300 bg-white px-3 py-2 text-xs font-bold text-zinc-900">Refresh Contract</button>
                </form>
                <% if (!item.hasRecording) { %>
                  <a href="/releases/<%= encodeURIComponent(cockpit.type) %>/<%= encodeURIComponent(cockpit.id) %>/automation-setup" class="rounded-xl border border-sky-300 bg-sky-600 px-3 py-2 text-xs font-bold text-white">Open Automation Setup Wizard</a>
                <% } else { %>
                  <% if (item.wizardUrl) { %><a href="<%= item.wizardUrl %>" target="_blank" class="rounded-xl border border-zinc-300 bg-white px-3 py-2 text-xs font-bold text-zinc-900">Open Browsy Session (advanced)</a><% } %>
                  <form data-action-form method="POST" action="<%= recBase %>/recordings/<%= encodeURIComponent(item.recordingId) %>/launch">
                    <button data-submit-label="Launching…" class="rounded-xl border border-sky-300 bg-sky-600 px-3 py-2 text-xs font-bold text-white">Launch Recorder</button>
                  </form>
                  <form data-action-form method="POST" action="<%= recBase %>/recordings/<%= encodeURIComponent(item.recordingId) %>/stop">
                    <button data-submit-label="Stopping…" class="rounded-xl border border-zinc-300 bg-white px-3 py-2 text-xs font-bold text-zinc-900">Stop Recording</button>
                  </form>
                  <form data-action-form method="POST" action="<%= recBase %>/recordings/<%= encodeURIComponent(item.recordingId) %>/import" data-confirm="Import/replace the published Browsy workflow contract from this recording?">
                    <button data-submit-label="Importing…" class="rounded-xl border border-emerald-300 bg-emerald-600 px-3 py-2 text-xs font-bold text-white">Import / Replace</button>
                  </form>
                  <form data-action-form method="POST" action="<%= recBase %>/recordings/start">
                    <input type="hidden" name="task_key" value="<%= item.taskKey %>">
                    <button data-submit-label="Starting…" class="rounded-xl border border-zinc-300 bg-white px-3 py-2 text-xs font-bold text-zinc-900">Re-record</button>
                  </form>
                <% } %>
                <form data-action-form method="POST" action="<%= recBase %>/tasks/<%= encodeURIComponent(item.taskKey) %>/run">
                  <input type="hidden" name="dry_run" value="true">
                  <button data-submit-label="Running…" <%= item.ready ? '' : 'disabled' %> class="rounded-xl border px-3 py-2 text-xs font-bold <%= item.ready ? 'border-zinc-300 bg-white text-zinc-900' : 'border-zinc-200 bg-zinc-100 text-zinc-400 cursor-not-allowed' %>">Run Preview</button>
                </form>
                <form data-action-form method="POST" action="<%= recBase %>/tasks/<%= encodeURIComponent(item.taskKey) %>/run" data-confirm="<%= item.ready ? 'Run the live Browsy automation for this workflow? It still stops at the human submit gate.' : 'This workflow has no ready contract yet — the run will be blocked. Continue?' %>">
                  <input type="hidden" name="dry_run" value="false">
                  <button data-submit-label="Running…" <%= item.ready ? '' : 'disabled' %> class="rounded-xl border px-3 py-2 text-xs font-bold <%= item.ready ? 'border-emerald-300 bg-emerald-600 text-white' : 'border-zinc-200 bg-zinc-100 text-zinc-400 cursor-not-allowed' %>">Run Live</button>
                </form>
                <% if (!item.ready) { %><div class="basis-full text-xs text-zinc-500">Run Live is disabled until the Browsy contract is recorded/imported and complete.</div><% } %>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    </details>
  <% } %>

  <section id="tracks" class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h2 class="text-lg font-bold text-zinc-900">Track table / album details</h2>
        <p class="mt-1 text-sm text-zinc-600">Track order, files, readiness pills, cost visibility, and safe remove-from-release controls live here.</p>
      </div>
      <div class="flex flex-wrap gap-2 text-xs">
        <a href="/releases/<%= cockpit.type %>/<%= encodeURIComponent(cockpit.id) %>#tracks" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 font-semibold hover:bg-zinc-50">All tracks</a>
        <a href="/releases/<%= cockpit.type %>/<%= encodeURIComponent(cockpit.id) %>?focus=metadata#tracks" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 font-semibold hover:bg-zinc-50">Metadata blockers</a>
        <a href="/releases/<%= cockpit.type %>/<%= encodeURIComponent(cockpit.id) %>?focus=audio#tracks" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 font-semibold hover:bg-zinc-50">Audio blockers</a>
      </div>
    </div>

    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="text-left text-xs uppercase tracking-wide text-zinc-500">
          <tr>
            <th class="pb-3 pr-3">Order</th>
            <th class="pb-3 pr-3">Title</th>
            <th class="pb-3 pr-3">File name</th>
            <th class="pb-3 pr-3">Song ID</th>
            <th class="pb-3 pr-3">Metadata</th>
            <th class="pb-3 pr-3">Audio</th>
            <th class="pb-3 pr-3">Cost</th>
            <th class="pb-3 pr-3">Release status</th>
            <th class="pb-3">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          <% cockpit.trackTable.rows.forEach(track => { %>
            <% const visible = activeFocus === 'all' || track.affected[activeFocus]; %>
            <% if (visible) { %>
              <tr class="<%= track.affected.metadata || track.affected.audio ? 'bg-amber-50/50' : '' %>">
                <td class="py-3 pr-3 font-semibold text-zinc-600">#<%= track.track_number %></td>
                <td class="py-3 pr-3">
                  <div class="flex items-center gap-1.5">
                    <span class="font-semibold text-zinc-900"><%= track.title || track.topic || track.id %></span>
                    <%- playBtn(track.releaseAudio?.selected?.url) %>
                  </div>
                </td>
                <td class="py-3 pr-3 text-xs text-zinc-600"><%= track.audioStatus.fileName || '—' %></td>
                <td class="py-3 pr-3 text-xs text-zinc-500"><%= track.id %></td>
                <td class="py-3 pr-3"><span class="<%= statusClass(track.metadataStatus.status) %>"><%= track.metadataStatus.label %></span></td>
                <td class="py-3 pr-3"><span class="<%= statusClass(track.audioStatus.status) %>"><%= track.audioStatus.label %></span></td>
                <td class="py-3 pr-3 text-xs text-zinc-600"><%= track.costDisplay %></td>
                <td class="py-3 pr-3"><span class="<%= lifecycleClass(track.lifecycleLabel) %>"><%= track.lifecycleLabel %></span></td>
                <td class="py-3">
                  <div class="flex flex-wrap gap-2">
                    <a href="<%= track.actions.openSong %>" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50">Open song</a>
                    <a href="<%= track.actions.fixMetadata %>" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50">Fix metadata</a>
                    <form data-action-form method="POST" action="<%= track.actions.generateMetadata %>">
                      <button data-submit-label="Generating…" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50">Generate metadata</button>
                    </form>
                    <a href="<%= track.actions.chooseMaster %>" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50"><%= track.releaseAudio?.requiresSelection ? 'Choose master' : 'Choose / change master' %></a>
                    <a href="<%= track.actions.generateMaster %>" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50">Generate master</a>
                    <% if (track.actions.removeTrack) { %>
                      <form data-action-form method="POST" action="<%= track.actions.removeTrack %>" data-confirm="Remove this track from the album release? The song stays in the catalog.">
                        <button data-submit-label="Removing…" class="rounded-lg border border-rose-200 bg-rose-50 px-2.5 py-1.5 text-xs font-semibold text-rose-700 hover:bg-rose-100">Remove track</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% } %>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5">
    <h2 class="text-lg font-bold text-zinc-900">Run history / logs</h2>
    <% if (runHistory.length) { %>
      <div class="mt-4 space-y-3">
        <% runHistory.forEach(run => { %>
          <div class="rounded-xl border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm">
            <div class="flex flex-wrap items-center gap-2">
              <span class="<%= statusClass(run.status) %>"><%= run.status.replace(/_/g, ' ') %></span>
              <span class="font-semibold text-zinc-900"><%= run.action %></span>
              <% if (run.displayStatus) { %><span class="text-xs text-zinc-500"><%= run.displayStatus %></span><% } %>
              <span class="text-xs text-zinc-500"><%= formatDateTime(run.latestAt) %></span>
            </div>
            <div class="mt-2 text-xs text-zinc-600">Run ID <span class="font-semibold text-zinc-900"><%= run.runId %></span></div>
            <% if (run.command) { %><div class="mt-1 break-all text-xs text-zinc-600"><%= run.command %></div><% } %>
            <% if (run.error) { %><div class="mt-2 text-sm text-rose-700"><%= run.error %></div><% } %>
            <div class="mt-2 flex flex-wrap gap-3 text-xs">
              <% if (run.logUrl) { %><a href="<%= run.logUrl %>" target="_blank" class="font-semibold text-sky-700 hover:underline">Open log output</a><% } %>
              <% if (run.logPath) { %><span class="text-zinc-500"><%= run.logPath %></span><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="mt-3 rounded-lg border border-dashed border-zinc-300 bg-zinc-50 p-4 text-sm text-zinc-500">No release automation runs recorded yet.</div>
    <% } %>
  </section>
</div>

<script>
  document.querySelectorAll('[data-action-form]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      const confirmMessage = form.getAttribute('data-confirm');
      if (confirmMessage && !window.confirm(confirmMessage)) {
        event.preventDefault();
        return;
      }
      const button = form.querySelector('button[type="submit"], button:not([type])');
      if (button) {
        button.dataset.originalText = button.textContent.trim();
        button.textContent = button.getAttribute('data-submit-label') || 'Running…';
        button.disabled = true;
      }
    });
  });

  document.querySelectorAll('[data-copy-path]').forEach((button) => {
    button.addEventListener('click', async () => {
      const path = button.getAttribute('data-copy-path') || '';
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(path);
        } else {
          const ta = document.createElement('textarea');
          ta.value = path;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        button.classList.add('text-emerald-600', 'border-emerald-300');
        button.classList.remove('text-zinc-400');
        setTimeout(() => {
          button.classList.remove('text-emerald-600', 'border-emerald-300');
          button.classList.add('text-zinc-400');
        }, 1200);
      } catch (err) {
        button.title = 'Copy failed — select the text manually';
      }
    });
  });
</script>
