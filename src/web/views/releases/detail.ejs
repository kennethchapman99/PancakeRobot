<% title = cockpit.title + ' Release Cockpit' %>
<%
  const activeFocus = ['metadata', 'audio'].includes(String(focus || '').toLowerCase()) ? String(focus).toLowerCase() : 'all';
  const statusClass = (status) => ({
    complete: 'badge-green',
    blocked: 'badge-red',
    ready: 'badge-blue',
    running: 'badge-blue',
    not_started: 'badge-gray',
    skipped: 'badge-gray',
    failed: 'badge-red',
  }[status] || 'badge-gray');
  const lifecycleClass = (status) => ({
    draft: 'badge-gray',
    editing: 'badge-yellow',
    submitted_to_distrokid: 'badge-blue',
    hyperfollow_ready: 'badge-blue',
    pre_release_marketing_ready: 'badge-green',
    archived: 'badge-gray',
    post_release_complete: 'badge-green',
  }[status] || 'badge-gray');
  const buttonClass = (label, enabled) => {
    if (!enabled) return 'border-zinc-200 bg-zinc-100 text-zinc-500';
    if (/skip|remove|delete/i.test(label)) return 'border-rose-300 bg-rose-500 text-white';
    if (/approve|paste|save/i.test(label)) return 'border-amber-300 bg-amber-500 text-white';
    if (/build outreach|send outreach/i.test(label)) return 'border-emerald-300 bg-emerald-600 text-white';
    return 'border-sky-300 bg-sky-600 text-white';
  };
  const feedbackClass = (level) => ({
    error: 'border-rose-200 bg-rose-50 text-rose-900',
    warning: 'border-amber-200 bg-amber-50 text-amber-900',
    success: 'border-emerald-200 bg-emerald-50 text-emerald-900',
    info: 'border-sky-200 bg-sky-50 text-sky-900',
  }[level] || 'border-sky-200 bg-sky-50 text-sky-900');
  const manualHyperfollowFormAction = `/releases/${encodeURIComponent(cockpit.type)}/${encodeURIComponent(cockpit.id)}/actions/hyperfollow`;
  const runHistory = cockpit.runHistory || [];
%>

<div class="p-8 max-w-7xl">
  <a href="/releases" class="mb-4 inline-flex text-sm text-zinc-500 hover:text-zinc-700">← Release Cockpit</a>

  <% if (actionFeedback) { %>
    <section class="mb-6 rounded-2xl border p-4 <%= feedbackClass(actionFeedback.level) %>">
      <div class="text-sm font-semibold"><%= actionFeedback.message %></div>
    </section>
  <% } %>

  <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500"><%= cockpit.type === 'album' ? 'Album Release' : 'Single Release' %></div>
        <h1 class="mt-1 text-3xl font-black tracking-tight text-zinc-900"><%= cockpit.title %></h1>
        <div class="mt-3 flex flex-wrap items-center gap-2 text-sm text-zinc-600">
          <span>ID <span class="font-semibold text-zinc-900"><%= cockpit.id %></span></span>
          <span>·</span>
          <span><%= cockpit.tracks.length %> track<%= cockpit.tracks.length === 1 ? '' : 's' %></span>
          <span>·</span>
          <span>Release date <span class="font-semibold text-zinc-900"><%= cockpit.releaseDate || '—' %></span></span>
          <span>·</span>
          <span>Brand profile <span class="font-semibold text-zinc-900"><%= cockpit.brandProfileId || '—' %></span></span>
        </div>
      </div>
      <div>
        <span class="<%= lifecycleClass(cockpit.lifecycle.current) %>"><%= cockpit.lifecycle.current.replace(/_/g, ' ') %></span>
      </div>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5">
    <div class="mb-4 flex items-center justify-between gap-3">
      <h2 class="text-lg font-bold text-zinc-900">Magic Release command bar</h2>
      <div class="text-xs text-zinc-500">Disabled actions show the exact blocking reason.</div>
    </div>
    <div class="grid gap-3 lg:grid-cols-5">
      <% cockpit.commandCenter.primaryActions.forEach(action => { %>
        <form data-action-form method="POST" action="<%= action.url %>" data-confirm="<%= action.confirmation || '' %>">
          <% if (action.key === 'live_submit') { %><input type="hidden" name="confirm" value="true"><% } %>
          <button data-submit-label="Running…" <%= action.enabled ? '' : 'disabled' %> class="flex h-full w-full flex-col justify-between rounded-2xl border px-4 py-4 text-left text-sm font-bold shadow-sm transition hover:brightness-95 disabled:cursor-not-allowed disabled:opacity-100 <%= buttonClass(action.label, action.enabled) %>">
            <span><%= action.label %></span>
            <% if (action.disabledReason) { %><span class="mt-2 text-xs font-medium opacity-90"><%= action.disabledReason %></span><% } %>
          </button>
        </form>
      <% }) %>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5">
    <div class="mb-4 flex items-center justify-between gap-3">
      <div>
        <h2 class="text-lg font-bold text-zinc-900">Release Readiness</h2>
        <p class="mt-1 text-sm text-zinc-600">This list is the source of truth for the release. Every row shows status, blocking reason or last result, and the next direct action.</p>
      </div>
      <div class="text-xs text-zinc-500">Statuses: complete, blocked, ready, running, not started, skipped, failed.</div>
    </div>

    <div class="space-y-3">
      <% cockpit.stages.forEach((stage, index) => { %>
        <div class="rounded-2xl border border-zinc-200 bg-zinc-50/60 p-4">
          <div class="grid gap-4 lg:grid-cols-[64px_minmax(0,1fr)_160px]">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-sm font-black text-zinc-500 ring-1 ring-zinc-200"><%= index + 1 %></div>
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <div class="font-semibold text-zinc-900"><%= stage.label %></div>
                <span class="rounded-full border border-zinc-200 bg-white px-2 py-0.5 text-[11px] font-semibold text-zinc-500"><%= stage.owner %></span>
              </div>
              <div class="mt-2 text-sm text-zinc-700"><%= stage.detail %></div>

              <% if (stage.latestRun) { %>
                <div class="mt-3 rounded-xl border border-zinc-200 bg-white px-3 py-3 text-xs text-zinc-600">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="font-semibold text-zinc-900">Run <%= stage.latestRun.runId %></span>
                    <span>·</span>
                    <span><%= formatDateTime(stage.latestRun.latestAt) %></span>
                    <% if (stage.latestRun.command) { %><span>·</span><span class="break-all"><%= stage.latestRun.command %></span><% } %>
                  </div>
                  <% if (stage.latestRun.error) { %><div class="mt-2 text-rose-700"><%= stage.latestRun.error %></div><% } %>
                  <% if (stage.latestRun.logUrl) { %><div class="mt-2"><a href="<%= stage.latestRun.logUrl %>" target="_blank" class="font-semibold text-sky-700 hover:underline">Open log output</a></div><% } %>
                </div>
              <% } %>

              <% if (stage.key === 'hyperfollow') { %>
                <form data-action-form method="POST" action="<%= manualHyperfollowFormAction %>" class="mt-3 rounded-xl border border-zinc-200 bg-white p-3">
                  <label class="text-xs font-semibold text-zinc-600" for="hyperfollow-url">Paste / save HyperFollow URL</label>
                  <div class="mt-2 flex flex-col gap-2 sm:flex-row">
                    <input id="hyperfollow-url" name="hyperfollow_url" value="<%= cockpit.hyperfollow?.url || '' %>" placeholder="https://distrokid.com/hyperfollow/..." class="w-full rounded-xl border border-zinc-200 px-3 py-2 text-sm">
                    <button data-submit-label="Saving…" <%= stage.actions.some(action => action.label === 'Save HyperFollow' && action.enabled) || cockpit.hyperfollow?.url ? '' : 'disabled' %> class="rounded-xl border px-4 py-2 text-sm font-bold <%= buttonClass('Save HyperFollow', stage.actions.some(action => action.label === 'Save HyperFollow' && action.enabled) || Boolean(cockpit.hyperfollow?.url)) %>">Save HyperFollow</button>
                  </div>
                  <% if (!stage.actions.some(action => action.label === 'Save HyperFollow' && action.enabled) && !cockpit.hyperfollow?.url) { %>
                    <div class="mt-2 text-xs text-amber-700">Available after live submit.</div>
                  <% } %>
                </form>
              <% } %>

              <% if ((stage.actions || []).length) { %>
                <div class="mt-3 flex flex-wrap gap-2">
                  <% stage.actions.forEach(action => { %>
                    <% if (stage.key === 'hyperfollow' && action.label === 'Save HyperFollow') { return; } %>
                    <% if (stage.key === 'hyperfollow' && action.label === 'Paste HyperFollow URL') { return; } %>
                    <% if (action.method === 'GET') { %>
                      <a href="<%= action.url %>" class="rounded-xl border px-3 py-2 text-xs font-bold <%= buttonClass(action.label, action.enabled) %> <%= action.enabled ? '' : 'pointer-events-none opacity-100' %>"><%= action.label %></a>
                    <% } else { %>
                      <form data-action-form method="POST" action="<%= action.url %>" data-confirm="<%= action.confirmation || '' %>">
                        <% if (action.label === 'Run live submit automation') { %><input type="hidden" name="confirm" value="true"><% } %>
                        <button data-submit-label="Running…" <%= action.enabled ? '' : 'disabled' %> class="rounded-xl border px-3 py-2 text-xs font-bold shadow-sm <%= buttonClass(action.label, action.enabled) %>"><%= action.label %></button>
                      </form>
                    <% } %>
                    <% if (!action.enabled && action.disabledReason) { %><div class="basis-full text-xs text-zinc-500"><%= action.disabledReason %></div><% } %>
                  <% }) %>
                </div>
              <% } %>
            </div>
            <div class="space-y-2">
              <div><span class="<%= statusClass(stage.status) %>"><%= stage.displayStatus %></span></div>
              <div class="text-xs text-zinc-500"><%= stage.blockerCount %> item<%= stage.blockerCount === 1 ? '' : 's' %></div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <section id="tracks" class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h2 class="text-lg font-bold text-zinc-900">Track table / album details</h2>
        <p class="mt-1 text-sm text-zinc-600">Track order, files, readiness pills, cost visibility, and safe remove-from-release controls live here.</p>
      </div>
      <div class="flex flex-wrap gap-2 text-xs">
        <a href="/releases/<%= cockpit.type %>/<%= encodeURIComponent(cockpit.id) %>#tracks" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 font-semibold hover:bg-zinc-50">All tracks</a>
        <a href="/releases/<%= cockpit.type %>/<%= encodeURIComponent(cockpit.id) %>?focus=metadata#tracks" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 font-semibold hover:bg-zinc-50">Metadata blockers</a>
        <a href="/releases/<%= cockpit.type %>/<%= encodeURIComponent(cockpit.id) %>?focus=audio#tracks" class="rounded-lg border border-zinc-200 bg-white px-3 py-2 font-semibold hover:bg-zinc-50">Audio blockers</a>
      </div>
    </div>

    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="text-left text-xs uppercase tracking-wide text-zinc-500">
          <tr>
            <th class="pb-3 pr-3">Order</th>
            <th class="pb-3 pr-3">Title</th>
            <th class="pb-3 pr-3">File name</th>
            <th class="pb-3 pr-3">Song ID</th>
            <th class="pb-3 pr-3">Metadata</th>
            <th class="pb-3 pr-3">Audio</th>
            <th class="pb-3 pr-3">Cost</th>
            <th class="pb-3 pr-3">Release status</th>
            <th class="pb-3">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          <% cockpit.trackTable.rows.forEach(track => { %>
            <% const visible = activeFocus === 'all' || track.affected[activeFocus]; %>
            <% if (visible) { %>
              <tr class="<%= track.affected.metadata || track.affected.audio ? 'bg-amber-50/50' : '' %>">
                <td class="py-3 pr-3 font-semibold text-zinc-600">#<%= track.track_number %></td>
                <td class="py-3 pr-3 font-semibold text-zinc-900"><%= track.title || track.topic || track.id %></td>
                <td class="py-3 pr-3 text-xs text-zinc-600"><%= track.audioStatus.fileName || '—' %></td>
                <td class="py-3 pr-3 text-xs text-zinc-500"><%= track.id %></td>
                <td class="py-3 pr-3"><span class="<%= statusClass(track.metadataStatus.status) %>"><%= track.metadataStatus.label %></span></td>
                <td class="py-3 pr-3"><span class="<%= statusClass(track.audioStatus.status) %>"><%= track.audioStatus.label %></span></td>
                <td class="py-3 pr-3 text-xs text-zinc-600"><%= track.costDisplay %></td>
                <td class="py-3 pr-3"><span class="<%= lifecycleClass(track.lifecycleLabel) %>"><%= track.lifecycleLabel %></span></td>
                <td class="py-3">
                  <div class="flex flex-wrap gap-2">
                    <a href="<%= track.actions.openSong %>" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50">Open song</a>
                    <a href="<%= track.actions.fixMetadata %>" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50">Fix metadata</a>
                    <form data-action-form method="POST" action="<%= track.actions.generateMetadata %>">
                      <button data-submit-label="Generating…" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50">Generate metadata</button>
                    </form>
                    <a href="<%= track.actions.chooseMaster %>" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50"><%= track.releaseAudio?.requiresSelection ? 'Choose master' : 'Choose / change master' %></a>
                    <a href="<%= track.actions.generateMaster %>" class="rounded-lg border border-zinc-200 bg-white px-2.5 py-1.5 text-xs font-semibold hover:bg-zinc-50">Generate master</a>
                    <% if (track.actions.removeTrack) { %>
                      <form data-action-form method="POST" action="<%= track.actions.removeTrack %>" data-confirm="Remove this track from the album release? The song stays in the catalog.">
                        <button data-submit-label="Removing…" class="rounded-lg border border-rose-200 bg-rose-50 px-2.5 py-1.5 text-xs font-semibold text-rose-700 hover:bg-rose-100">Remove track</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% } %>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 rounded-2xl border border-zinc-200 bg-white p-5">
    <h2 class="text-lg font-bold text-zinc-900">Run history / logs</h2>
    <% if (runHistory.length) { %>
      <div class="mt-4 space-y-3">
        <% runHistory.forEach(run => { %>
          <div class="rounded-xl border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm">
            <div class="flex flex-wrap items-center gap-2">
              <span class="<%= statusClass(run.status) %>"><%= run.status.replace(/_/g, ' ') %></span>
              <span class="font-semibold text-zinc-900"><%= run.action %></span>
              <span class="text-xs text-zinc-500"><%= formatDateTime(run.latestAt) %></span>
            </div>
            <div class="mt-2 text-xs text-zinc-600">Run ID <span class="font-semibold text-zinc-900"><%= run.runId %></span></div>
            <% if (run.command) { %><div class="mt-1 break-all text-xs text-zinc-600"><%= run.command %></div><% } %>
            <% if (run.error) { %><div class="mt-2 text-sm text-rose-700"><%= run.error %></div><% } %>
            <div class="mt-2 flex flex-wrap gap-3 text-xs">
              <% if (run.logUrl) { %><a href="<%= run.logUrl %>" target="_blank" class="font-semibold text-sky-700 hover:underline">Open log output</a><% } %>
              <% if (run.logPath) { %><span class="text-zinc-500"><%= run.logPath %></span><% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="mt-3 rounded-lg border border-dashed border-zinc-300 bg-zinc-50 p-4 text-sm text-zinc-500">No release automation runs recorded yet.</div>
    <% } %>
  </section>
</div>

<script>
  document.querySelectorAll('[data-action-form]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      const confirmMessage = form.getAttribute('data-confirm');
      if (confirmMessage && !window.confirm(confirmMessage)) {
        event.preventDefault();
        return;
      }
      const button = form.querySelector('button[type="submit"], button:not([type])');
      if (button) {
        button.dataset.originalText = button.textContent.trim();
        button.textContent = button.getAttribute('data-submit-label') || 'Running…';
        button.disabled = true;
      }
    });
  });
</script>
