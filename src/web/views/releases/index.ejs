<% title = 'Release Cockpit' %>
<div class="p-8 max-w-6xl">
  <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 class="text-3xl font-black tracking-tight text-zinc-900">Release Cockpit</h1>
      <p class="mt-2 text-sm text-zinc-600">Canonical release management for albums and singles. The list loads from lightweight DB state; open a release for full readiness checks.</p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <button id="filter-all" onclick="setFilter('all')" class="rounded-lg border border-zinc-300 bg-white px-3 py-1.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 transition-colors">All releases</button>
      <button id="filter-starred" onclick="setFilter('starred')" class="rounded-lg border border-zinc-300 bg-white px-3 py-1.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 transition-colors">
        <span class="mr-1">★</span>Starred only
      </button>
      <% const profileNames = [...new Set(releases.map(r => r.brandProfileName).filter(Boolean))].sort(); %>
      <% if (profileNames.length > 1) { %>
        <span class="text-zinc-300 text-xs">|</span>
        <% profileNames.forEach(name => { %>
          <button
            class="profile-filter-btn rounded-lg border border-zinc-300 bg-white px-3 py-1.5 text-xs font-semibold text-zinc-700 hover:bg-zinc-50 transition-colors"
            data-profile="<%= name %>"
            onclick="setProfileFilter('<%= name %>')"
          ><%= name %></button>
        <% }) %>
      <% } %>
    </div>
  </div>

  <section class="mt-6 overflow-hidden rounded-xl border border-zinc-200 bg-white">
    <div class="grid grid-cols-[32px_1fr_150px_100px_100px_120px] gap-3 border-b border-zinc-200 bg-zinc-50 px-4 py-3 text-xs font-semibold uppercase tracking-wide text-zinc-500">
      <div></div>
      <div>Release</div>
      <div>Profile</div>
      <div>Type</div>
      <div>Summary</div>
      <div>Release Date</div>
    </div>
    <% if (releases.length) { %>
      <% releases.forEach(release => { %>
        <div class="release-row grid grid-cols-[32px_1fr_150px_100px_100px_120px] gap-3 border-b border-zinc-100 px-4 py-3 text-sm hover:bg-zinc-50 items-center"
          data-starred="<%= release.starred ? '1' : '0' %>"
          data-profile="<%= release.brandProfileName || '' %>">
          <div>
            <button
              class="star-btn text-lg leading-none transition-colors <%= release.starred ? 'text-amber-400' : 'text-zinc-300 hover:text-amber-300' %>"
              data-type="<%= release.type %>"
              data-id="<%= encodeURIComponent(release.id) %>"
              data-starred="<%= release.starred ? '1' : '0' %>"
              title="<%= release.starred ? 'Unstar release' : 'Star release' %>"
              onclick="toggleStar(event, this)"
            >★</button>
          </div>
          <a href="/releases/<%= encodeURIComponent(release.type) %>/<%= encodeURIComponent(release.id) %>" class="min-w-0">
            <div class="truncate font-semibold text-zinc-900"><%= release.title %></div>
            <div class="mt-0.5 truncate text-xs text-zinc-500"><%= release.id %></div>
            <% if (release.hyperfollowUrl) { %>
              <div class="mt-1 truncate text-xs text-emerald-700">HyperFollow saved</div>
            <% } %>
          </a>
          <div class="truncate text-sm text-zinc-600"><%= release.brandProfileName || '—' %></div>
          <div><span class="badge-gray"><%= release.type === 'album' ? 'Album' : 'Single' %></span></div>
          <div>
            <span class="badge-gray"><%= release.stageSummary || ((release.trackCount || 1) + ' track') %></span>
          </div>
          <div class="text-zinc-600"><%= release.releaseDate || '—' %></div>
        </div>
      <% }) %>
      <div id="no-results-msg" class="hidden p-8 text-center text-sm text-zinc-500"></div>
    <% } else { %>
      <div class="p-8 text-center text-sm text-zinc-500">No releases are available yet.</div>
    <% } %>
  </section>
</div>

<script>
  let activeFilter = 'all';
  let activeProfile = null;

  function applyFilters() {
    const rows = document.querySelectorAll('.release-row');
    let visibleCount = 0;
    rows.forEach(row => {
      const isStarred = row.dataset.starred === '1';
      const rowProfile = row.dataset.profile;
      const passesStarFilter = activeFilter === 'all' || isStarred;
      const passesProfileFilter = !activeProfile || rowProfile === activeProfile;
      const show = passesStarFilter && passesProfileFilter;
      row.classList.toggle('hidden', !show);
      if (show) visibleCount++;
    });

    const msg = document.getElementById('no-results-msg');
    if (msg) {
      const label = activeFilter === 'starred' && activeProfile
        ? `No starred releases for ${activeProfile}.`
        : activeFilter === 'starred'
          ? 'No starred releases yet. Click ★ on any release to star it.'
          : activeProfile
            ? `No releases for ${activeProfile}.`
            : '';
      msg.textContent = label;
      msg.classList.toggle('hidden', visibleCount > 0);
    }
  }

  function setFilter(filter) {
    activeFilter = filter;
    document.getElementById('filter-all').classList.toggle('bg-zinc-900', filter === 'all');
    document.getElementById('filter-all').classList.toggle('text-white', filter === 'all');
    document.getElementById('filter-all').classList.toggle('border-zinc-900', filter === 'all');
    document.getElementById('filter-starred').classList.toggle('bg-zinc-900', filter === 'starred');
    document.getElementById('filter-starred').classList.toggle('text-white', filter === 'starred');
    document.getElementById('filter-starred').classList.toggle('border-zinc-900', filter === 'starred');
    applyFilters();
  }

  function setProfileFilter(profile) {
    activeProfile = activeProfile === profile ? null : profile;
    document.querySelectorAll('.profile-filter-btn').forEach(btn => {
      const active = btn.dataset.profile === activeProfile;
      btn.classList.toggle('bg-zinc-900', active);
      btn.classList.toggle('text-white', active);
      btn.classList.toggle('border-zinc-900', active);
    });
    applyFilters();
  }

  async function toggleStar(event, btn) {
    event.preventDefault();
    event.stopPropagation();
    const type = btn.dataset.type;
    const id = btn.dataset.id;
    try {
      const res = await fetch(`/releases/${encodeURIComponent(type)}/${id}/star`, { method: 'POST' });
      const data = await res.json();
      if (!data.ok) return;
      const starred = data.starred;
      btn.dataset.starred = starred ? '1' : '0';
      btn.title = starred ? 'Unstar release' : 'Star release';
      btn.className = `star-btn text-lg leading-none transition-colors ${starred ? 'text-amber-400' : 'text-zinc-300 hover:text-amber-300'}`;
      const row = btn.closest('.release-row');
      row.dataset.starred = starred ? '1' : '0';
      applyFilters();
    } catch (e) {
      console.error('Failed to toggle star:', e);
    }
  }
</script>
