<% title = 'Automation Setup Wizard' %>
<%
  const feedbackClass = (level) => ({
    error: 'border-rose-200 bg-rose-50 text-rose-900',
    warning: 'border-amber-200 bg-amber-50 text-amber-900',
    success: 'border-emerald-200 bg-emerald-50 text-emerald-900',
    info: 'border-sky-200 bg-sky-50 text-sky-900',
  }[level] || 'border-sky-200 bg-sky-50 text-sky-900');
  const setup = context.validation || { ok: false, indicators: [], errors: [], warnings: [] };
  const payload = context.samplePayload || {};
  const album = payload.album || {};
  const tracks = payload.tracks || [];
%>

<div class="p-8 max-w-7xl">
  <a href="/releases/<%= encodeURIComponent(cockpit.type) %>/<%= encodeURIComponent(cockpit.id) %>" class="mb-4 inline-flex text-sm text-zinc-500 hover:text-zinc-700">← Release Cockpit</a>

  <% if (actionFeedback) { %>
    <section class="mb-6 rounded-2xl border p-4 <%= feedbackClass(actionFeedback.level) %>">
      <div class="text-sm font-semibold"><%= actionFeedback.message %></div>
    </section>
  <% } %>

  <section id="automation" class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Automation Setup Wizard</div>
        <h1 class="mt-1 text-3xl font-black tracking-tight text-zinc-900"><%= context.workflowName %></h1>
        <div class="mt-2 text-sm text-zinc-600">Review the Pancake Robot release contract before Browsy opens a recorder.</div>
      </div>
      <span class="rounded-full px-3 py-1 text-xs font-bold <%= setup.ok ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-800' %>"><%= setup.state %></span>
    </div>

    <div class="mt-5 grid gap-4 lg:grid-cols-2">
      <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4">
        <h2 class="text-base font-bold text-zinc-900">Workflow Identity</h2>
        <dl class="mt-3 space-y-2 text-sm">
          <div><dt class="text-xs font-semibold text-zinc-500">Workflow ID</dt><dd class="font-mono text-zinc-900"><%= context.workflowId %></dd></div>
          <div><dt class="text-xs font-semibold text-zinc-500">Workflow ref</dt><dd class="font-mono text-zinc-900"><%= context.workflowRef %></dd></div>
          <div><dt class="text-xs font-semibold text-zinc-500">Source app</dt><dd class="font-mono text-zinc-900"><%= context.sourceApp %></dd></div>
          <div><dt class="text-xs font-semibold text-zinc-500">Browsy base URL</dt><dd class="font-mono text-zinc-900"><%= context.browsyBaseUrl || 'Not configured' %></dd></div>
          <div><dt class="text-xs font-semibold text-zinc-500">Target URL</dt><dd class="font-mono text-zinc-900"><%= context.targetUrl %></dd></div>
        </dl>
      </div>

      <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4">
        <h2 class="text-base font-bold text-zinc-900">Validation</h2>
        <div class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
          <% setup.indicators.forEach(ind => { %>
            <div class="<%= ind.ok ? 'text-emerald-700' : 'text-rose-700' %>"><%= ind.ok ? '✓' : '✗' %> <%= ind.label %></div>
          <% }) %>
        </div>
        <% if (setup.errors.length) { %>
          <div class="mt-3 rounded-lg border border-rose-200 bg-rose-50 p-3 text-xs text-rose-800"><%= setup.errors.join(' ') %></div>
        <% } %>
        <% if (setup.warnings.length) { %>
          <div class="mt-3 rounded-lg border border-amber-200 bg-amber-50 p-3 text-xs text-amber-800"><%= setup.warnings.join(' ') %></div>
        <% } %>
      </div>
    </div>

    <section class="mt-5 rounded-xl border border-zinc-200 bg-white p-4">
      <h2 class="text-base font-bold text-zinc-900">Inputs Pancake Robot Will Provide</h2>
      <div class="mt-3 flex flex-wrap gap-2 text-xs">
        <% context.bindingHints.forEach(hint => { %>
          <span class="rounded-full border border-zinc-200 bg-zinc-50 px-2 py-1 font-mono text-zinc-700"><%= hint.path %></span>
        <% }) %>
      </div>
    </section>

    <section class="mt-5 rounded-xl border border-zinc-200 bg-white p-4">
      <h2 class="text-base font-bold text-zinc-900">Sample Release Payload</h2>
      <div class="mt-3 grid gap-3 text-sm lg:grid-cols-2">
        <div>
          <div><span class="font-semibold text-zinc-500">Album</span> <%= album.title || 'Missing title' %></div>
          <div><span class="font-semibold text-zinc-500">Artist</span> <%= album.artistName || 'Missing artist' %></div>
          <div><span class="font-semibold text-zinc-500">Release date</span> <span class="font-mono"><%= album.releaseDate || 'Missing release date' %></span></div>
          <div><span class="font-semibold text-zinc-500">Cover art</span> <span class="font-mono break-all"><%= album.coverArtPath || 'Missing cover art path' %></span></div>
          <div><span class="font-semibold text-zinc-500">tracks.length</span> <span class="font-mono"><%= tracks.length %></span></div>
          <div><span class="font-semibold text-zinc-500">derived.numberOfSongs</span> <span class="font-mono"><%= payload.derived?.numberOfSongs ?? tracks.length %></span></div>
        </div>
        <div class="space-y-2">
          <% tracks.forEach(track => { %>
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-3">
              <div class="font-semibold text-zinc-900"><%= track.index %>. <%= track.title || 'Missing title' %></div>
              <div class="mt-1 font-mono text-xs break-all text-zinc-600"><%= track.audioPath || 'Missing audio path' %></div>
            </div>
          <% }) %>
        </div>
      </div>
      <details class="mt-4">
        <summary class="cursor-pointer text-xs font-semibold text-zinc-600">Raw sample payload JSON</summary>
        <pre class="mt-2 overflow-auto rounded-xl bg-zinc-950 p-4 text-xs text-zinc-100"><%= JSON.stringify(payload, null, 2) %></pre>
      </details>
    </section>

    <form method="POST" action="/releases/<%= encodeURIComponent(cockpit.type) %>/<%= encodeURIComponent(cockpit.id) %>/automation-setup/start-recording" class="mt-5 rounded-xl border border-zinc-200 bg-zinc-50 p-4">
      <label class="text-xs font-semibold text-zinc-600" for="target_url">Target URL</label>
      <input id="target_url" name="target_url" value="<%= context.targetUrl %>" class="mt-2 w-full rounded-xl border border-zinc-200 px-3 py-2 font-mono text-sm">
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <button data-submit-label="Starting…" <%= setup.ok ? '' : 'disabled' %> class="rounded-xl border px-4 py-2 text-sm font-bold <%= setup.ok ? 'border-sky-300 bg-sky-600 text-white' : 'border-zinc-200 bg-zinc-100 text-zinc-400 cursor-not-allowed' %>">Start Recording</button>
        <% if (!setup.ok) { %><span class="text-xs text-zinc-500">Disabled until setup validation passes.</span><% } %>
      </div>
    </form>
  </section>
</div>
