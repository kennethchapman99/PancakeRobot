<% title = releaseKit.title + ' Release Kit' %>
<% const manifest = releaseKit.manifest || { assets: [] }; const generatedAt = releaseKit.generatedAt || manifest.generatedAt || ''; const withAssetVersion = (url) => !url ? '' : url + (url.includes('?') ? '&' : '?') + 'v=' + encodeURIComponent(generatedAt); const previewAssets = (manifest.assets || []).filter(asset => ['image', 'video'].includes(asset.kind) && asset.publicUrl); const fileAssets = (manifest.assets || []).filter(asset => asset.publicUrl); const supportingAssets = fileAssets.filter(asset => ['metadata', 'document'].includes(asset.kind)); const legacyPreviewAsset = fileAssets.find(asset => asset.kind === 'preview'); %>

<div class="max-w-5xl mx-auto p-8 space-y-8">
  <section class="bg-white border border-zinc-200 rounded-2xl p-8">
    <div class="flex flex-wrap items-start justify-between gap-6">
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-zinc-400">Release Kit</div>
        <h1 class="text-4xl font-extrabold mt-2"><%= releaseKit.title %></h1>
        <div class="text-sm text-zinc-500 mt-2"><%= releaseKit.artistName %><% if (releaseKit.releaseDate) { %> · <%= releaseKit.releaseDate %><% } %></div>
        <% if (preview) { %><div class="mt-3 inline-flex rounded-full bg-amber-100 text-amber-700 px-3 py-1 text-xs font-semibold">Preview mode</div><% } %>
      </div>
      <% if (releaseKit.heroImageUrl) { %>
      <img src="<%= releaseKit.heroImageUrl %>" alt="<%= releaseKit.title %>" class="w-48 h-48 rounded-2xl object-cover border border-zinc-200">
      <% } %>
    </div>
    <% if (releaseKit.shortDescription || releaseKit.longDescription) { %>
    <div class="mt-6 grid md:grid-cols-2 gap-6">
      <div>
        <div class="text-xs uppercase tracking-wide text-zinc-400 mb-2">Short Description</div>
        <div class="text-sm text-zinc-700"><%= releaseKit.shortDescription || '—' %></div>
      </div>
      <div>
        <div class="text-xs uppercase tracking-wide text-zinc-400 mb-2">Long Description</div>
        <div class="text-sm text-zinc-700 whitespace-pre-wrap"><%= releaseKit.longDescription || '—' %></div>
      </div>
    </div>
    <% } %>
  </section>

  <section class="grid lg:grid-cols-[1.1fr_0.9fr] gap-6">
    <div class="bg-white border border-zinc-200 rounded-2xl p-6">
      <h2 class="font-semibold text-lg mb-4">Streaming + Promo Links</h2>
      <div class="grid md:grid-cols-2 gap-3">
        <% for (const link of releaseKit.streamingLinks) { %>
        <a href="<%= link.url %>" target="_blank" rel="noopener" class="border border-zinc-200 rounded-xl p-3 hover:bg-zinc-50">
          <div class="text-[10px] uppercase tracking-wide text-zinc-400"><%= link.label %></div>
          <div class="mt-1 text-sm text-blue-600 break-all"><%= link.url %></div>
        </a>
        <% } %>
        <% if (releaseKit.kit.marketing_links.audio_download_url) { %><a href="<%= releaseKit.kit.marketing_links.audio_download_url %>" target="_blank" rel="noopener" class="border border-zinc-200 rounded-xl p-3 hover:bg-zinc-50"><div class="text-[10px] uppercase tracking-wide text-zinc-400">Download Audio</div><div class="mt-1 text-sm text-blue-600 break-all"><%= releaseKit.kit.marketing_links.audio_download_url %></div></a><% } %>
        <% if (releaseKit.kit.marketing_links.promo_assets_folder_url) { %><a href="<%= releaseKit.kit.marketing_links.promo_assets_folder_url %>" target="_blank" rel="noopener" class="border border-zinc-200 rounded-xl p-3 hover:bg-zinc-50"><div class="text-[10px] uppercase tracking-wide text-zinc-400">Promo Assets</div><div class="mt-1 text-sm text-blue-600 break-all"><%= releaseKit.kit.marketing_links.promo_assets_folder_url %></div></a><% } %>
        <% if (releaseKit.kit.marketing_links.lyrics_url) { %><a href="<%= releaseKit.kit.marketing_links.lyrics_url %>" target="_blank" rel="noopener" class="border border-zinc-200 rounded-xl p-3 hover:bg-zinc-50"><div class="text-[10px] uppercase tracking-wide text-zinc-400">Lyrics</div><div class="mt-1 text-sm text-blue-600 break-all"><%= releaseKit.kit.marketing_links.lyrics_url %></div></a><% } %>
      </div>
    </div>

    <div class="bg-white border border-zinc-200 rounded-2xl p-6">
      <h2 class="font-semibold text-lg mb-4">Contact + Social</h2>
      <div class="space-y-3 text-sm">
        <% if (releaseKit.socialHandle) { %><div><span class="text-zinc-400">Social handle:</span> <span class="font-medium text-zinc-700"><%= releaseKit.socialHandle %></span></div><% } %>
        <% if (releaseKit.kit.marketing_links.contact_email) { %><div><span class="text-zinc-400">Contact:</span> <a class="text-blue-600" href="mailto:<%= releaseKit.kit.marketing_links.contact_email %>"><%= releaseKit.kit.marketing_links.contact_email %></a></div><% } %>
        <% if (releaseKit.kit.marketing_links.artist_website_url) { %><div><span class="text-zinc-400">Website:</span> <a class="text-blue-600 break-all" href="<%= releaseKit.kit.marketing_links.artist_website_url %>" target="_blank"><%= releaseKit.kit.marketing_links.artist_website_url %></a></div><% } %>
        <% if (releaseKit.kit.marketing_links.instagram_url) { %><div><span class="text-zinc-400">Instagram:</span> <a class="text-blue-600 break-all" href="<%= releaseKit.kit.marketing_links.instagram_url %>" target="_blank"><%= releaseKit.kit.marketing_links.instagram_url %></a></div><% } %>
        <% if (releaseKit.kit.marketing_links.tiktok_url) { %><div><span class="text-zinc-400">TikTok:</span> <a class="text-blue-600 break-all" href="<%= releaseKit.kit.marketing_links.tiktok_url %>" target="_blank"><%= releaseKit.kit.marketing_links.tiktok_url %></a></div><% } %>
      </div>
      <div class="mt-5 grid gap-3">
        <div class="rounded-xl border border-zinc-200 p-3 text-sm">
          <div class="text-[10px] uppercase tracking-wide text-zinc-400">Latest Instagram URL</div>
          <% if (releaseKit.latestSocial?.latestInstagramUrl) { %><a href="<%= releaseKit.latestSocial.latestInstagramUrl %>" target="_blank" rel="noopener" class="mt-1 block break-all text-blue-600"><%= releaseKit.latestSocial.latestInstagramUrl %></a><% } else { %><div class="mt-1 text-zinc-400">—</div><% } %>
        </div>
        <div class="rounded-xl border border-zinc-200 p-3 text-sm">
          <div class="text-[10px] uppercase tracking-wide text-zinc-400">Latest Facebook URL</div>
          <% if (releaseKit.latestSocial?.latestFacebookUrl) { %><a href="<%= releaseKit.latestSocial.latestFacebookUrl %>" target="_blank" rel="noopener" class="mt-1 block break-all text-blue-600"><%= releaseKit.latestSocial.latestFacebookUrl %></a><% } else { %><div class="mt-1 text-zinc-400">—</div><% } %>
        </div>
        <div class="rounded-xl border border-zinc-200 p-3 text-sm">
          <div class="text-[10px] uppercase tracking-wide text-zinc-400">Latest YouTube URL</div>
          <% if (releaseKit.latestSocial?.latestYouTubeUrl) { %><a href="<%= releaseKit.latestSocial.latestYouTubeUrl %>" target="_blank" rel="noopener" class="mt-1 block break-all text-blue-600"><%= releaseKit.latestSocial.latestYouTubeUrl %></a><% } else { %><div class="mt-1 text-zinc-400">—</div><% } %>
        </div>
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <a href="/songs/<%= encodeURIComponent(releaseKit.song.id) %>?tab=marketing" class="border border-zinc-200 rounded-xl px-3 py-2 text-sm hover:bg-zinc-50">Use in Daily Social Push</a>
        <a href="/marketing/social" class="border border-zinc-200 rounded-xl px-3 py-2 text-sm hover:bg-zinc-50">Open Daily Social</a>
      </div>
      <div class="mt-6 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-800"><%= releaseKit.usageNote %></div>
      <% if (generatedAt) { %><div class="mt-3 text-xs text-zinc-500">Last generated: <%= generatedAt %></div><% } %>
    </div>
  </section>

  <section class="bg-white border border-zinc-200 rounded-2xl p-6">
    <div class="mb-4">
      <h2 class="font-semibold text-lg">Generated Social + Media Assets</h2>
      <div class="text-xs text-zinc-500 mt-1">This is the canonical preview surface for release assets.</div>
    </div>
    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
      <% if (!previewAssets.length) { %>
      <div class="text-sm text-zinc-400">No generated promo assets yet.</div>
      <% } %>
      <% for (const asset of previewAssets) { %>
      <div class="border border-zinc-200 rounded-xl p-3">
        <% if (asset.type === 'video') { %>
        <a href="<%= withAssetVersion(asset.publicUrl) %>" target="_blank" rel="noopener" class="block">
          <video controls class="w-full h-44 object-cover rounded-lg border border-zinc-200 bg-zinc-950"><source src="<%= withAssetVersion(asset.publicUrl) %>"></video>
        </a>
        <% } else { %>
        <a href="<%= withAssetVersion(asset.publicUrl) %>" target="_blank" rel="noopener" class="block">
          <img src="<%= withAssetVersion(asset.publicUrl) %>" alt="<%= asset.altText || asset.label %>" class="w-full h-44 object-cover rounded-lg border border-zinc-200 bg-zinc-50 hover:opacity-95">
        </a>
        <% } %>
        <a href="<%= withAssetVersion(asset.publicUrl) %>" target="_blank" rel="noopener" class="mt-2 block text-sm font-medium text-zinc-700 hover:text-zinc-900"><%= asset.label %></a>
        <div class="mt-1 text-[11px] text-zinc-500"><%= (asset.platformFit || []).join(' · ') || 'general' %></div>
        <% if (asset.dimensions) { %><div class="mt-1 text-[11px] text-zinc-500"><%= asset.dimensions.width %> × <%= asset.dimensions.height %></div><% } %>
        <div class="mt-3 flex flex-wrap gap-2">
          <a href="<%= withAssetVersion(asset.publicUrl) %>" target="_blank" rel="noopener" class="border border-zinc-200 rounded-lg px-2 py-1 text-xs hover:bg-zinc-50">Open</a>
          <a href="<%= withAssetVersion(asset.publicUrl) %>" download class="border border-zinc-200 rounded-lg px-2 py-1 text-xs hover:bg-zinc-50">Download</a>
        </div>
      </div>
      <% } %>
    </div>
  </section>

  <section class="bg-white border border-zinc-200 rounded-2xl p-6">
    <div class="flex items-center justify-between gap-4 mb-4">
      <h2 class="font-semibold text-lg">Manifest + Supporting Files</h2>
      <% if (legacyPreviewAsset?.publicUrl || manifest.dashboardUrl) { %><a href="<%= withAssetVersion(legacyPreviewAsset?.publicUrl || manifest.dashboardUrl) %>" target="_blank" rel="noopener" class="border border-zinc-200 rounded-xl px-3 py-2 text-sm hover:bg-zinc-50">Open Legacy Static Preview</a><% } %>
    </div>
    <div class="grid md:grid-cols-2 gap-3">
      <% if (!supportingAssets.length) { %>
      <div class="text-sm text-zinc-400">No manifest-backed files yet.</div>
      <% } %>
      <% for (const asset of supportingAssets) { %>
      <a href="<%= withAssetVersion(asset.publicUrl) %>" target="_blank" rel="noopener" class="border border-zinc-200 rounded-xl p-3 hover:bg-zinc-50">
        <div class="text-[10px] uppercase tracking-wide text-zinc-400"><%= asset.kind %></div>
        <div class="mt-1 text-sm text-zinc-700"><%= asset.label %></div>
        <div class="mt-1 text-[11px] text-zinc-500 break-all"><%= asset.publicUrl %></div>
      </a>
      <% } %>
    </div>
    <% if (manifest.socialHandle || generatedAt) { %>
    <div class="mt-4 rounded-xl border border-zinc-200 bg-zinc-50 p-4 text-xs text-zinc-600">
      <% if (manifest.socialHandle) { %><div>socialHandle: <span class="font-mono"><%= manifest.socialHandle %></span></div><% } %>
      <% if (generatedAt) { %><div class="mt-1">generatedAt: <span class="font-mono"><%= generatedAt %></span></div><% } %>
    </div>
    <% } %>
  </section>
</div>
