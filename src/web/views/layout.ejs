<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %><%= appTitle || brandName || 'Music Pipeline' %></title>
  <link rel="icon" type="image/png" href="<%= logoPath || '/logo.png' %>">
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <style>
    [x-cloak] { display: none !important; }
    .badge-base { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:0.75rem; font-weight:500; }
    .badge-gray   { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:0.75rem; font-weight:500; background:#f4f4f5; color:#52525b; }
    .badge-blue   { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:0.75rem; font-weight:500; background:#dbeafe; color:#1d4ed8; }
    .badge-yellow { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:0.75rem; font-weight:500; background:#fef3c7; color:#b45309; }
    .badge-green  { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:0.75rem; font-weight:500; background:#dcfce7; color:#15803d; }
    .badge-emerald{ display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:0.75rem; font-weight:500; background:#d1fae5; color:#047857; }
    .badge-purple { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:0.75rem; font-weight:500; background:#ede9fe; color:#6d28d9; }
    .badge-red    { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:0.75rem; font-weight:500; background:#fee2e2; color:#b91c1c; }
    .badge-dim    { display:inline-flex; align-items:center; padding:2px 8px; border-radius:9999px; font-size:0.75rem; font-weight:500; background:#f4f4f5; color:#a1a1aa; }
    html.songs-detail-page main > div[x-data="songDetail()"] { max-width: 88rem !important; width: 100%; }
  </style>
</head>
<body class="h-full bg-zinc-50 text-zinc-900 antialiased">

<div class="flex h-full min-h-screen">

  <!-- Sidebar -->
  <nav class="w-56 shrink-0 bg-zinc-900 text-zinc-100 flex flex-col">
    <!-- Brand Logo -->
    <div class="px-4 pt-5 pb-4 border-b border-zinc-800 flex flex-col items-center">
      <img src="<%= logoPath || '/logo.png' %>" alt="<%= brandName || 'Music Pipeline' %>" class="w-36 h-36 object-contain drop-shadow-lg">
      <div class="text-xs text-zinc-500 mt-1 tracking-widest uppercase font-medium"><%= sidebarSubtitle || 'Music Studio' %></div>
    </div>

    <div class="flex-1 py-4 overflow-y-auto">
      <div class="px-3 space-y-0.5">
        <!-- Generate CTA — primary action -->
        <a href="/ideas/generate"
           class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-semibold transition-all mb-1
             <%= currentPath === '/ideas/generate' ? 'bg-amber-600 text-white' : 'bg-amber-500 hover:bg-amber-400 text-white' %> shadow-sm">
          <span class="text-base">✨</span>
          Generate Ideas
        </a>

        <% const navLinks = [['/', 'Dashboard', '◈'], ['/ideas', 'Idea Vault', '💡'], ['/songs', 'Song Catalog', '🎵'], ['/marketing', 'Marketing', '📣'], ['/brand', 'Brand', '🎨']]; %>
        <% for (const [href, label, icon] of navLinks) { %>
          <a href="<%= href %>"
             class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors <%= currentPath === href || (href !== '/' && currentPath.startsWith(href) && href !== '/ideas' || currentPath === href) ? 'bg-zinc-700 text-white font-medium' : 'text-zinc-400 hover:bg-zinc-800 hover:text-white' %>">
            <span class="text-base"><%= icon %></span>
            <%= label %>
          </a>
        <% } %>
      </div>
    </div>

    <div class="px-4 py-4 border-t border-zinc-800 text-xs text-zinc-600">
      <div><%= defaultDistributor || 'Distribution' %></div>
      <% if (distributorUrl) { %>
      <div class="mt-1">
        <a href="<%= distributorUrl %>" target="_blank" class="text-zinc-500 hover:text-zinc-300 transition">open distributor ↗</a>
      </div>
      <% } %>
    </div>
  </nav>

  <!-- Main -->
  <main class="flex-1 overflow-y-auto">
    <%- body %>
  </main>

</div>

<script>
  (() => {
    const isSongDetailPage = /^\/songs\/[^/]+\/?$/.test(window.location.pathname);
    if (!isSongDetailPage) return;

    document.documentElement.classList.add('songs-detail-page');

    const removeClosest = (element, selector) => {
      const node = element?.closest(selector);
      if (node) node.remove();
    };

    const run = () => {
      const detailRoot = document.querySelector('main > div[x-data="songDetail()"]');
      if (detailRoot) {
        detailRoot.classList.remove('max-w-4xl');
        detailRoot.classList.add('max-w-7xl', 'w-full');
      }

      removeClosest(document.getElementById('pct-label'), '.bg-white.border.border-zinc-200.rounded-xl.p-5.mb-6');

      const emptyThumbnailNode = Array.from(document.querySelectorAll('div, button'))
        .find((node) => {
          const text = node.textContent || '';
          return text.includes('No thumbnails yet') || text.includes('Generate Thumbnails');
        });

      if (emptyThumbnailNode) {
        const thumbnailColumn = emptyThumbnailNode.closest('.col-span-2') || emptyThumbnailNode.closest('.bg-zinc-50.border.border-dashed');
        const mediaGrid = thumbnailColumn?.closest('.grid');
        thumbnailColumn?.remove();

        const audioColumn = mediaGrid?.querySelector('.col-span-1');
        if (audioColumn && !mediaGrid.querySelector('.col-span-2')) {
          audioColumn.classList.remove('col-span-1');
          audioColumn.classList.add('col-span-full');
        }
      }

      const checklistHeading = Array.from(document.querySelectorAll('h2'))
        .find((heading) => heading.textContent?.trim() === 'Publishing Checklist');
      removeClosest(checklistHeading, 'section');
    };

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
    else run();
  })();
</script>

<script>
  (() => {
    const match = window.location.pathname.match(/^\/songs\/([^/]+)\/?$/);
    if (!match) return;

    const songId = decodeURIComponent(match[1]);
    const metaUrl = `/media/songs/${encodeURIComponent(songId)}/audio/generation-meta.json?ts=${Date.now()}`;

    const inferFromAudioDom = () => {
      const source = document.querySelector('audio source[src*="-paid.mp3"], audio source[src*="-free.mp3"]');
      if (!source) return null;
      const src = source.getAttribute('src') || '';
      const isFree = src.includes('-free.mp3');
      return {
        model: isFree ? 'music-2.6-free' : 'music-2.6',
        render_tier: isFree ? 'free' : 'paid',
        inferred_from_filename: true,
      };
    };

    const renderBadge = (meta) => {
      if (!meta || document.querySelector('[data-render-model-badge]')) return;

      const model = meta.model || 'unknown model';
      const tier = meta.render_tier || (model.includes('free') ? 'free' : model === 'unknown model' ? 'unknown' : 'paid');
      const isPaid = tier === 'paid';
      const isFree = tier === 'free';
      const label = isPaid ? `💎 MiniMax ${model} — PAID` : isFree ? `🧪 MiniMax ${model} — FREE` : `🎵 MiniMax ${model}`;
      const className = isPaid ? 'badge-emerald' : isFree ? 'badge-yellow' : 'badge-gray';

      const badge = document.createElement('span');
      badge.setAttribute('data-render-model-badge', 'true');
      badge.className = `${className} ml-0.5`;
      badge.textContent = label;
      badge.title = meta.inferred_from_filename
        ? 'Inferred from rendered audio filename. New renders also write audio/generation-meta.json.'
        : `Generated ${meta.generated_at || ''}. Pre-render QA: ${meta.pre_render_qa_passed === false ? 'failed' : 'passed/unknown'}. Post-render QA: ${meta.post_render_qa_passed === false ? 'failed' : 'passed/unknown'}.`;

      const headerRow = document.querySelector('main h1')?.parentElement?.querySelector('.flex.items-center.gap-2.mt-2');
      if (headerRow) {
        const dot = document.createElement('span');
        dot.className = 'text-sm text-zinc-300';
        dot.textContent = '·';
        headerRow.appendChild(dot);
        headerRow.appendChild(badge.cloneNode(true));
      }

      const audioCard = document.querySelector('audio')?.closest('.bg-zinc-900');
      if (audioCard) {
        const panel = document.createElement('div');
        panel.className = 'mt-3 rounded-xl bg-white/10 border border-white/10 px-3 py-2 text-xs text-zinc-200';
        panel.setAttribute('data-render-model-badge', 'true');
        panel.innerHTML = `
          <div class="font-semibold text-white">${label}</div>
          <div class="mt-0.5 text-zinc-400">${meta.generated_at ? `Rendered ${new Date(meta.generated_at).toLocaleString()}` : meta.inferred_from_filename ? 'Inferred from audio filename' : 'Render metadata available'}</div>
          ${meta.pre_render_qa_passed !== undefined ? `<div class="mt-1">Pre-render QA: ${meta.pre_render_qa_passed ? 'passed' : 'failed'}</div>` : ''}
          ${meta.post_render_qa_passed !== undefined ? `<div>Post-render QA: ${meta.post_render_qa_passed ? 'passed' : 'needs review'}</div>` : ''}
        `;
        audioCard.appendChild(panel);
      }
    };

    fetch(metaUrl)
      .then((res) => res.ok ? res.json() : null)
      .then((meta) => renderBadge(meta || inferFromAudioDom()))
      .catch(() => renderBadge(inferFromAudioDom()));
  })();
</script>

</body>
</html>
