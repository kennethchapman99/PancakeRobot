{
  "upload_url": "https://distrokid.com/new/",
  "stop_before_submit": true,
  "fields": {
    "artist": {
      "strategy": "label",
      "selector": "",
      "manifest_key": "artist",
      "note": "Example map is intentionally conservative. Run --discover-fields or Playwright codegen to map this field."
    },
    "release_title": {
      "strategy": "label",
      "selector": "",
      "manifest_key": "release_title",
      "note": "Run --discover-fields or Playwright codegen to map this field. Label text may match unrelated checkboxes."
    },
    "track_title": {
      "strategy": "label",
      "selector": "",
      "manifest_key": "track_title",
      "note": "Run --discover-fields or Playwright codegen to map this field. Label text may match unrelated radio inputs."
    },
    "audio_file": {
      "strategy": "inputFile",
      "selector": "",
      "manifest_key": "audio_file",
      "note": "Run --discover-fields or Playwright codegen to map this field. DistroKid may have multiple file inputs."
    },
    "cover_art": {
      "strategy": "inputFile",
      "selector": "",
      "manifest_key": "cover_art"
    },
    "primary_genre": {
      "strategy": "select",
      "selector": "",
      "manifest_key": "primary_genre"
    },
    "secondary_genre": {
      "strategy": "select",
      "selector": "",
      "manifest_key": "secondary_genre"
    },
    "language": {
      "strategy": "select",
      "selector": "",
      "manifest_key": "language"
    },
    "explicit": {
      "strategy": "radioOrCheckbox",
      "selector": "",
      "manifest_key": "explicit"
    },
    "lyrics": {
      "strategy": "textarea",
      "selector": "",
      "manifest_key": "lyrics_file"
    },
    "release_date": {
      "strategy": "date",
      "selector": "",
      "manifest_key": "release_date"
    },
    "made_for_kids": {
      "strategy": "radioOrCheckbox",
      "selector": "",
      "manifest_key": "made_for_kids"
    },
    "ai_generated": {
      "strategy": "radioOrCheckbox",
      "selector": "",
      "manifest_key": "is_ai_generated"
    }
  },
  "dangerous_buttons_never_click": [
    "Submit",
    "Done",
    "Finalize",
    "Release",
    "Upload to stores",
    "Continue & submit",
    "Save and submit",
    "Submit release",
    "Send to stores"
  ]
}
