ANTHROPIC_API_KEY=sk-ant-...
CF_ACCOUNT_ID=...
CF_API_TOKEN=...

# MiniMax music generation
# Default production model is music-2.6. Set MINIMAX_API_KEY to enable automatic renders.
MINIMAX_API_KEY=...
MINIMAX_MUSIC_MODEL=music-2.6

# Toggle this to audition with the free MiniMax model.
# true  = use music-2.6-free unless MINIMAX_MUSIC_MODEL is explicitly set
# false = use paid/default music-2.6
MINIMAX_USE_FREE_MODEL=false

# Only use for intentionally short jingles. Normal songs must pass the 220+ word QA gate.
PANCAKE_ALLOW_SHORT_SONGS=false

# Marketing release agent
# Builds Instagram + TikTok assets for manual posting. Autopublish stays false in this phase.
MARKETING_AUTOBUILD=true
MARKETING_OUTPUT_DIR=output/marketing-ready
MARKETING_DEFAULT_HANDLE=@pancakerobotmusic
MARKETING_DEFAULT_ARTIST=Pancake Robot
MARKETING_DEFAULT_CTA=Listen everywhere - link in bio
MARKETING_HOOK_SECONDS=15
MARKETING_CHARACTER_ASSET=
INSTAGRAM_AUTOPUBLISH=false
TIKTOK_AUTOPUBLISH=false

# Social publishing
SOCIAL_PUBLISH_MODE=dry_run
SOCIAL_REQUIRE_APPROVAL=true
PUBLIC_BASE_URL=http://localhost:3737

DAILY_SOCIAL_ENABLED=false
DAILY_SOCIAL_TIMEZONE=America/Toronto
DAILY_SOCIAL_REQUIRE_APPROVAL=true
DAILY_SOCIAL_PLATFORMS=instagram,facebook,youtube
DAILY_SOCIAL_INSTAGRAM_TIME=08:30
DAILY_SOCIAL_FACEBOOK_TIME=09:00
DAILY_SOCIAL_YOUTUBE_TIME=16:00

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3737/api/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
YOUTUBE_TOKEN_PATH=~/.pancake-robot/youtube_token.json

# Meta / Facebook / Instagram
META_GRAPH_VERSION=v25.0
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=

# Instagram
INSTAGRAM_IG_USER_ID=

# Facebook
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
