{
  "name": "music-pipeline",
  "version": "1.0.0",
  "description": "Profile-driven autonomous music production pipeline",
  "type": "module",
  "main": "src/orchestrator.js",
  "bin": {
    "pancakerobot": "./bin/pancakerobot"
  },
  "scripts": {
    "doctor": "node scripts/ensure-node-runtime.js",
    "pancake": "bash scripts/pancake.sh",
    "pancake:web": "bash scripts/pancake.sh web",
    "pancake:stack": "bash scripts/pancake.sh stack",
    "pancake:telegram": "bash scripts/pancake.sh telegram",
    "pancake:test": "bash scripts/pancake.sh test",
    "pancake:cleanup": "bash scripts/pancake.sh cleanup",
    "pancake:doctor": "bash scripts/pancake.sh doctor",
    "prestart": "node scripts/ensure-node-runtime.js",
    "start": "node src/orchestrator.js",
    "preweb": "node scripts/ensure-node-runtime.js",
    "web": "node --watch --import ./src/web/render-mode-preload.js --import ./src/web/marketing-song-detail-preload.js src/web/server.js",
    "predev:mobile": "node scripts/ensure-node-runtime.js",
    "dev:mobile": "node src/scripts/run-mobile-dev-stack.js",
    "setup": "node src/orchestrator.js --setup",
    "new": "node src/orchestrator.js --new",
    "magic": "node src/scripts/run-magic-pipeline-service.js",
    "release-stage": "node src/scripts/run-magic-release-stage.js",
    "album:repair": "node src/scripts/repair-album-batch.js",
    "album:resume": "node src/scripts/repair-album-batch.js --resume",
    "magic:legacy": "node src/orchestrator.js --magic",
    "magic:workflow": "node src/scripts/run-magic-song-workflow.js",
    "pretelegram": "node scripts/ensure-node-runtime.js",
    "telegram": "node src/inbound/telegram/bot.js",
    "workflow:runs": "node src/scripts/list-workflow-runs.js",
    "workflow:show": "node src/scripts/show-workflow-run.js",
    "workflow:admin": "node src/scripts/workflow-runs-admin.js",
    "new:paid": "MINIMAX_USE_FREE_MODEL=false MINIMAX_MUSIC_MODEL=music-2.6 node src/orchestrator.js --new",
    "new:free": "MINIMAX_USE_FREE_MODEL=true node src/orchestrator.js --new",
    "marketing": "node src/scripts/build-marketing-pack.js",
    "marketing:agent": "node src/scripts/run-marketing-agent.js",
    "release-selection": "node src/scripts/run-release-selection.js",
    "release-cockpit:cleanup-tests": "node scripts/cleanup-release-cockpit-test-data.js",
    "marketing:gmail:auth": "node src/scripts/marketing-gmail-auth.js",
    "marketing:gmail:reauth": "node src/scripts/marketing-gmail-reauth.js",
    "marketing:gmail:scan": "node src/scripts/scan-marketing-inbox.js",
    "marketing:targets:import": "node src/scripts/import-marketing-targets.js",
    "marketing:contacts:import": "node src/scripts/import-outreach-contacts-csv.js",
    "marketing:targets:match": "node src/scripts/match-release-targets.js",
    "marketing:targets:seed-test": "node src/scripts/seed-test-marketing-target.js",
    "marketing:outlets:seed": "node src/scripts/seed-marketing-outlets-to-targets.js",
    "marketing:outlets:doctor": "node src/scripts/doctor-marketing-outlets.js",
    "marketing:outlets:enrich": "node src/scripts/enrich-marketing-outlets.js",
    "finance:summary": "node src/scripts/finance-manager-cli.js summary",
    "finance:audit": "node src/scripts/finance-manager-cli.js audit",
    "finance:missing-prices": "node src/scripts/finance-manager-cli.js missing-prices",
    "finance:reprice": "node src/scripts/finance-manager-cli.js reprice",
    "catalog:repair-trigger": "node scripts/repair-song-catalog-trigger.js",
    "precatalog:cleanup": "node scripts/ensure-node-runtime.js",
    "catalog:cleanup": "node scripts/cleanup-song-catalog.js",
    "report": "node src/orchestrator.js --report",
    "research": "node src/orchestrator.js --research",
    "schedule": "node src/orchestrator.js --schedule",
    "suggest": "node src/orchestrator.js --suggest",
    "list": "node src/orchestrator.js --list",
    "verify-song": "node src/orchestrator.js --verify",
    "approve": "node src/orchestrator.js --approve",
    "reject": "node src/orchestrator.js --reject",
    "pretest": "node scripts/ensure-node-runtime.js",
    "test": "node scripts/repair-song-catalog-trigger.js && node --test",
    "test:marketing-router": "node src/scripts/smoke-test-marketing-router.js",
    "smoke:release-assets": "node src/scripts/smoke-release-assets.js",
    "smoke:cloudflare-tunnel": "node scripts/smoke-cloudflare-tunnel.js",
    "distrokid:save-auth": "node scripts/distrokid/save-auth.mjs",
    "distrokid:check-auth": "node scripts/distrokid/check-auth.mjs",
    "distrokid:package": "node scripts/distrokid/build-release-package.mjs",
    "distrokid:upload": "node scripts/distrokid/upload-release.mjs",
    "distrokid:batch": "node scripts/distrokid/batch-upload.mjs",
    "distrokid:queue": "node scripts/distrokid/queue-song.mjs",
    "distrokid:run-queued": "node scripts/distrokid/run-queued.mjs",
    "distrokid:mark-submitted": "node scripts/distrokid/mark-submitted.mjs",
    "distrokid:smoke": "node scripts/distrokid/smoke-test.mjs",
    "distrokid:ui-smoke": "node scripts/distrokid/ui-smoke-test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.9.0",
    "canvas": "^2.11.0",
    "chalk": "^5.0.0",
    "chart.js": "^4.0.0",
    "dotenv": "^16.0.0",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "googleapis": "^171.4.0",
    "inquirer": "^9.0.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.0",
    "ora": "^7.0.0"
  },
  "engines": {
    "node": "22.22.2"
  },
  "volta": {
    "node": "22.22.2"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
